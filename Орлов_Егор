//                     НАЛОГИ И ИНФЛЯЦИЯ


void pay_taxes(RUB income, RUB& taxes_paid, RUB& capital) 
{

    RUB tax = static_cast<RUB>(income * TAX_RATE);

    if (capital >= tax) 
    {
        capital -= tax;
        taxes_paid += tax;
    }

    else
    {
        // Если не хватает, берём из следующего дохода (упрощенно)
        capital = 0;
    }

}


void apply_inflation(int year) 
{

    if (year == SIMULATION_START_YEAR) 
    {
        return;
    }

    double factor = 1.0 + INFLATION_RATE_YEARLY;


    // Алиса
    alice.food = static_cast<RUB>(alice.food * factor);
    alice.transport = static_cast<RUB>(alice.transport * factor);
    alice.beauty = static_cast<RUB>(alice.beauty * factor);
    alice.health = static_cast<RUB>(alice.health * factor);
    alice.clothes = static_cast<RUB>(alice.clothes * factor);
    alice.entertainment = static_cast<RUB>(alice.entertainment * factor);


    // Макс
    max.food = static_cast<RUB>(max.food * factor);
    max.transport = static_cast<RUB>(max.transport * factor);
    max.sports = static_cast<RUB>(max.sports * factor);
    max.tools = static_cast<RUB>(max.tools * factor);
    max.gadgets = static_cast<RUB>(max.gadgets * factor);
    max.hobbies = static_cast<RUB>(max.hobbies * factor);

}




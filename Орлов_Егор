        place = "работа (совместный проект)";
    }

    else if (r < 55) 
    {
        place = "кафе";
    }

    else if (r < 75) 
    {
        place = "спортзал";
    }

    else if (r < 90)
    {
        place = "конференция/митап";
    }

    else 
    {
        place = "случайная встреча в парке";
    }


    // Время (год) знакомства – в пределах симуляции, допустим год от 2026 до 2034
    int meet_year = 2026 + rand() % 9;
    int meet_month = 1 + rand() % 12;


    std::cout << "Знакомство произошло в " << meet_month << "/" << meet_year << " в месте: " << place << ".\n";


    // Вероятность близкого общения зависит от места и времени
    double probability = 0.0;


    if (place == "работа (совместный проект)") 
    {
        probability = 0.8;
    }

    else if (place == "кафе") 
    {
        probability = 0.4;
    }

    else if (place == "спортзал") 
    {
        probability = 0.5;
    }

    else if (place == "конференция/митап") 
    {
        probability = 0.6;
    }

    else 
    {
        probability = 0.2;
    }


    // Чем позже знакомство, тем выше шанс (больше общих интересов)
    if (meet_year >= 2030) 
    {
        probability += 0.1;
    }

    if (meet_year >= 2033) 
    {
        probability += 0.1;
    }

    if (probability > 1.0) 
    {
        probability = 1.0;
    }
    

    int r2 = rand() % 100;
    bool close_communication = (r2 < probability * 100);

    if (close_communication)
    {
        std::cout << "Они начали близко общаться, стали хорошими друзьями (а возможно, и больше)!\n";


//                         КРЕДИТНЫЕ ФУНКЦИИ


void take_loan(Loan& loan, RUB amount, int months, double rate, RUB& capital)
{

    loan.amount_owed = amount;
    loan.months_left = months;
    loan.annual_rate = rate;
    loan.active = true;
    double monthly_rate = rate / 12 / 100;
    loan.monthly_payment = static_cast<RUB>(amount * monthly_rate / (1 - pow(1 + monthly_rate, -months)));
    capital += amount; // получаем сумму кредита
    std::cout << "Взят кредит на " << amount << " руб. на " << months << " мес. под " << rate << "% годовых. Ежемесячный платёж: " << loan.monthly_payment << " руб.\n";

}


void pay_loan(Loan& loan, RUB& capital)
{

    if (!loan.active) 
    {
        return;
    }

    if (capital >= loan.monthly_payment) 
    {
        capital -= loan.monthly_payment;
        loan.amount_owed -= loan.monthly_payment;
        loan.months_left--;

        if (loan.amount_owed <= 0 || loan.months_left <= 0) 
        {
            loan.active = false;
            std::cout << "✅ Кредит полностью погашен!\n";
        }

    }

    else 
    {
        // Просрочка
        loan.amount_owed += loan.amount_owed * 0.02;
        std::cout << "⚠️ Не хватает средств на оплату кредита! Долг увеличен.\n";
    }

}




// Функция генерации случайного варианта квартиры с вероятностями
Apartment generate_apartment_choice(const std::string& person_name) 
{

    Apartment apt;
    // случайный район: центр 20%, спальный 60%, пригород 20%
    int r = rand() % 100;

    if (r < 20)
    {
        apt.district = "центр";
        apt.price = 12'000'000 + (rand() % 5'000'000);
        apt.monthly_utilities = 8'000;
        apt.comfort_level = 8.0 + (rand() % 30) / 10.0;
    }

    else if (r < 80) 
    {
        apt.district = "спальный район";
        apt.price = 7'000'000 + (rand() % 3'000'000);
        apt.monthly_utilities = 5'000;
        apt.comfort_level = 5.0 + (rand() % 40) / 10.0;
    }

    else
    {
        apt.district = "пригород";
        apt.price = 5'000'000 + (rand() % 2'000'000);
        apt.monthly_utilities = 7'000;
        apt.comfort_level = 6.0 + (rand() % 30) / 10.0;
    }

    // тип квартиры: студия 20%, однушка 40%, двушка 30%, трешка 10%
    r = rand() % 100;

    if (r < 20) 
    {
        apt.type = "студия";
        apt.rooms = 1;
        apt.area = 28 + (rand() % 7);
        apt.has_balcony = (rand() % 2 == 0);
        apt.has_parking = false;
    }

    else if (r < 60) 
    {
        apt.type = "однушка";
        apt.rooms = 1;
        apt.area = 35 + (rand() % 10);
        apt.has_balcony = (rand() % 2 == 0);
        apt.has_parking = (rand() % 3 == 0);
    }

    else if (r < 90) 
    {
        apt.type = "двушка";
        apt.rooms = 2;
        apt.area = 50 + (rand() % 15);
        apt.has_balcony = true;
        apt.has_parking = (rand() % 2 == 0);
    }

    else
    {
        apt.type = "трешка";
        apt.rooms = 3;
        apt.area = 70 + (rand() % 20);
        apt.has_balcony = true;
        apt.has_parking = (rand() % 2 == 0);
    }


    apt.floor = 1 + (rand() % 20);
    apt.owned = false;
    apt.rented_out = false;
    apt.monthly_rent = apt.price * 0.005; // 0.5% от цены в месяц


    // Немного модификации цены в зависимости от района и типа
    if (apt.district == "центр") 
    {
        apt.price *= 1.3;
    }

    if (apt.type == "студия") 
    {
        apt.price *= 0.9;
    }

    if (apt.type == "трешка") 
    {
        apt.price *= 1.2;
    }

    return apt;

}



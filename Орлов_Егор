//                     НАКОПЛЕНИЯ/ИНВЕСТИЦИИ


void alice_investments() 
{

    // Переводим часть свободных средств в инвестиции
    if (alice.capital > 50'000) 
    {
        RUB to_invest = alice.capital * 0.2;
        if (to_invest > 100'000) to_invest = 100'000;
        alice.capital -= to_invest;
        alice.invest.cash += to_invest;

        // Распределяем между акциями и облигациями
        alice.invest.stocks += to_invest * 0.6;
        alice.invest.bonds += to_invest * 0.4;
    }

    // Рост инвестиций
    alice.invest.stocks = static_cast<RUB>(alice.invest.stocks * alice.invest.stock_growth);
    alice.invest.bonds = static_cast<RUB>(alice.invest.bonds * (1 + alice.invest.bond_coupon / 100));
    alice.invest.cash = alice.invest.cash * 1.003; // 0.3% по депозиту
    // Обналичивать не будем, просто капитал считаем отдельно

}


void max_investments() 
{

    if (max.capital > 50'000) 
    {
        RUB to_invest = max.capital * 0.25;

        if (to_invest > 150'000)
        {
            to_invest = 150'000;
        }

        max.capital -= to_invest;
        max.invest.cash += to_invest;
        max.invest.stocks += to_invest * 0.7;
        max.invest.bonds += to_invest * 0.3;

    }

    max.invest.stocks = static_cast<RUB>(max.invest.stocks * max.invest.stock_growth);
    max.invest.bonds = static_cast<RUB>(max.invest.bonds * (1 + max.invest.bond_coupon / 100));
    max.invest.cash = max.invest.cash * 1.003;

}



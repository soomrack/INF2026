void choose_apartment_alice(Alice& p)
{
    std::cout << "\nВЫБОР КВАРТИРЫ\n";
    std::cout << "Алиса решила подобрать квартиру.\n";
    std::cout << "Доступные варианты:\n";

    const int NUM_OPTIONS = 3;

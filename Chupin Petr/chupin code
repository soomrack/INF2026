
#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <stdlib.h> 
#include <time.h>

using RUB = long long int;

struct Car {
    RUB value;      
    RUB gas;     
    RUB tires;      
    RUB servise; 
    RUB parking;
    RUB WHSD;       
    RUB racingfees; 
    RUB taxes;
};

struct Loan {
    RUB Moneydebt;  
    RUB Moneypayment; 
    RUB Percentrate; 
    RUB Monthsterm;
};

struct Food {
    RUB energydrink;     
    int count_energy;
    RUB ciggarete;  
    int count_ciggarete;
    RUB restaurant;       
    RUB homefood;
};

struct Person {
    int health;
    RUB salary;
    RUB capital;
    RUB fitness;
    struct Car car;
    struct Loan loan;
    struct Food food;
};

struct Person Alice;
struct Person Michael;
float pp = 14.5;

void michael_init() {
    Michael.capital = 50000;
    Michael.salary = 150000;
    Michael.health = 100;

    Michael.food.ciggarete = 250;
    Michael.food.count_ciggarete = 0;  
    Michael.food.energydrink = 290;
    Michael.food.count_energy = 0;     
    Michael.food.homefood = 12000;
    Michael.food.restaurant = 0;       

    Michael.car.gas = 6000;            
    Michael.car.WHSD = 0;
    Michael.car.taxes = 1500;
    Michael.car.parking = 1000;
    Michael.car.tires = 20000;
    Michael.car.servise = 7000;
}

void michael_salary(const int month, const int year) {
    if (month == 1) {
        Michael.salary = (RUB)(Michael.salary * 1.05);
    }
    if ((month == 8) && (year == 2026)) {
        Michael.salary = (RUB)(Michael.salary * 1.5);
    }
    if (rand() % 500 == 0) { 
        Michael.salary = 0;
        printf("--- СОБЫТИЕ: Майкла уволили в %d году! ---\n", year);
    }
    Michael.capital += Michael.salary;
}

void michael_bank_interest() {
    Michael.capital += (RUB)(Michael.capital * (pp / 12.0 / 100.0));
}

void michael_fitness() {
    RUB cost = 1000; 
    int sessions = 8;
    Michael.capital -= (sessions * cost);
    Michael.health += (sessions / 4) * 2;
    if (Michael.health > 100) Michael.health = 100;

    if (rand() % 200 < 1) { 
        int injury = 3 + (rand() % 7);
        Michael.health -= injury;
        Michael.capital -= 2000;
        printf("--- СОБЫТИЕ: Легкая травма Майкла в зале! ---\n");
    }
}

void michael_lifestyle_impact() {
    if (Michael.food.count_ciggarete > 10) {
        Michael.health -= (Michael.food.count_ciggarete - 10) / 2;
    }
    Michael.health -= (Michael.food.count_energy / 5);

    int death_roll = rand() % 1000;
    int threshold = (Michael.health < 30) ? 5 : 0;

    if (death_roll < threshold) {
        Michael.health = 0;
        printf("--- СОБЫТИЕ: Остановка сердца Майкла! ---\n");
    }
    if (Michael.health < 0) Michael.health = 0;
}


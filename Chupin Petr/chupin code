}

void alice_fitness() {
    RUB cost = 5000; int sessions = 12;
    Alice.capital -= (sessions * cost);
    Alice.health += (sessions / 3) * 4;
    if (Alice.health > 100) Alice.health = 100;
    if (rand() % 100 < 3) {
        Alice.health -= (5 + rand() % 15);
        Alice.capital -= 10000;

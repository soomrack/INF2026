}

void alice_food() {
    RUB total_spent = 0;

    total_spent += Alice.food.count_ciggarete * Alice.food.ciggarete;
    total_spent += Alice.food.count_energy * Alice.food.energydrink;
    total_spent += Alice.food.homefood;

    Alice.capital -= total_spent;
}

void alice_car(int month) {
    Alice.capital -= Alice.car.gas;
    Alice.capital -= Alice.car.tires;
    Alice.capital -= Alice.car.WHSD;
    Alice.capital -= Alice.car.taxes;
    Alice.capital -= Alice.car.parking;
    if (month == 10 || month == 5) {
        Alice.capital -= Alice.car.tires;
        printf("--- СОБЫТИЕ: Алиса сменила резину на авто: -%lld RUB ---\n", Alice.car.tires);
    }
    if (month == 5) {
        Alice.capital -= Alice.car.servise;
        printf("--- СОБЫТИЕ: Плановое ТО автомобиля: -%lld RUB ---\n", Alice.car.servise);
    }
}

void simulation() {
    int month = 2, year = 2026;
    srand((unsigned int)time(NULL));

    while (!((month == 3) && (year == 2027))) {
        if (Alice.health > 0) {
            if (month >= 5 && month <= 9) alice_racing();
            alice_fitness();
            alice_lifestyle_impact();
            alice_food();
            alice_car(month);
            alice_bank_interest();
            alice_salary(month, year);
        }
        if (Michael.health > 0) {
            michael_fitness();
            michael_lifestyle_impact();
            michael_food();
            michael_car(month);
            michael_bank_interest();
            michael_salary(month, year);
        }

        if (++month == 13) { month = 1; year++; }
    }
}

int main() {
    system("chcp 1251 > nul");
    alice_init();
    michael_init();
    simulation();
    printf("\n--- ИТОГИ СИМУЛЯЦИИ ---\n");
    printf("ALICE:   Cap: %lld, HP: %d\n", Alice.capital, Alice.health);
    printf("MICHAEL: Cap: %lld, HP: %d\n", Michael.capital, Michael.health);
    return 0;
}

}

void michael_health_check() {
    int risk = rand() % 100;

        if (risk < 5) {
            printf("\n СОБЫТИЕ: Болезнь Майкла! Траты на лечение.\n");
            Alice.health -= 20;
            Alice.capital -= 50000;
        }
        else if (risk < 15) {
            Alice.health -= 2;
            Alice.capital -= 3000;
        }
}

void michael_food() {
    RUB total_spent = 0;

    total_spent += Michael.food.count_ciggarete * Michael.food.ciggarete;
    total_spent += Michael.food.count_energy * Michael.food.energydrink;
    total_spent += Michael.food.homefood;

    Michael.capital -= total_spent;
}

void michael_car(int month) {
    Michael.capital -= Michael.car.gas;
    Michael.capital -= Michael.car.tires;
    Michael.capital -= Michael.car.WHSD;
    Michael.capital -= Michael.car.taxes;
    Michael.capital -= Michael.car.parking;
    Michael.capital -= Michael.car.servise;
    if (month == 10 || month == 4) {
        Michael.capital -= Michael.car.tires;
        printf("--- СОБЫТИЕ: Майкл сменил резину на авто: -%lld RUB ---\n", Michael.car.tires);
    }
    if (month == 3) {
        Michael.capital -= Michael.car.servise;
        printf("--- СОБЫТИЕ: Плановое ТО автомобиля: -%lld RUB ---\n", Michael.car.servise);
    }
}

void michael_random_events() {
    if (rand() % 150 == 7) { 
        RUB bonus = 10000 + (rand() % 30000);
        Michael.capital += bonus;
        printf("--- СОБЫТИЕ: Премия Майклу! +%lld ---\n", bonus);
    }
}

void alice_init() {
    Alice.capital = 50000;
    Alice.salary = 150000;
    Alice.health = 100;
    Alice.food.ciggarete = 250;
    Alice.food.count_ciggarete = 12;
    Alice.food.energydrink = 290;
    Alice.food.count_energy = 30;
    Alice.food.homefood = 8000;
    Alice.food.restaurant = 10000;
    Alice.car.gas = 15000;
    Alice.car.WHSD = 4000;
    Alice.car.taxes = 2000;
    Alice.car.parking = 4000;
    Alice.car.tires = 20000;   
    Alice.car.servise = 10000;
}

void alice_salary(const int month, const int year) {
    if (month == 1) Alice.salary = (RUB)(Alice.salary * 1.05);
    if ((month == 8) && (year == 2026)) Alice.salary = (RUB)(Alice.salary * 1.5);

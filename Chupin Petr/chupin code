    int death_roll = rand() % 1000;
    int threshold = (Alice.health < 30) ? 10 : 0;
    if (Alice.food.count_energy > 40 && Alice.food.count_ciggarete > 30) threshold += 50;
    if (death_roll < threshold) Alice.health = 0;

void alice_food(const int month, const int year)
{
    if (month == 12) alice.vtb.account_rub -= 2000;  // christmas party

    alice.food += alice.food * (current_inflation / 100. / 12.);
        
    alice.vtb.account_rub -= alice.food;
    alice.total_expenses_lifetime += alice.food;
}

void alice_job(const int month, const int year)
{
    if (month == 3) {
        alice.job.salary *= 1.3; // был 1.2, теперь 1.3
    }
    if (month == 2 && year == 2026) {
        alice.vtb.account_rub += 10000; // было 5000
        alice.total_income_lifetime += 10000;
    }
    alice.vtb.account_rub += alice.job.salary;
    alice.total_income_lifetime += alice.job.salary;
    if (month == 9) {
        alice.job.bonus += 15000; // было 10000
    }

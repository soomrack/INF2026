struct Storage_Stack {
    ResourceID resource_id;
    int amount;
};

class Storage {
public:
    std::vector<Storage_Stack> items;

    void add(ResourceID resource_id, int amount);
    bool remove(ResourceID resource_id, int amount);
    int get_amount(ResourceID resource_id);
};

Storage storage = {
    {
        {Oats, 1900}, // овес
        {Barley, 1500}, // ячмень
        {Rye, 1400},  // рожь
        {Wheat, 1600}  // пшеница
    }
};


void Storage::add(ResourceID resource_id, int amount) {
    for (auto& item : items) {
        if (item.resource_id == resource_id) {
            item.amount += amount;
            return;
        }
    }
    items.push_back({ resource_id, amount });
}

bool Storage::remove(ResourceID resource_id, int amount) {
    for (auto& item : items) {
        if (item.resource_id == resource_id) {
            if (item.amount < amount) return false; // недостаточно ресурса для удаления

            item.amount -= amount;
            return true;


        }
    }
    return false;
}

int Storage::get_amount(ResourceID resource_id) {
    for (auto& item : items) {
        if (item.resource_id == resource_id) {
            return item.amount;
        }
    }
    return 0;
}


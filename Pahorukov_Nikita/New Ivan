// Весна: посадка культуры
void plant_crop(Month month) {

    if (month != April and month != September) return;

    if (barin.how_many_years == 0) {
        barin.random_barin_order();
    }

    if (month == April) {
        for (auto& field : fields) {
            if (field.type == Summer_type) {

                ResourceID grain_to_plant = ResourceID(barin.forced_summer_crop);

                int grain_index = static_cast<int>(grain_to_plant);

                int max_needed = field.area * grains[grain_index].kg_for_desyatina;

                int available = storage.get_amount(grain_to_plant);

                int planted = std::min(max_needed, available);

                if (planted == 0) {
                    std::cout << "Not enough " << resources[grain_to_plant].name << "\n";
                    break;
                }

                storage.remove(grain_to_plant, planted);

                std::cout << "April: Planted summer_culture " << planted << " kg of "
                    << resources[grain_to_plant].name << "\n";

                field.current_grain = grain_to_plant;
                field.planted_kg = planted;
                field.is_planted = true;
            }
        }
    }

    if (month == September) {
        for (auto& field : fields) {
            if (field.type == Winter_type) {

                ResourceID grain_to_plant = ResourceID(barin.forced_winter_crop);

                int grain_index = static_cast<int>(grain_to_plant);

                int max_needed = field.area * grains[grain_index].kg_for_desyatina;

                int available = storage.get_amount(grain_to_plant);

                int planted = std::min(max_needed, available);

                if (planted == 0) {
                    std::cout << "Not enough " << resources[grain_to_plant].name << "\n";
                    break;
                }

                storage.remove(grain_to_plant, planted);

                std::cout << "September: Planted summer_culture " << planted << " kg of "
                    << resources[grain_to_plant].name << "\n";

                field.current_grain = grain_to_plant;
                field.planted_kg = planted;
                field.is_planted = true;
            }
        }
    }
}
// Лето: сбор урожая
void harvest_crop(Month month) {

    if (month == January) {
        double random_harvest_coeff = Random::weighted(harvest_chance);
        std::cout << random_harvest_coeff << "\n";
        
        for (auto& field : fields) {
            field.current_random_harvest_coeff = random_harvest_coeff;
        }
    }

    if (month != July and month != August) return;

    if (month == July) {
        for (auto& field : fields) {
            if (field.type == Winter_type and field.is_planted == true) {

                int grown_harvest = field.planted_kg * field.current_random_harvest_coeff;

                int obrok = grown_harvest * barin.percent_obrok;

                int ivan_part = grown_harvest - obrok;

                storage.add(field.current_grain, ivan_part);

                std::cout << "July: Croped winter_culture " << grown_harvest << " kg of "
                    << resources[field.current_grain].name << "\n";
                std::cout << "Ivan take his part " << ivan_part << " kg of "
                    << resources[field.current_grain].name << "\n";

                field.type = Summer_type;

                field.is_planted = false;
                field.planted_kg = 0;

                field.current_grain = NO_RESOURCE;

            }
        }
    }
    if (month == August) {
        for (auto& field : fields) {
            if (field.type == Chill_type) {
                field.type = Winter_type;
            }

            if (field.type == Summer_type and field.is_planted == true) {

                int grown_harvest = field.planted_kg * field.current_random_harvest_coeff;

                int obrok = grown_harvest * barin.percent_obrok;
                int ivan_part = grown_harvest - obrok;

                storage.add(field.current_grain, ivan_part);

                std::cout << "August: Croped summer_culture " << grown_harvest << " kg of "
                    << resources[field.current_grain].name << "\n";
                std::cout << "Ivan take his part " << ivan_part << " kg of "
                    << resources[field.current_grain].name << "\n";

                field.type = Chill_type;

                field.is_planted = false;
                field.planted_kg = 0;

                field.current_grain = NO_RESOURCE;
            }
        }
    }
    /*for (auto& field : fields) {
        std::cout << field.field_number << " " << field.type << "\n";
    }*/
}

// Основная функция обработки сезона
void process_cropping(Month month) {
    plant_crop(month);
    harvest_crop(month);

}



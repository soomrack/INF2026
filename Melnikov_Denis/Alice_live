/// Степень тяжести болезни
enum class illness_severity { none, mild, moderate, severe };

/// Описание одного типа болезни
struct illness_type
{
    std::string      name;            ///< Название болезни
    illness_severity severity;        ///< Тяжесть
    int              min_days;        ///< Минимальная длительность (дней)
    int              max_days;        ///< Максимальная длительность (дней)
    RUB              doctor_cost;     ///< Стоимость визита к врачу
    RUB              medicine_min;    ///< Минимальная стоимость лекарств
    RUB              medicine_max;    ///< Максимальная стоимость лекарств
    float            chance_per_month;///< Шанс заболеть в месяц (%)
    float            food_multiplier; ///< Модификатор расходов на еду
};


// ============================================================
//  Жизнь Алисы
// ============================================================

void alice_start()
{
    Alice.age = 24;
    Alice.salary = 20'000;   // начальная зарплата
    Alice.base_salary = 20'000;   // запоминаем для расчёта роста
    Alice.sber.account_rub = 0;

    // Автомобиль
    Alice.car.car_cost = 4'000'000;
    Alice.car.current_value = 4'000'000; // начальная рыночная стоимость
    Alice.car.horsepower = 150;
    Alice.car.liters_per_100km = 9.5f;
    Alice.car.km_per_day = 40.0f;
    Alice.car.fuel_price = 58.0f;

    // Сбрасываем статистику
    Alice.total_sick_days = 0;
    Alice.total_medical_cost = 0;
    Alice.total_lost_salary = 0;
    Alice.total_fuel_cost = 0;
    Alice.total_transport_tax = 0;
    Alice.total_car_repair_cost = 0;
    Alice.total_car_incidents = 0;

    Alice.apartment_level = -1;
    Alice.total_property_tax = 0;

    // Сбрасываем флаги жизненных событий
    Alice.is_married = false;
    Alice.has_first_child = false;
    Alice.is_grandmother = false;
    Alice.is_retired = false;
    Alice.passport_renewed = false;

    // Глобальный счётчик месяцев
    g_total_months_elapsed = 0;
}


void alice_live()
{
    static std::mt19937 vacation_gen(std::random_device{}());
    static std::mt19937 illness_gen(std::random_device{}());
    static std::mt19937 car_gen(std::random_device{}());

    int month = 1;

    while (month < 13)
    {
        // ── 0. Возрастные события (в начале каждого нового года жизни) ──
        if (month == 1)
        {
            switch (Alice.age)
            {
            case 30: check_age_events(30); break; // замужество
            case 32: check_age_events(32); break; // рождение ребёнка
            case 45: check_age_events(45); break; // замена паспорта
            case 64: check_age_events(64); break; // стала бабушкой
            case 65: check_age_events(65); break; // выход на пенсию
            default: break;
            }
        }

        // ── 0а. Ежегодный рост зарплаты (только в январе, до пенсии) ───
        if (month == 1 && !Alice.is_retired && Alice.age > 24)
        {
            // Зарплата растёт с карьерой + покрытие инфляции
            RUB new_salary = static_cast<RUB>(
                Alice.base_salary * salary_growth_factor() * inflation_factor());
            if (new_salary > Alice.salary)
                Alice.salary = new_salary;
        }

        // ── 0б. Амортизация автомобиля ───────────────────────────────────
        Alice.car.depreciate();

        const bool is_vacation_month = (month == 7);

        // ── 1. Генерация болезни ──────────────────────────────
        illness_result illness = generate_illness(illness_gen);

        // ── 2. Случайные события ─────────────────────────────
        month_result events = generate_monthly_events();
        Alice.sber.account_rub += events.total_income;

        // ── 3. Зарплата ───────────────────────────────────────
        {
            RUB daily_salary = Alice.salary / 22;
            int unpaid_days = 0;

            if (illness.sick)
            {
                switch (illness.severity)
                {
                case illness_severity::mild:
                    unpaid_days = std::min(illness.days, 2);
                    break;
                case illness_severity::moderate:
                case illness_severity::severe:
                    unpaid_days = illness.days;
                    break;
                default: break;
                }
            }

            illness.lost_salary = daily_salary * unpaid_days;
            RUB reduced_salary = std::max(0L, Alice.salary - illness.lost_salary);
            RUB tax = taxes_state.calc_income_tax(reduced_salary);
            Alice.sber.account_rub += reduced_salary - tax;
        }

        // ── 4. Расходы на еду (с учётом инфляции через price_catalog) ────
        Alice.food_cost = Food(month, Alice.fridge, Alice.salary,
            illness.sick ? illness.days : 0);
        Alice.sber.account_rub -= Alice.food_cost;

        // ── 5. Расходы на бензин (цена растёт с инфляцией) ───────────────
        if (!Alice.is_retired)
        {
            fuel_params fp{
                Alice.car.km_per_day,
                Alice.car.liters_per_100km,
                Alice.car.fuel_price,
                22
            };
            int sick_work_days = illness.sick ? std::min(illness.days, 22) : 0;
            RUB fuel_cost = calc_monthly_fuel_cost(fp, sick_work_days);
            Alice.sber.account_rub -= fuel_cost;
            Alice.total_fuel_cost += fuel_cost;
        }
        else
        {
            // На пенсии — только личные поездки (~25% от рабочего расхода)
            fuel_params fp{
                Alice.car.km_per_day * 0.25f,
                Alice.car.liters_per_100km,
                Alice.car.fuel_price,
                22
            };
            RUB fuel_cost = calc_monthly_fuel_cost(fp, 0);
            Alice.sber.account_rub -= fuel_cost;
            Alice.total_fuel_cost += fuel_cost;
        }

        // ── 6а. Покупка/улучшение квартиры (раз в год, в декабре) ────────
        if (month == 12)
        {
            const auto& catalog = apartment_catalog();
            int next_level = Alice.apartment_level + 1;
            if (next_level < static_cast<int>(catalog.size()))
            {
                const Apartment& next_apt = catalog[next_level];
                // Стоимость квартиры также растёт с инфляцией
                RUB inflated_price = inflate(next_apt.price);
                RUB needed = static_cast<RUB>(inflated_price * 1.2);
                if (Alice.sber.account_rub >= needed)
                {
                    Alice.sber.account_rub -= inflated_price;
                    Alice.apartment_level = next_level;
                }
            }
        }

        // ── 6б. Налог на имущество (раз в год, в декабре) ────────────────
        if (month == 12 && Alice.apartment_level >= 0)
        {
            const Apartment& apt = apartment_catalog()[Alice.apartment_level];
            // Кадастровая стоимость тоже индексируется
            RUB inflated_cadastral = inflate(apt.cadastral_value);
            RUB prop_tax = taxes_state.calc_property_tax(inflated_cadastral);
            RUB actual = std::min(prop_tax, std::max(0L, Alice.sber.account_rub));
            Alice.sber.account_rub -= actual;
            Alice.total_property_tax += actual;
        }

        // ── 6в. Транспортный налог (раз в год, в декабре) ────────────────
        if (month == 12)
        {
            // Транспортный налог: ставка * л.с. (ставка тоже индексируется)
            float inflated_rate = taxes_state.transport_tax_rate * inflation_factor();
            RUB transport_tax = static_cast<RUB>(Alice.car.horsepower * inflated_rate);
            RUB actual_tax = std::min(transport_tax, std::max(0L, Alice.sber.account_rub));
            Alice.sber.account_rub -= actual_tax;
            Alice.total_transport_tax += actual_tax;
        }

        // ── 7. Случайное событие с машиной ───────────────────────────────
        {
            car_event_result car_ev = generate_car_event(car_gen);
            if (car_ev.happened)
            {
                RUB actual_repair = std::min(car_ev.total_cost,
                    std::max(0L, Alice.sber.account_rub));
                Alice.sber.account_rub -= actual_repair;
                Alice.total_car_repair_cost += actual_repair;
                ++Alice.total_car_incidents;
            }
        }

        // ── 8. ТО автомобиля ──────────────────────────────────────────────
        {
            RUB service_cost = alice_service_station(month, 0);
            RUB actual = std::min(service_cost, std::max(0L, Alice.sber.account_rub));
            Alice.sber.account_rub -= actual;
        }

        // ── 9. Медицинские расходы ────────────────────────────────────────
        if (illness.sick)
        {
            RUB medical_total = illness.doctor_cost + illness.medicine_cost;
            RUB actual_payment = std::min(medical_total, std::max(0L, Alice.sber.account_rub));
            Alice.sber.account_rub -= actual_payment;

            Alice.total_sick_days += illness.days;
            Alice.total_medical_cost += actual_payment;
            Alice.total_lost_salary += illness.lost_salary;
        }

        // ── 10. Отпуск (июль) ─────────────────────────────────────────────
        if (is_vacation_month)
        {
            auto [vacation_cost, vac_saved] = alice_vacation(vacation_gen, illness);
            illness.vacation_savings = vac_saved;
        }

        // ── 11. Переход к следующему месяцу/году ──────────────────────────
        ++month;
        ++g_total_months_elapsed; // обновляем глобальный счётчик
        if (month == 13)
        {
            Alice.age++;
            month = 1;
        }
        if (Alice.age == 97) break;
    }
}

// ============================================================
//  Итоги жизни Алисы
// ============================================================

void alice_conclusion()
{
    // Считает "визуальную" ширину строки для setw.
    auto vis_len = [](const std::string& s) -> int {
        int len = 0;
        for (unsigned char c : s)
            if ((c & 0xC0) != 0x80) ++len; // первые байты UTF-8
        return len;
        };

    constexpr int W = 54; // ширина содержимого рамки (визуальная)

    // ── Горизонтальная линия ─────────────────────────────────
    auto hline = [](char c = '-') {
        std::cout << std::setfill(c) << std::setw(W + 2) << "" << std::setfill(' ') << "\n";
        };

    // ── Заголовок секции ─────────────────────────────────────
    auto title = [&](const std::string& s) {
        std::string padded = " " + s;
        int pad = W - vis_len(padded);
        std::cout << "|" << padded << std::string(std::max(0, pad), ' ') << "|\n";
        };

    // ── Строка таблицы (метка + значение) ────────────────────
    constexpr int WL = 34;
    constexpr int WR = 16;
    auto row = [&](const std::string& label, const std::string& value) {
        int lpad = WL - vis_len(label);
        int rpad = WR - vis_len(value);
        std::cout << "|  " << label << std::string(std::max(0, lpad), ' ')
            << std::string(std::max(0, rpad), ' ') << value << "  |\n";
        };
    auto row_rub = [&](const std::string& label, RUB value) {
        row(label, std::to_string(value) + " руб.");
        };

    // ── Центрированная строка ─────────────────────────────────
    auto center_line = [&](const std::string& s) {
        int vl = vis_len(s);
        int left_pad = (W - vl) / 2;
        int right_pad = W - vl - left_pad;
        std::cout << "|" << std::string(left_pad, ' ') << s
            << std::string(right_pad, ' ') << "|\n";
        };

    // ══════════════════════ ШАПКА ══════════════════════════
    std::cout << "\n";
    hline('=');
    center_line("ИСТОРИЯ ЖИЗНИ АЛИСЫ");
    hline('=');
    std::cout << "\n";

    // ══════════════════ ХРОНИКА СОБЫТИЙ ════════════════════
    auto life_event = [](const char* tag, const std::string& text) {
        std::cout << std::left << std::setw(11) << tag << text << "\n";
        };

    life_event("[24 года]", "Начало самостоятельной жизни. Зарплата 20 000 руб.,");
    std::cout << std::setw(11) << "" << "автомобиль за 4 000 000 руб.\n";
    if (Alice.is_married)
        life_event("[30 лет] ", "Вышла замуж. Свадьба, кольца, счастье.");
    if (Alice.has_first_child)
        life_event("[32 года]", "Родился первый ребёнок. Декрет, бессонные ночи.");
    if (Alice.passport_renewed)
        life_event("[45 лет] ", "Сходила в МФЦ — поменяла паспорт.");
    if (Alice.apartment_level >= 0)
    {
        const Apartment& best = apartment_catalog()[Alice.apartment_level];
        std::cout << std::left << std::setw(11) << "[жильё]"
            << "\"" << best.name << "\" (" << best.area_sqm << " кв.м)\n";
    }
    if (Alice.is_grandmother)
        life_event("[64 года]", "Стала бабушкой. Подарки, радость, новый круг.");
    if (Alice.is_retired)
        life_event("[65 лет] ", "Вышла на пенсию. Торт, цветы, свобода.");
    std::cout << "\n";

    // ══════════════════ ТАБЛИЦА: ЗДОРОВЬЕ ══════════════════
    hline('-');
    title("  ЗДОРОВЬЕ");
    hline('-');
    row_rub("Дней на больничном", Alice.total_sick_days);
    row_rub("Расходы на медицину", Alice.total_medical_cost);
    row_rub("Потери зарплаты (болезни)", Alice.total_lost_salary);
    hline('-');
    if (Alice.total_sick_days < 200)
        title("  Отличное здоровье — редко брала больничный.");
    else if (Alice.total_sick_days < 600)
        title("  Болела регулярно, но всегда справлялась.");
    else
        title("  Здоровье доставляло немало хлопот.");
    std::cout << "\n";

    // ══════════════════ ТАБЛИЦА: АВТОМОБИЛЬ ════════════════
    hline('-');
    title("  АВТОМОБИЛЬ");
    hline('-');
    row_rub("Расходы на бензин", Alice.total_fuel_cost);
    row_rub("Транспортный налог", Alice.total_transport_tax);
    row_rub("Ремонты (инциденты)", Alice.total_car_repair_cost);
    row("Количество происшествий", std::to_string(Alice.total_car_incidents) + " шт.");
    row_rub("Остаточная стоимость авто", Alice.car.current_value);
    RUB total_car = Alice.total_fuel_cost + Alice.total_transport_tax
        + Alice.total_car_repair_cost;
    hline('-');
    row_rub("ИТОГО на автомобиль", total_car);
    hline('-');
    if (Alice.total_car_incidents == 0)
        title("  Ни единой аварии — повезло!");
    else
        title("  С машиной случалось всякое.");
    std::cout << "\n";

    // ══════════════════ ТАБЛИЦА: ЖИЛЬЁ ═════════════════════
    hline('-');
    title("  ЖИЛЬЁ");
    hline('-');
    if (Alice.apartment_level < 0)
    {
        title("  Собственной квартиры так и не появилось.");
        title("  Всю жизнь снимала или жила с родственниками.");
    }
    else
    {
        const Apartment& apt = apartment_catalog()[Alice.apartment_level];
        row("Последняя квартира", apt.name);
        row("Площадь", std::to_string(apt.area_sqm) + " кв.м");
        row_rub("Цена покупки (базовая)", apt.price);
        row_rub("Кадастровая стоимость", apt.cadastral_value);
        row_rub("Налог на имущество", Alice.total_property_tax);
        hline('-');
        if (Alice.apartment_level == 0)
            title("  Скромный, но свой угол — это тоже немало.");
        else if (Alice.apartment_level <= 2)
            title("  Хорошая квартира, нажитая честным трудом.");
        else
            title("  Роскошное жильё — итог всей жизни.");
    }
    std::cout << "\n";

    // ══════════════════ ТАБЛИЦА: ИНФЛЯЦИЯ ══════════════════
    hline('-');
    title("  ИНФЛЯЦИЯ И РОСТ ЦЕН");
    hline('-');
    {
        std::ostringstream oss;
        oss << std::fixed << std::setprecision(2) << inflation_factor();
        row("Итоговый множитель инфляции", "x" + oss.str());
    }
    {
        std::ostringstream oss;
        oss << std::fixed << std::setprecision(0)
            << (inflation_factor() - 1.0f) * 100.0f << "%";
        row("Рост цен за жизнь", oss.str());
    }
    row_rub("Зарплата в конце жизни", Alice.salary);
    row_rub("Остаточная стоимость авто", Alice.car.current_value);
    hline('-');
    std::cout << "\n";

    // ══════════════════ ТАБЛИЦА: ФИНАНСЫ ═══════════════════
    hline('-');
    title("  ФИНАНСОВЫЙ ИТОГ");
    hline('-');
    row_rub("Баланс RUB", Alice.sber.account_rub);
    if (Alice.sber.account_usd > 0)
        row("Баланс USD", std::to_string(Alice.sber.account_usd) + " $");
    if (Alice.sber.account_eur > 0)
        row("Баланс EUR", std::to_string(Alice.sber.account_eur) + " €");
    RUB total = Alice.sber.total_assets_rub();
    hline('-');
    row_rub("ИТОГО активов (в руб.)", total);
    hline('-');

    // Процентная разбивка расходов
    RUB total_spent = Alice.total_medical_cost
        + Alice.total_fuel_cost + Alice.total_transport_tax
        + Alice.total_car_repair_cost
        + Alice.total_property_tax;
    if (total_spent > 0)
    {
        auto pct_str = [&](RUB part) -> std::string {
            std::ostringstream oss;
            oss << std::fixed << std::setprecision(1)
                << (part * 100.0 / total_spent) << "%";
            return oss.str();
            };
        row("Медицина (% расходов)", pct_str(Alice.total_medical_cost));
        row("Автомобиль (% расходов)", pct_str(Alice.total_fuel_cost
            + Alice.total_transport_tax
            + Alice.total_car_repair_cost));
        row("Имущество (% расходов)", pct_str(Alice.total_property_tax));
        hline('-');
    }

    if (total <= 0)
        title("  Жизнь прожита на полную — денег не осталось.");
    else if (total < 500'000)
        title("  Скромные сбережения, зато прожита честно.");
    else if (total < 5'000'000)
        title("  Приличная сумма — есть что оставить детям.");
    else
        title("  Финансовый гений своего времени.");

    std::cout << "\n";
    hline('=');
    center_line("К О Н Е Ц");
    hline('=');
    std::cout << "\n";
}


int main()
{
    setlocale(LC_ALL, "ru");
    alice_start();
    alice_live();   
    alice_conclusion();
}

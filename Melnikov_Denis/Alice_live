/// Количество месяцев, прошедших с начала симуляции
static int g_total_months_elapsed = 0;

/// Базовый год симуляции — 2024
static constexpr int BASE_YEAR = 2024;

/// Годовая инфляция (8%)
static constexpr float ANNUAL_INFLATION_RATE = 0.08f;

/// Годовой рост зарплаты (5%)
static constexpr float ANNUAL_SALARY_GROWTH = 0.05f;

/// Коэффициент амортизации автомобиля в месяц (0.4% в месяц)
static constexpr float MONTHLY_CAR_DEPRECIATION = 0.004f;

// ── Вычислить накопленный инфляционный множитель ─────────────
/// Возвращает во сколько раз выросли цены за прошедшие месяцы
inline float inflation_factor()
{
    float years = static_cast<float>(g_total_months_elapsed) / 12.0f;
    return std::pow(1.0f + ANNUAL_INFLATION_RATE, years);
}

// ── Вычислить множитель роста зарплаты ───────────────────────
/// Возвращает коэффициент роста зарплаты за прошедшие месяцы
inline float salary_growth_factor()
{
    float years = static_cast<float>(g_total_months_elapsed) / 12.0f;
    return std::pow(1.0f + ANNUAL_SALARY_GROWTH, years);
}

// ── Применить инфляцию к рублёвой сумме ─────────────────────
/// Масштабирует базовую сумму с учётом текущей инфляции
inline RUB inflate(RUB base_amount)
{
    return static_cast<RUB>(base_amount * inflation_factor());
}


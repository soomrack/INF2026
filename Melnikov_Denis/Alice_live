/// Результат автомобильного инцидента
struct car_event_result
{
    bool        happened = false; ///< Произошло ли событие
    std::string name;               ///< Название события
    RUB         repair_cost = 0;    ///< Стоимость ремонта
    RUB         tow_cost = 0;    ///< Стоимость эвакуации
    RUB         total_cost = 0;    ///< Итого
};

/// Сгенерировать автомобильный инцидент с учётом инфляции
car_event_result generate_car_event(std::mt19937& gen)
{
    car_event_result result;
    const auto& catalog = car_event_catalog();

    std::uniform_real_distribution<float> roll(0.0f, 100.0f);
    if (roll(gen) > 40.0f)
        return result; // в этом месяце ничего не случилось

    std::vector<int> weights;
    for (const auto& ev : catalog)
        weights.push_back(static_cast<int>(ev.chance * 100));
    std::discrete_distribution<> dist(weights.begin(), weights.end());
    const car_event& chosen = catalog[dist(gen)];

    result.happened = true;
    result.name = chosen.name;

    std::uniform_int_distribution<> cost_dist(
        static_cast<int>(chosen.repair_min),
        static_cast<int>(chosen.repair_max));
    // Стоимость ремонта растёт вместе с инфляцией
    result.repair_cost = inflate(static_cast<RUB>(cost_dist(gen)));

    if (chosen.needs_tow)
    {
        std::uniform_int_distribution<> tow_dist(3'000, 7'000);
        result.tow_cost = inflate(static_cast<RUB>(tow_dist(gen)));
    }

    result.total_cost = result.repair_cost + result.tow_cost;
    return result;
}


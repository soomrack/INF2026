/// Результат генерации болезни за месяц
struct illness_result
{
    bool             sick = false;         ///< Болела ли
    std::string      name;                              ///< Название болезни
    illness_severity severity = illness_severity::none;
    int              days = 0;             ///< Дней болезни
    RUB              doctor_cost = 0;             ///< Расходы на врача
    RUB              medicine_cost = 0;             ///< Расходы на лекарства
    float            food_multiplier = 1.0f;          ///< Модификатор еды
    RUB              lost_salary = 0;             ///< Потеряно зарплаты
    RUB              vacation_savings = 0;             ///< Сэкономлено на отпуске
};

/// Сгенерировать событие болезни с учётом инфляции на медицину
illness_result generate_illness(std::mt19937& gen)
{
    illness_result result;
    const auto& catalog = illness_catalog();

    // Суммарный шанс заболеть
    float total_chance = 0.0f;
    for (const auto& ill : catalog) total_chance += ill.chance_per_month;

    std::uniform_real_distribution<float> roll(0.0f, 100.0f);
    if (roll(gen) > std::min(total_chance, 55.0f))
        return result; // не заболела

    // Выбираем конкретную болезнь
    std::vector<int> weights;
    for (const auto& ill : catalog)
        weights.push_back(static_cast<int>(ill.chance_per_month * 100));
    std::discrete_distribution<> dist(weights.begin(), weights.end());
    const illness_type& chosen = catalog[dist(gen)];

    result.sick = true;
    result.name = chosen.name;
    result.severity = chosen.severity;
    result.food_multiplier = chosen.food_multiplier;

    std::uniform_int_distribution<> days_dist(chosen.min_days, chosen.max_days);
    result.days = days_dist(gen);

    // Посещение врача: при тяжёлых всегда, при лёгких — 60%
    bool visits_doctor = (chosen.severity != illness_severity::mild) || (roll(gen) < 60.0f);
    // Стоимость врача растёт с инфляцией
    result.doctor_cost = visits_doctor ? inflate(chosen.doctor_cost) : 0;

    // Стоимость лекарств тоже растёт
    std::uniform_int_distribution<> med_dist(
        static_cast<int>(chosen.medicine_min),
        static_cast<int>(chosen.medicine_max));
    result.medicine_cost = inflate(static_cast<RUB>(med_dist(gen)));

    return result;
}


/// Стоимость ТО автомобиля за данный месяц (с учётом инфляции)
RUB alice_service_station(const int month, [[maybe_unused]] const int mileage)
{
    RUB cost_of_repair = 0;

    // Базовые стоимости запчастей и расходников (с инфляцией)
    std::map<std::string, RUB> parts_costs
    {
        {"filter_oil",    inflate(1'000)},
        {"filter_air",    inflate(750)},
        {"filter_fuel",   inflate(10'000)},
        {"filter_cabin",  inflate(5'600)},
        {"antifreeze",    inflate(2'400)},
        {"break_fluid",   inflate(9'000)},
        {"motor_oil",     inflate(5'000)},
        {"spark_plugs",   inflate(10'000)},
    };

    // Июль — полное ТО (замена всех расходников)
    if (month == 7)
        for (const auto& [product, price] : parts_costs)
            cost_of_repair += price;

    // Ежемесячная мойка и мелкие расходы
    cost_of_repair += inflate(500);
    return cost_of_repair;
}


/// Симулировать отпуск Алисы — возвращает (потрачено, сэкономлено)
std::pair<RUB, RUB> alice_vacation(std::mt19937& gen, const illness_result& illness)
{
    vacation_profile profile = get_vacation_style(Alice.salary);

    // Веса зон в зависимости от стиля жизни
    std::vector<int> zone_weights;
    switch (profile.style)
    {
    case vacation_style::backpacker: zone_weights = { 30, 30, 40 }; break;
    case vacation_style::budget:     zone_weights = { 35, 35, 30 }; break;
    case vacation_style::comfort:    zone_weights = { 40, 40, 20 }; break;
    case vacation_style::luxury:     zone_weights = { 45, 50,  5 }; break;
    case vacation_style::elite:      zone_weights = { 40, 58,  2 }; break;
    }
    std::discrete_distribution<> zone_dist(zone_weights.begin(), zone_weights.end());
    vacation_currency_zone zone = static_cast<vacation_currency_zone>(zone_dist(gen));

    // Бюджет отпуска с учётом инфляции
    RUB vacation_budget_rub = static_cast<RUB>(
        Alice.salary * 12 * profile.budget_share * inflation_factor());
    if (vacation_budget_rub > Alice.sber.account_rub)
        vacation_budget_rub = Alice.sber.account_rub / 2;

    // Конвертируем деньги в нужную валюту
    switch (zone)
    {
    case vacation_currency_zone::EUR:
        if (Alice.sber.account_rub >= vacation_budget_rub)
            Alice.sber.rub_to_eur(vacation_budget_rub);
        break;
    case vacation_currency_zone::USD:
        if (Alice.sber.account_rub >= vacation_budget_rub)
            Alice.sber.rub_to_usd(vacation_budget_rub);
        break;
    case vacation_currency_zone::RUB:
        break;
    }

    const std::vector<vacation_destination>* dest_pool = nullptr;
    switch (zone)
    {
    case vacation_currency_zone::EUR: dest_pool = &vacation_pool::eur_destinations(); break;
    case vacation_currency_zone::USD: dest_pool = &vacation_pool::usd_destinations(); break;
    case vacation_currency_zone::RUB: dest_pool = &vacation_pool::rub_destinations(); break;
    }

    std::uniform_int_distribution<> dest_dist(0, (int)dest_pool->size() - 1);
    const vacation_destination& dest = (*dest_pool)[dest_dist(gen)];

    // Базовая стоимость перелёта (с инфляцией)
    RUB base_flight_cost = 0;
    switch (zone)
    {
    case vacation_currency_zone::EUR: base_flight_cost = inflate(35'000); break;
    case vacation_currency_zone::USD: base_flight_cost = inflate(55'000); break;
    case vacation_currency_zone::RUB: base_flight_cost = inflate(10'000); break;
    }

    int days = profile.vacation_days;
    int sick_days = illness.sick ? std::min(illness.days, days) : 0;
    int well_days = days - sick_days;

    // Расчёт стоимостей с учётом инфляции на услуги
    float inf = inflation_factor();
    RUB flight_cost = static_cast<RUB>(base_flight_cost * dest.tourist_markup * profile.flight_multiplier);
    RUB hotel_cost = static_cast<RUB>(dest.avg_daily_hotel_rub * inf * days * dest.tourist_markup * profile.hotel_multiplier);

    RUB food_well = static_cast<RUB>(dest.avg_daily_food_rub * inf * well_days * dest.tourist_markup * profile.food_multiplier);
    RUB other_well = static_cast<RUB>(dest.avg_daily_other_rub * inf * well_days * dest.tourist_markup * profile.other_multiplier);

    RUB food_sick = static_cast<RUB>(dest.avg_daily_food_rub * inf * sick_days * dest.tourist_markup * profile.food_multiplier * illness.food_multiplier);
    RUB other_sick = static_cast<RUB>(dest.avg_daily_other_rub * inf * sick_days * dest.tourist_markup * profile.other_multiplier * 0.15f);

    RUB extras = inflate(profile.extras_rub);
    RUB total_cost_rub = flight_cost + hotel_cost + food_well + food_sick + other_well + other_sick + extras;

    RUB other_full = static_cast<RUB>(dest.avg_daily_other_rub * inf * days * dest.tourist_markup * profile.other_multiplier);
    RUB food_full = static_cast<RUB>(dest.avg_daily_food_rub * inf * days * dest.tourist_markup * profile.food_multiplier);
    RUB saved = (other_full - other_well - other_sick) + (food_full - food_well - food_sick);
    if (saved < 0) saved = 0;

    // Списание с соответствующего счёта
    switch (zone)
    {
    case vacation_currency_zone::EUR:
    {
        EUR cost_eur = static_cast<EUR>(std::ceil(total_cost_rub / 100.0));
        EUR eur_before = Alice.sber.account_eur;
        if (Alice.sber.account_eur < cost_eur)
        {
            EUR need_more_eur = cost_eur - Alice.sber.account_eur;
            RUB need_more_rub = need_more_eur * 100;
            if (Alice.sber.account_rub >= need_more_rub)
                Alice.sber.rub_to_eur(need_more_rub);
            else { cost_eur = Alice.sber.account_eur; total_cost_rub = cost_eur * 100; }
        }
        Alice.sber.account_eur -= cost_eur;
        EUR leftover = Alice.sber.account_eur - eur_before;
        if (leftover > 0) Alice.sber.eur_to_rub(leftover);
        break;
    }
    case vacation_currency_zone::USD:
    {
        static constexpr float USD_RATE = 90.91f;
        USD cost_usd = static_cast<USD>(std::ceil(total_cost_rub / USD_RATE));
        USD usd_before = Alice.sber.account_usd;
        if (Alice.sber.account_usd < cost_usd)
        {
            USD need_more_usd = cost_usd - Alice.sber.account_usd;
            RUB need_more_rub = static_cast<RUB>(need_more_usd * USD_RATE) + 1;
            if (Alice.sber.account_rub >= need_more_rub)
                Alice.sber.rub_to_usd(need_more_rub);
            else { cost_usd = Alice.sber.account_usd; total_cost_rub = static_cast<RUB>(cost_usd * USD_RATE); }
        }
        Alice.sber.account_usd -= cost_usd;
        USD leftover = Alice.sber.account_usd - usd_before;
        if (leftover > 0) Alice.sber.usd_to_rub(leftover);
        break;
    }
    case vacation_currency_zone::RUB:
        if (Alice.sber.account_rub < total_cost_rub)
            total_cost_rub = Alice.sber.account_rub;
        Alice.sber.account_rub -= total_cost_rub;
        break;
    }

    return { total_cost_rub, saved };
}


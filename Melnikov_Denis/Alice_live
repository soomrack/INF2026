/// Структура, хранящая все налоговые ставки государства
struct taxes_state
{
    procent income_tax = 13.0f;  ///< НДФЛ стандартный
    procent income_tax_high = 15.0f;  ///< НДФЛ повышенный (>5 млн)
    procent investment_tax = 13.0f;  ///< Налог с инвестиций
    procent deposit_tax = 13.0f;  ///< Налог с депозитов
    procent transport_tax_rate = 15.0f;  ///< Транспортный налог (руб/л.с.)
    procent property_tax = 0.1f;  ///< Налог на имущество (%)
    procent pension_fund = 22.0f;  ///< Взносы в ПФР
    procent social_insurance = 2.9f;  ///< Взносы ФСС
    procent medical_insurance = 5.1f;  ///< Взносы ФОМС
    procent vat = 20.0f;  ///< НДС стандартный
    procent vat_food = 10.0f;  ///< НДС на продукты

    /// Рассчитать НДФЛ с учётом прогрессивной шкалы
    RUB calc_income_tax(RUB gross, RUB annual_income_so_far = 0) const;

    /// Рассчитать транспортный налог по мощности
    RUB calc_transport_tax(int horsepower) const;

    /// Рассчитать налог с процентов по вкладу
    RUB calc_deposit_tax(RUB interest_earned) const;

    /// Рассчитать налог с инвестиционной прибыли
    RUB calc_investment_tax(RUB profit) const;

    /// Рассчитать налог на имущество по кадастровой стоимости
    RUB calc_property_tax(RUB cadastral_value) const;

    /// Суммарная нагрузка работодателя (страховые взносы, %)
    float total_employer_burden() const;
};

// ── Реализации методов taxes_state ──────────────────────────

RUB taxes_state::calc_income_tax(RUB gross, RUB annual_income_so_far) const
{
    const RUB threshold = 5'000'000;
    RUB total = annual_income_so_far + gross;
    if (total <= threshold)
        return static_cast<RUB>(gross * (income_tax / 100.0f));
    if (annual_income_so_far >= threshold)
        return static_cast<RUB>(gross * (income_tax_high / 100.0f));
    RUB below = threshold - annual_income_so_far;
    RUB above = gross - below;
    return static_cast<RUB>(below * (income_tax / 100.0f))
        + static_cast<RUB>(above * (income_tax_high / 100.0f));
}

RUB taxes_state::calc_transport_tax(int horsepower) const
{
    return static_cast<RUB>(horsepower * transport_tax_rate);
}

RUB taxes_state::calc_deposit_tax(RUB interest_earned) const
{
    return static_cast<RUB>(interest_earned * (deposit_tax / 100.0f));
}

RUB taxes_state::calc_investment_tax(RUB profit) const
{
    return profit > 0 ? static_cast<RUB>(profit * (investment_tax / 100.0f)) : 0;
}

RUB taxes_state::calc_property_tax(RUB cadastral_value) const
{
    return static_cast<RUB>(cadastral_value * (property_tax / 100.0f));
}

float taxes_state::total_employer_burden() const
{
    return pension_fund + social_insurance + medical_insurance;
}

/// Глобальный экземпляр налоговых ставок
struct taxes_state taxes_state;

// ============================================================
//  class Bank — банк Алисы (Сбербанк)
// ============================================================

class Bank
{
private:
    // ── Валютные курсы ───────────────────────────────────────
    static constexpr float DOLLAR_RATE = 90.91f;
    static constexpr float EURO_RATE = 100.00f;
    static constexpr float RUB_TO_USD_RATE = 1.0f / DOLLAR_RATE;
    static constexpr float RUB_TO_EUR_RATE = 1.0f / EURO_RATE;

    // ── Ставки по депозитам ─────────────────────────────────
    static constexpr float DEPOSIT_RATE_SHORT = 0.04f;  ///< Короткий вклад (3 мес.)
    static constexpr float DEPOSIT_RATE_LONG = 0.10f;  ///< Длинный вклад (36 мес.)

    /// Комиссия за перевод (0.5%)
    static constexpr float TRANSFER_FEE = 0.005f;

    // ── Внутренние структуры ─────────────────────────────────

    /// Одна транзакция в истории операций
    struct transaction
    {
        std::string type;       ///< Тип операции
        RUB         amount_rub; ///< Сумма в рублях
        std::string note;       ///< Примечание
    };

    /// Депозитный вклад
    struct deposit
    {
        std::string name;           ///< Название вклада
        RUB         principal;      ///< Основная сумма
        RUB         accrued = 0;  ///< Начисленные проценты
        float       rate;           ///< Годовая ставка
        int         total_months;   ///< Срок вклада в месяцах
        int         months_done = 0;///< Пройдено месяцев
        bool        active = true;  ///< Активен ли вклад

        /// Ежемесячное начисление процентов
        RUB  monthly_gain()    const { return static_cast<RUB>(principal * (rate / 12.0f)); }
        /// Налог с накопленных процентов
        RUB  tax_on_interest() const { return static_cast<RUB>(accrued * 0.035f); }
        /// Итоговая выплата при закрытии
        RUB  payout()          const { return principal + accrued - tax_on_interest(); }

        /// Начислить проценты за один месяц
        void accrue_month()
        {
            if (!active) return;
            accrued += monthly_gain();
            if (++months_done >= total_months) active = false;
        }
    };

    std::vector<transaction> tx_history; ///< История всех операций
    std::vector<deposit>     deposits;   ///< Список вкладов
    int next_deposit_id = 1;             ///< Счётчик ID вкладов

    // ── Приватные вспомогательные методы (объявления) ────────

    void    log(const std::string& type, RUB amount, const std::string& note);
    void    require_rub(RUB needed) const;
    deposit& find_deposit(int id);

public:
    // ── Публичные счета ─────────────────────────────────────
    RUB account_rub = 0; ///< Рублёвый счёт
    USD account_usd = 0; ///< Долларовый счёт
    EUR account_eur = 0; ///< Евровый счёт

    // ── Объявления публичных методов ─────────────────────────

    void add_rub(RUB amount, const std::string& note = "Пополнение RUB");
    void add_usd(USD amount, const std::string& note = "Пополнение USD");
    void add_eur(EUR amount, const std::string& note = "Пополнение EUR");

    void withdraw_rub(RUB amount, const std::string& note = "Снятие");
    void transfer_out(RUB amount, const std::string& recipient);
    void transfer_in(RUB amount, const std::string& sender);

    void rub_to_usd(RUB amount);
    void rub_to_eur(RUB amount);
    void usd_to_rub(USD amount);
    void eur_to_rub(EUR amount);

    void receive_salary(RUB gross, const std::string& employer = "Работодатель");
    void pay_penalty(RUB amount, const std::string& reason);
    void pay_expense(RUB amount, const std::string& reason);

    int  open_deposit_short(const std::string& dep_name, RUB amount);
    int  open_deposit_long(const std::string& dep_name, RUB amount);
    void close_deposit(int id);
    void accrue_month_deposits();

    RUB  total_assets_rub() const;

    void print()          const;
    void print_deposits() const;
    void print_history(int last_n = 10) const;
};

// ── Реализации приватных методов Bank ───────────────────────

void Bank::log(const std::string& type, RUB amount, const std::string& note)
{
    tx_history.push_back({ type, amount, note });
}

void Bank::require_rub(RUB needed) const
{
    if (account_rub < needed)
        throw std::runtime_error("Недостаточно RUB: нужно " +
            std::to_string(needed) + ", есть " + std::to_string(account_rub));
}

Bank::deposit& Bank::find_deposit(int id)
{
    if (id < 1 || id > static_cast<int>(deposits.size()))
        throw std::runtime_error("Вклад не найден: " + std::to_string(id));
    return deposits[id - 1];
}

// ── Реализации публичных методов Bank ───────────────────────

void Bank::add_rub(RUB amount, const std::string& note)
{
    account_rub += amount;
    log("Пополнение", amount, note);
}

void Bank::add_usd(USD amount, const std::string& note)
{
    account_usd += amount;
    log("Пополнение USD", amount, note);
}

void Bank::add_eur(EUR amount, const std::string& note)
{
    account_eur += amount;
    log("Пополнение EUR", amount, note);
}

void Bank::withdraw_rub(RUB amount, const std::string& note)
{
    require_rub(amount);
    account_rub -= amount;
    log("Снятие", amount, note);
}

void Bank::transfer_out(RUB amount, const std::string& recipient)
{
    RUB fee = static_cast<RUB>(amount * TRANSFER_FEE);
    require_rub(amount + fee);
    account_rub -= (amount + fee);
    log("Перевод", amount, "-> " + recipient);
    log("Комиссия", fee, "за перевод");
}

void Bank::transfer_in(RUB amount, const std::string& sender)
{
    account_rub += amount;
    log("Входящий перевод", amount, "от " + sender);
}

void Bank::rub_to_usd(RUB amount)
{
    require_rub(amount);
    account_rub -= amount;
    account_usd += static_cast<USD>(amount * RUB_TO_USD_RATE);
    log("Обмен RUB->USD", amount, "");
}

void Bank::rub_to_eur(RUB amount)
{
    require_rub(amount);
    account_rub -= amount;
    account_eur += static_cast<EUR>(amount * RUB_TO_EUR_RATE);
    log("Обмен RUB->EUR", amount, "");
}

void Bank::usd_to_rub(USD amount)
{
    if (account_usd < amount) throw std::runtime_error("Недостаточно USD");
    account_usd -= amount;
    account_rub += static_cast<RUB>(amount * DOLLAR_RATE);
    log("Обмен USD->RUB", static_cast<RUB>(amount * DOLLAR_RATE), "");
}

void Bank::eur_to_rub(EUR amount)
{
    if (account_eur < amount) throw std::runtime_error("Недостаточно EUR");
    account_eur -= amount;
    account_rub += static_cast<RUB>(amount * EURO_RATE);
    log("Обмен EUR->RUB", static_cast<RUB>(amount * EURO_RATE), "");
}

void Bank::receive_salary(RUB gross, const std::string& employer)
{
    RUB tax = taxes_state.calc_income_tax(gross);
    RUB net = gross - tax;
    account_rub += net;
    log("Зарплата", gross, "от " + employer + " (до НДФЛ)");
    log("НДФЛ", tax, std::to_string(taxes_state.income_tax) + "%");
}

void Bank::pay_penalty(RUB amount, const std::string& reason)
{
    require_rub(amount);
    account_rub -= amount;
    log("Штраф", amount, reason);
}

void Bank::pay_expense(RUB amount, const std::string& reason)
{
    require_rub(amount);
    account_rub -= amount;
    log("Расход", amount, reason);
}

int Bank::open_deposit_short(const std::string& dep_name, RUB amount)
{
    require_rub(amount);
    account_rub -= amount;
    deposits.push_back({ dep_name, amount, 0, DEPOSIT_RATE_SHORT, 3 });
    log("Открытие вклада", amount, dep_name + " (3 мес., 4%)");
    return next_deposit_id++;
}

int Bank::open_deposit_long(const std::string& dep_name, RUB amount)
{
    require_rub(amount);
    account_rub -= amount;
    deposits.push_back({ dep_name, amount, 0, DEPOSIT_RATE_LONG, 36 });
    log("Открытие вклада", amount, dep_name + " (36 мес., 10%)");
    return next_deposit_id++;
}

void Bank::close_deposit(int id)
{
    deposit& dep = find_deposit(id);
    RUB payout = dep.payout();
    RUB tax = dep.tax_on_interest();
    account_rub += payout;
    dep.active = false;
    log("Закрытие вклада", payout, dep.name);
    if (tax > 0) log("Налог с вклада", tax, "удержан");
}

void Bank::accrue_month_deposits()
{
    for (auto& dep : deposits) dep.accrue_month();
}

RUB Bank::total_assets_rub() const
{
    RUB total = account_rub
        + static_cast<RUB>(account_usd * DOLLAR_RATE)
        + static_cast<RUB>(account_eur * EURO_RATE);
    for (const auto& dep : deposits)
        if (dep.active) total += dep.principal;
    return total;
}

void Bank::print() const
{
    std::cout << "=== Счёт в Сбербанке ===\n"
        << "  RUB: " << account_rub << "\n"
        << "  USD: " << account_usd << "\n"
        << "  EUR: " << account_eur << "\n"
        << "  Итого активов (RUB): " << total_assets_rub() << "\n";
}

void Bank::print_deposits() const
{
    std::cout << "=== Вклады ===\n";
    if (deposits.empty()) { std::cout << "  Нет вкладов\n"; return; }
    for (int i = 0; i < static_cast<int>(deposits.size()); ++i)
    {
        const auto& dep = deposits[i];
        std::cout << "  [" << (i + 1) << "] " << dep.name
            << " | тело=" << dep.principal
            << " RUB | начислено=" << dep.accrued
            << " RUB | " << dep.months_done << "/" << dep.total_months
            << " мес. | активен=" << (dep.active ? "да" : "нет")
            << " | выплата=" << dep.payout() << " RUB\n";
    }
}

void Bank::print_history(int last_n) const
{
    std::cout << "=== Последние " << last_n << " операций ===\n";
    int start = std::max(0, static_cast<int>(tx_history.size()) - last_n);
    for (int i = start; i < static_cast<int>(tx_history.size()); ++i)
        std::cout << "  " << tx_history[i].type
        << " | " << tx_history[i].amount_rub << " RUB"
        << " | " << tx_history[i].note << "\n";
}


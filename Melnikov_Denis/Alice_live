/// Параметры использования топлива
struct fuel_params
{
    float km_per_day;           ///< Километраж в день
    float liters_per_100km;     ///< Расход топлива (л/100 км)
    float fuel_price_per_liter; ///< Цена бензина за литр
    int   work_days_per_month;  ///< Рабочих дней в месяце
};

/// Рассчитать месячные расходы на топливо (с инфляционным ростом цены)
RUB calc_monthly_fuel_cost(const fuel_params& fp, int sick_days = 0)
{
    int active_days = std::max(0, fp.work_days_per_month - sick_days);
    float liters = (fp.km_per_day / 100.0f) * fp.liters_per_100km * active_days;
    liters *= 1.15f; // +15% на пробки и личные поездки

    // Цена топлива растёт с инфляцией
    float inflated_price = fp.fuel_price_per_liter * inflation_factor();
    return static_cast<RUB>(liters * inflated_price);
}


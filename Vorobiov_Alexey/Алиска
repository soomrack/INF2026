//  Инфляция 

void inflation(const int year)
{
    RUB food_infl = 8;   // 0.8%  СТАВКА
    RUB gas_infl = 9;   // 0.9%
    RUB cloth_infl = 5;  // 0.5%

    if (year >= 2028)
    {
        food_infl += 1;  // 0.9%
        gas_infl += 2;  // 1.1%
    }
    if (year >= 2031)
    {
        food_infl += 2;  //  1.1%
        gas_infl += 3;  //  1.4%
        cloth_infl += 1; // 0.6%
    }
    if (year >= 2034)
    {
        food_infl += 3;  // 1.4%
        gas_infl += 4;  // 1.8%
        cloth_infl += 2; // 0.8%
    }

    // Применяем инфляцию (цена * (1000 + ставка) / 1000)
    alice.food = alice.food * (1000 + food_infl) / 1000;

    alice.gas = alice.gas * (1000 + gas_infl) / 1000;

    alice.cloth = alice.cloth * (1000 + cloth_infl) / 1000;



    Bob.food = Bob.food * (1000 + food_infl) / 1000;

    Bob.gas = Bob.gas * (1000 + gas_infl) / 1000;

    Bob.cloth = Bob.cloth * (1000 + cloth_infl) / 1000;


}


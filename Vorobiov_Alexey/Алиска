void Bob_credit_payment()          //кредит
{
    // Если кредит уже выплачен - ничего не делаем
    if (Bob.credit_debt <= 0)
    {
        Bob.credit_debt = 0;
        return;
    }

    // Если остаток меньше платежа, то закрываем только остаток
    if (Bob.credit_debt < Bob.payment)
    {
        Bob.payment = Bob.credit_debt;
    }

    Bob.bank_account -= Bob.payment;
    Bob.credit_debt -= Bob.payment;

    if (Bob.credit_debt < 0)
    {
        Bob.credit_debt = 0;
    }
}



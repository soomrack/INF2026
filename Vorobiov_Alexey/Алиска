//  Симуляция до целевой даты 

void simulate_until(int start_year, int start_month)
{
    int year = 2026;
    int month = 2;

    while (not (year > start_year or (year == start_year and month > start_month)))
    {
        //АЛИСА
        alice_salary(year, month);

        alice_food_cost();
        alice_gas_cost();
        alice_cloth_cost();
        alice_savings_add();
        alice_monthly_savings_interest(year);
        alice_dream_check();

        alice_has_boat(year, month);

        //Боб
        Bob_salary(year, month);

        Bob_food_cost();
        Bob_cloth_cost();
        Bob_gas_cost();
        Bob_credit_payment();
        Bob_credit_interest();
        Bob_dream_check();

        //СЕМЬЯ (ДОМ)
        mortgage_payment();                 //ипотека
        home_insurance();                   //страховка жилья
        mortgage_interest();                //проценты ипотеки
        family_dream_check();
        large_purchases(year, month);       //мебель в дом


        //ОБЩЕЕ
        monthly_special(year, month);       //случайные события
        education_courses(year, month);     //курсы
        annual_taxes(year, month);          //налоги
        investment_income(year, month);     //инвестиции и копилка

        inflation(year);                    //инфляция

        // Сезонные скачки
        if (month == 6 or month == 7 or month == 8)
        {
            summer_gas_spike();   // летом бензин дороже
        }

        if (month == 12 or month == 1 or month == 2)
        {
            winter_food_spike();  // зимой еда дороже
        }

        month++;
        if (month == 13)
        {
            month = 1;
            year++;
        }
    }
}



        anna.investments.stocks + anna.investments.bonds + anna.investments.real_estate;
    wedding.budget = mikhail_assets + anna_assets;

    printf("Total cost: %lld RUB\n", total);
    printf("Budget: %lld RUB\n", wedding.budget);


// Доход от инвестиций Анны
void anna_apply_investment_returns(int month, int year) {
    float vol = market_volatility(month, year) / 10.0;

    float stock_rand = ((rand() % 200) - 100) / 100.0;
    float stock_month = anna.investments.stock_return / 12.0 / 100.0;
    float stock_vol = 15.0 * stock_rand / 12.0 / 100.0 + vol / 100.0;
    RUB stock_ret = (RUB)(anna.investments.stocks * (stock_month + stock_vol));
    anna.investments.stocks += stock_ret;

    float bond_rand = ((rand() % 100) - 50) / 100.0;
    float bond_month = anna.investments.bond_return / 12.0 / 100.0;
    float bond_vol = 5.0 * bond_rand / 12.0 / 100.0;
    RUB bond_ret = (RUB)(anna.investments.bonds * (bond_month + bond_vol));
    anna.investments.bonds += bond_ret;

    RUB total = stock_ret + bond_ret;
    if (total > 0) anna.investments.total_dividends += total;

    if (total != 0) printf("  Investment return: %lld\n", total);
}


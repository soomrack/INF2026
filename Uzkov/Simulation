// Депозит Анны
void anna_deposit(int month, int year) {
    anna.bank.interest = key_rate(month, year) - 2.0;
    RUB interest = (RUB)(anna.bank.deposit * (anna.bank.interest / 12.0 / 100.0));
    anna.bank.deposit += interest;
    anna.investments.total_dividends += interest;

    printf("  Deposit interest: +%lld\n", interest);

    if (anna.bank.account > 100000) {
        RUB transfer = anna.bank.account - 20000;
        anna.bank.deposit += transfer;
        anna.bank.account = 20000;
        printf("  Transfer to deposit: %lld\n", transfer);
        anna.actual_monthly_savings += transfer;
    }
}

// Обмен валюты Анны
void anna_currency_exchange(int month, int year) {
    if (month % 3 != 0) return;
    if (anna.bank.deposit <= 500000) return;

    RUB sum = 50000;
    float comm = 0.02 + market_volatility(month, year) / 100.0;
    USD bought = (USD)((sum * (1.0 - comm)) / anna.bank.rate_usd_rub);

    anna.bank.deposit -= sum;
    anna.bank.account_usd += bought;
    printf("  Bought %lld USD\n", bought);
}


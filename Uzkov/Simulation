// Ключевая ставка
float key_rate(int month, int year) {
    if (year == 2026) return 14.5;
    if (year == 2027) return 12.5;
    if (year == 2028) return 10.0;
    if (year == 2029) return 7.5;
    if (year == 2030) return 4.0;
    if (year == 2031) return 4.5;
    return 10.0;
}

// Инфляция
float inflation_rate(int year) {
    if (year == 2026) return 8.5;
    if (year == 2027) return 7.2;
    if (year == 2028) return 6.0;
    if (year == 2029) return 5.5;
    if (year == 2030) return 4.8;
    if (year == 2031) return 5.0;
    return 6.0;
}

// Волатильность рынка
float market_volatility(int month, int year) {
    return ((month * 7 + year * 3) % 30) / 10.0;
}


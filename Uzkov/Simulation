// Инфляция
void inflation(int month, int year) {
    if (month != 1) return;

    float rate = inflation_rate(year);
    float mult = 1.0 + rate / 100.0;

    anna.salary = (RUB)(anna.salary * mult);
    anna.food = (RUB)(anna.food * mult);
    anna.utilities = (RUB)(anna.utilities * mult);
    anna.car.gas = (RUB)(anna.car.gas * mult);
    anna.car.maintenance = (RUB)(anna.car.maintenance * mult);
    anna.car.insurance = (RUB)(anna.car.insurance * mult);
    anna.education = (RUB)(anna.education * mult);
    anna.car.value = (RUB)(anna.car.value * 0.95);
    anna.car.age_months++;

    mikhail.food = (RUB)(mikhail.food * mult);
    mikhail.entertainment = (RUB)(mikhail.entertainment * mult);
    mikhail.travel_budget = (RUB)(mikhail.travel_budget * mult);
    mikhail.clothing = (RUB)(mikhail.clothing * mult);
    mikhail.gadgets = (RUB)(mikhail.gadgets * mult);
    mikhail.parties = (RUB)(mikhail.parties * mult);
    mikhail.hobby = (RUB)(mikhail.hobby * mult);
    mikhail.car.gas = (RUB)(mikhail.car.gas * mult);
    mikhail.car.maintenance = (RUB)(mikhail.car.maintenance * mult);
    mikhail.car.insurance = (RUB)(mikhail.car.insurance * mult);
    mikhail.business.monthly_profit = (RUB)(mikhail.business.monthly_profit * (1.0 + rate / 200.0));
    mikhail.car.value = (RUB)(mikhail.car.value * 0.90);
    mikhail.car.age_months++;

    printf("  Inflation: %.1f%%\n", rate);
}

// Расчет налогов
void calculate_taxes(int year) {
    printf("\n=== TAXES %d ===\n", year);

    RUB anna_tax = (RUB)(anna.car.value * 0.02) +
        (RUB)(anna.total_earned * 0.13) +
        (RUB)(anna.property.apartment_value * 0.01) +
        (RUB)(anna.investments.total_dividends * 0.09);

    anna.bank.account -= anna_tax;
    anna.total_spent += anna_tax;
    anna.total_tax_paid += anna_tax;
    printf("Anna tax: %lld RUB\n", anna_tax);

    RUB mikhail_tax = (RUB)(mikhail.business.monthly_profit * 12 * 0.06) +
        (RUB)(mikhail.car.value * 0.02);

    mikhail.bank.account -= mikhail_tax;
    mikhail.total_spent += mikhail_tax;
    mikhail.total_tax_paid += mikhail_tax;
    printf("Mikhail tax: %lld RUB\n", mikhail_tax);

    if (mikhail.bank.account < 0) {
        mikhail.fines += 20000;
        mikhail.fines_count++;
        printf("Mikhail fine added\n");
    }
    printf("================\n\n");
}

// Курс валют
void update_currency_rate(int month, int year) {
    float rate = 78.5;
    if (year == 2027) rate = 82.0;
    if (year == 2028) rate = 89.5;
    if (year == 2029) rate = 95.0;
    if (year == 2030) rate = 96.5;
    if (year == 2031) rate = 93.0;

    float vol = market_volatility(month, year) * 2.0;
    anna.bank.rate_usd_rub = rate + vol;
    mikhail.bank.rate_usd_rub = anna.bank.rate_usd_rub;
    printf("  USD: %.2f RUB\n", anna.bank.rate_usd_rub);
}


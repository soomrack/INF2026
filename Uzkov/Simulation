    printf("\n\n*** WEDDING ***\n\n");

    RUB total = wedding.cafe_rent + wedding.rings_cost + wedding.travel_cost +
        wedding.photographer + wedding.dress_cost + wedding.suit_cost +
        wedding.cake_cost;

    RUB mikhail_assets = mikhail.bank.account +
        (RUB)(mikhail.bank.account_usd * mikhail.bank.rate_usd_rub) +
        mikhail.investments.stocks + mikhail.investments.crypto;

void update_personality_multipliers(Person& person) {
    person.personality.spending_multiplier = 0.7 + 
    (person.personality.impulsivity / 100) * 0.8 +
    (1 - person.personality.discipline / 100) * 0.5;
    if (person.personality.spending_multiplier > 1.5) person.personality.spending_multiplier = 1.5;
    if (person.personality.spending_multiplier < 0.5) person.personality.spending_multiplier = 0.5;

    person.personality.savings_multiplier =
    (person.personality.discipline / 100) * 1.2 +
    (1 - person.personality.impulsivity / 100) * 0.8;
    if (person.personality.savings_multiplier > 1.5) person.personality.savings_multiplier = 1.5;
    if (person.personality.savings_multiplier < 0.5) person.personality.savings_multiplier = 0.5;

    person.personality.investment_risk_premium =      // Премия за риск
    (person.personality.risk_tolerance / 100) * 1.5;
    if (person.personality.investment_risk_premium > 1.2) person.personality.investment_risk_premium = 1.2;
}


void apply_personality_to_career(Person& person, int month, int year) {
    float career_multiplier = 1.0;

    career_multiplier *= (person.personality.conscientiousness / 50);

    career_multiplier *= (person.personality.sociability / 50);

    career_multiplier *= (2.0 - person.personality.impulsivity / 50);

    if (person.personality.optimism > 70 && month == 3) {
        career_multiplier *= 1.1;
    }

    if (month == 3) {
        RUB salary_increase = person.salary * (career_multiplier - 1.0);
        if (salary_increase > 0) {
            person.salary += salary_increase;
        }
    }

    float freelance_multiplier = (person.personality.openness / 50) *
        (person.personality.conscientiousness / 50);
    if (freelance_multiplier > 1.5) freelance_multiplier = 1.5;

    person.freelance = person.freelance * freelance_multiplier;
}


void apply_personality_to_health(Person& person, int month, int year) {
    if (person.helth.helth_health < 50) {       // Оптимисты лучше переносят болезни
        float recovery_bonus = person.personality.optimism / 200;
        person.helth.helth_health += recovery_bonus;
    }

    if (person.personality.emotional_stability < 40) { 
        person.helth.helth_health -= 2.0;
    }

    if (person.personality.discipline > 70) {     // Дисциплинированные лучше следят за здоровьем
        person.helth.helth_health += 1.0;
    }

    if (person.personality.stress_level > 70) {
        person.helth.helth_health -= 3.0;
    }

    if (person.helth.helth_health > 100) person.helth.helth_health = 100;
    if (person.helth.helth_health < 0) person.helth.helth_health = 0;
}


void update_personality_dynamics(Person& person, int month, int year) {
    if (person.vtb.account_rub > 1'000'000 && month == 12) {    // Успехи повышают оптимизм
        person.personality.optimism += 5;
    }

    if (person.vtb.account_rub < 100'000 && month == 12) {       // Неудачи снижают оптимизм
        person.personality.optimism -= 5;
    }

    if (person.sport.gym_visit_count > 100 && month == 12) {
        person.personality.discipline += 3;
    }

    if (person.tax_deductions.education_deduction > 50'000 && month == 12) {
        person.personality.openness += 5;
    }

    if (person.personality.optimism > 100) person.personality.optimism = 100;
    if (person.personality.optimism < 0) person.personality.optimism = 0;
    if (person.personality.discipline > 100) person.personality.discipline = 100;
    if (person.personality.discipline < 0) person.personality.discipline = 0;

    update_personality_multipliers(person);
}


void apply_personality_to_expenses(Person& person, const string& expense_type, RUB& expense) {
    float multiplier = 1.0;

    if (expense_type == "emotions" || expense_type == "entertainment") {
        multiplier *= person.personality.spending_multiplier;
        if (person.personality.is_impulsive_buyer) {
            multiplier *= 1.2;
        }
    }
    else if (expense_type == "food") {
        multiplier *= (2.0 - person.personality.savings_multiplier);// меньше тратят на еду
    }
    else if (expense_type == "gym") {
        multiplier *= (person.personality.discipline / 50);// Дисциплинированные больше тратят на спорт
    }
    else if (expense_type == "travel") {
        multiplier *= (person.personality.openness / 50);// Открытые новому опыту больше путешествуют
    }

    expense = expense * multiplier;
}


void apply_personality_to_investments(Person& person, int month) {
    if (!person.personality.is_risk_seeker) {  // Консервативные инвесторы перекладываются в облигации
        if (person.vtb.invest.stocks > 0 && month == 1) {
            RUB stocks_to_bonds = person.vtb.invest.stocks * 0.3;
            person.vtb.invest.stocks -= stocks_to_bonds;
            person.Gazprom.obligation += stocks_to_bonds;
        }
    }
    if (person.personality.is_risk_seeker) {            // Рисковые инвесторы покупают больше акций
        if (person.vtb.account_rub > 100'000 && month == 6) {
            RUB stocks_purchase = min(person.vtb.account_rub * 0.2, 200'000.0);
            person.vtb.invest.stocks += stocks_purchase;
            person.vtb.account_rub -= stocks_purchase;
        }
    }
}


void update_political_situation(Person& person, int year, int month) {
    switch (year) {
    case 2026:
        person.politics.tension_level = 0.3;
        person.politics.economic_sanctions = 0.4;
        person.politics.is_election_year = false;
        break;
    case 2027:
        person.politics.tension_level = 0.5;
        person.politics.economic_sanctions = 0.6;
        person.politics.is_election_year = false;
        break;
    case 2028:
        person.politics.tension_level = 0.7;
        person.politics.economic_sanctions = 0.8;
        person.politics.is_election_year = true;  // год выборов
        break;
    case 2029:
        person.politics.tension_level = 0.4;
        person.politics.economic_sanctions = 0.5;
        person.politics.is_election_year = false;
        break;
    }

    if ((month >= 3 && month <= 5) || (month >= 9 && month <= 11)) {     // Сезонные протесты
        if (rand() % 100 < 30) {  // 30% шанс протестов в сезон
            person.politics.has_protests = true;
            person.politics.tension_level += 0.2;
        }
    }
    else {
        person.politics.has_protests = false;
    }

    if (rand() % 100 < 5) {  // 5% шанс значимого события
        int event = rand() % 3;
        switch (event) {
        case 0: // Новые санкции
            person.politics.economic_sanctions += 0.1;
            person.politics.tension_level += 0.15;
            break;
        case 1: // Отставка чиновника
            person.politics.tension_level += 0.1;
            break;
        case 2: // Политическая реформа
            person.politics.tension_level -= 0.2;
            break;
        }
    }

    if (person.politics.tension_level > 1.0) person.politics.tension_level = 1.0;
    if (person.politics.tension_level < 0.0) person.politics.tension_level = 0.0;
    if (person.politics.economic_sanctions > 1.0) person.politics.economic_sanctions = 1.0;
    if (person.politics.economic_sanctions < 0.0) person.politics.economic_sanctions = 0.0;
}



float normal_random(float mean, float stddev) {
    const double PI = 3.14159265358979323846;
    float u1 = (rand() + 1.0) / (RAND_MAX + 2.0);
    float u2 = (rand() + 1.0) / (RAND_MAX + 2.0);

    float z = sqrt(-2.0 * log(u1)) * cos(2.0 * PI * u2);
    return mean + stddev * z;
}


float inflation(const int year) {
    switch (year) {
    case 2026: return (12.5);
    case 2027: return (14.0);
    case 2028: return (13.0);
    case 2029: return (11.5);
    }
    return 0;
}


bool check_mortality(Person& person, Illness& illness) {
    if (illness.is_active) {
        float random = (rand() % 1000) / 1000.0; // 0-1
        if (random < illness.mortality_risk) {
            return true;
        }
    }
    return false;
}


void activate_illness(Person& person, int month, int year) {
    float inflation_rate = inflation(year) / 100.0 / 12.0;
    float base_chance = 0.05; // базовый шанс 5%

    if (month == 12 || month == 1 || month == 2) {
        base_chance += 0.10;
    }

    if (month == 3 || month == 4 || month == 5) {
        base_chance += 0.05;
    }

    if (person.sport.gym_visit_count > 8) {
        base_chance *= 0.7;
    }

    if (person.helth.helth_health < 40) {
        base_chance *= 1.5;
    }

    float random = (rand() % 100) / 100.0;

    if (random < base_chance) {
        int illness_type = rand() % 9;

        switch (illness_type) {
        case 0: // Грипп
            if (!person.helth.flu.is_active) {
                person.helth.flu.is_active = true;
                person.helth.flu.months_remaining = person.helth.flu.duration_months;
                person.helth.flu.treatment_cost_per_month += person.helth.flu.treatment_cost_per_month * inflation_rate * person.helth.flu.duration_months;
            }
            break;

        case 1: // Ковид
            if (!person.helth.covid.is_active && rand() % 100 < 20) { // 20% шанс ковида среди болезней
                person.helth.covid.is_active = true;
                person.helth.covid.months_remaining = person.helth.covid.duration_months;
                person.helth.covid.treatment_cost_per_month += person.helth.covid.treatment_cost_per_month * inflation_rate * person.helth.covid.duration_months;
            }
            break;

        case 2: // Гипертония
            if (!person.helth.hypertension.is_active && person.helth.helth_health < 50) {
                person.helth.hypertension.is_active = true;
                person.helth.hypertension.months_remaining = 999;
            }
            break;

        case 3: // Диабет
            if (!person.helth.diabetes.is_active && rand() % 100 < 5) {
                person.helth.diabetes.is_active = true;
                person.helth.diabetes.months_remaining = 999;
            }
            break;

        case 4: // Травма
            if (!person.helth.injury.is_active && person.sport.gym_visit_count > 15) {
                person.helth.injury.is_active = true;
                person.helth.injury.months_remaining = person.helth.injury.duration_months;
                person.helth.injury.one_time_cost += person.helth.injury.one_time_cost * inflation_rate * 12;

                if (rand() % 3 == 0) {
                    person.helth.is_hospitalized = true;
                    person.helth.hospitalization_days = 7 + rand() % 14;
                }
            }
            break;

        case 5: // Аллергия
            if (!person.helth.allergy.is_active && (month == 4 || month == 5 || month == 6)) {
                person.helth.allergy.is_active = true;
                person.helth.allergy.months_remaining = 3; // на 3 месяца
            }
            break;

        case 6: // Гастрит
            if (!person.helth.gastritis.is_active && person.food > 4000) {
                person.helth.gastritis.is_active = true;
                person.helth.gastritis.months_remaining = person.helth.gastritis.duration_months;
            }
            break;

        case 7: // Мигрень
            if (!person.helth.migraine.is_active && person.helth.helth_health < 60) {
                person.helth.migraine.is_active = true;
                person.helth.migraine.months_remaining = person.helth.migraine.duration_months;
            }
            break;

        case 8: // Боль в спине
            if (!person.helth.back_pain.is_active && person.sport.gym_visit_count < 4) {
                person.helth.back_pain.is_active = true;
                person.helth.back_pain.months_remaining = 2;
            }
            break;
        }
    }
}


void process_illnesses(Person& person, int month, int year) {
    Illness* illnesses[] = {
        &person.helth.flu, &person.helth.covid, &person.helth.hypertension,
        &person.helth.diabetes, &person.helth.injury, &person.helth.allergy,
        &person.helth.gastritis, &person.helth.migraine, &person.helth.back_pain
    };

    float inflation_rate = inflation(year) / 100.0 / 12.0;
    bool any_illness_active = false;
    float total_work_efficiency = 1.0;

    for (auto illness : illnesses) {
        if (illness->is_active) {
            any_illness_active = true;

            // Проверка на смертность
            if (check_mortality(person, *illness)) {
                printf("Симуляция завершена досрочно\n");
                exit(0);
            }

            person.vtb.account_rub -= illness->treatment_cost_per_month;

            if (illness->one_time_cost > 0) {
                person.vtb.account_rub -= illness->one_time_cost;
                illness->one_time_cost = 0; // обнуляем разовые затраты
            }

            person.helth.helth_health += illness->helth_impact;      // Влияние на ментальное здоровье

            total_work_efficiency *= illness->work_efficiency;        // Влияние на эффективность работы

            if (illness->months_remaining > 0 && illness->months_remaining < 999) {
                illness->months_remaining--;
                if (illness->months_remaining <= 0) {
                    illness->is_active = false;
                }
            }
        }
    }

    if (person.helth.is_hospitalized) {
        person.helth.hospitalization_days--;
        total_work_efficiency = 0;

        if (person.helth.hospitalization_days <= 0) {
            person.helth.is_hospitalized = false;
        }
    }

    if (total_work_efficiency < 1.0) {
        RUB original_salary = person.salary;
        person.salary *= total_work_efficiency;
        person.freelance *= total_work_efficiency;
    }
}


void person_depression(Person& person, int month, int year)
{
    float inflation_rate = inflation(year) / 100.0 / 12.0;

    float helth_health_change = 0;

    update_political_situation(person, year, month);

    float political_impact = 0;
    political_impact -= person.politics.tension_level * 10.0;
    political_impact -= person.politics.economic_sanctions * 8.0;

    if (person.politics.has_protests) {
        political_impact -= 5.0;
        if (person.housing.location.find("Center") != string::npos ||         // Если живет в центре города - страдает больше
            person.housing.location == "Moscow") {
            political_impact -= 3.0;
        }
    }

    if (person.politics.is_election_year) {
        political_impact -= 7.0;
        if (month >= 8 && month <= 11) {  // предвыборная гонка
            political_impact -= 5.0;
        }
    }

    int news_impact = rand() % 21 - 10; 
    political_impact += news_impact / 2.0;

    helth_health_change += political_impact;

    if (person.sport.gym_visit_count > 10) {       // 1. Спортзал положительно влияет
        helth_health_change += 2.0;
    }

    RUB total_expenses = person.housing.rent + person.food + person.utilities + person.cat + person.sport.gym_membership;     // 2. Финансовый стресс
    RUB monthly_income = person.salary + person.freelance;

    if (total_expenses > monthly_income * 0.7) {
        helth_health_change -= 1.5;  // стресс от высоких расходов
    }

    if (person.cat > 0) {            // Одиночество (котик помогает)
        helth_health_change += 1.0;
    }

    int random_event = rand() % 100;        //Случайные события
    if (random_event < 5) {
        helth_health_change -= 5.0;  // плохой день
    }
    else if (random_event > 95) {
        helth_health_change += 5.0;  // отличный день
    }

    if (month == 11) {       // 5. Путешествия поднимают настроение (но временно)
        helth_health_change += 10.0;
    }

    person.helth.helth_health += helth_health_change;     // Обновляем ментальное здоровье (ограничиваем 0-100)
    if (person.helth.helth_health > 100) {
        person.helth.helth_health = 100;
    }
    if (person.helth.helth_health < 0) {
        person.helth.helth_health = 0;
    }

    if (person.helth.helth_health < 30 && !person.helth.is_depressed) {            // Проверяем, не впала ли в депрессию
        person.helth.is_depressed = true;
        person.helth.depression_months = 1;
    }

    if (person.helth.is_depressed) {
        person.helth.depression_months++;

        if (rand() % 3 == 0) {  // 33% шанс не работать на фрилансе
            person.freelance = 0;
        }

        if (rand() % 2 == 0) {  // 50% шанс пропустить зал
            person.sport.gym_visit_count = 0;
        }

        person.emotions *= 1.5;

        if (month % 3 == 0) {
            person.helth.missed_work_days = person.salary / 22 * 3;  // пропустила 3 дня
            person.vtb.account_rub -= person.helth.missed_work_days;
        }

        if (person.helth.helth_health < 50) {
            person.helth.therapy_cost += person.helth.therapy_cost * inflation_rate;
            person.vtb.account_rub -= person.helth.therapy_cost;
            person.helth.helth_health += 5.0;  // терапия помогает
        }

        if (person.helth.depression_months > 2) {
            person.helth.depression_months += person.helth.drugs_cost * inflation_rate;
            person.vtb.account_rub -= person.helth.drugs_cost;
            person.helth.helth_health += 3.0;  // лекарства помогают
        }

        if (person.helth.helth_health > 60) {
            person.helth.is_depressed = false;
            person.helth.depression_months = 0;
        }
    }
}



    printf("%s's salary = %lld\n", name.c_str(), person.salary);
    RUB capital = calculate_capital(person);
    printf("%s's capital = %lld RUB\n\n", name.c_str(), capital);
}


void person_car(Person& person, int month, int year)
{
    if (year == 2028) {
        person.car.gas == 6'000;  //повышение водительского стажа
    }

    if (month == 3) {
        person.vtb.account_rub -= person.tax.car_log + person.car.osago;
    }

    person.vtb.account_rub -= person.car.gas;

    if (month == 3 and year % 2 == 0) {
        person.vtb.account_rub -= person.car.tires;
    }
}


void simulation(Person& person)
{
    int year = 2026;
    int month = 2;

    while (!(year == 2027 && month == 6)) {
        person_salary(person, month, year);
        person_car(person, month, year);
        person_utilities(person, month, year);
        person_cat_food(person, month, year);
        person_trip(person, month, year);
        person_rent(person, year);
        person_deposit(person, month);
        person_vtb_stocks(person, month);
        person_alfa_stocks(person, month);
        person_T_stocks(person, month);
        person_Gazprom_obligations(person, month);
        person_Rosneft_obligations(person, month);
        person_Rosatom_obligations(person, month);
        person_spbbank_stocks(person, month);
        person_spbbank_obligations(person, month);
        person_freelancing(person, month, year);
        person_emotions(person);
        person_food(person, month, year);
        person_depression(person, month, year);
        person_gym(person, month, year);
        person_medical_insurance(person, month, year);
        karl_move_to_mytishchi(person, year, month);
        activate_illness(person, month, year);
        process_illnesses(person, month, year);
        update_personality_multipliers(person);
        update_personality_dynamics(person, month, year);
        apply_personality_to_career(person, month, year);
        apply_personality_to_health(person, month, year);
        update_political_situation(person, year, month);

        if (month == 4 && year > 2026) {
            file_tax_return(person, year - 1);
        }
        ++month;
        if (month == 13) {
            ++year;
            month = 1;
        }
    }
}



#include <iostream>
using namespace std;


using Percent = float;

using RUB = long long int;
using USD = long long int;
using percent = float;


struct Taxes {
    RUB insurance;
    RUB car_log;
    percent NPD;
};


struct Invest {
    RUB obligation;
    RUB stocks;
};


struct Car {
    RUB value;
    RUB gas;
    RUB osago;
    RUB tires;
};


struct Bank {
    RUB account_rub;
    RUB deposit;
    percent persent_deposit;
    USD account_usd;
    Invest invest;
    
    float rate_usd_rub;
};


struct Person {
    Bank vtb;
    Bank alfa;
    Bank T;
    Bank SpB;
    Invest Gazprom;
    Invest Rosneft;
    Invest Rosatom;
    RUB salary;
    RUB freelance;
    RUB food;
    RUB utilities;
    RUB rent;
    RUB cat;
    RUB emotions;
    USD trip;
    Car car;
    Taxes tax;
};
struct Person alice;


void alice_init()
{
    alice.vtb.rate_usd_rub = 78.76;
    alice.vtb.account_rub = 0;
    alice.vtb.account_usd = 1'000;

    alice.salary = 180'000;
    alice.freelance = 15'000;
    alice.vtb.deposit = 0;
    alice.vtb.persent_deposit = 20;
    alice.food = 3'000;
    alice.utilities = 3'500;
    alice.rent = 120'000;
    alice.cat = 3'000;
    alice.trip = 8'000;
    alice.emotions = 10'000;
    alice.vtb.invest.stocks = 88;
    alice.alfa.invest.stocks = 90;
    alice.T.invest.stocks = 3'000;
    alice.Gazprom.obligation = 950;
    alice.Rosneft.obligation = 900;
    alice.Rosatom.obligation = 1'000;

    alice.tax.car_log = 5'000;
    alice.tax.NPD = 4;
    alice.tax.car_log = 200;
    alice.car.value = 2'400'000;
    
    alice.car.gas = 15'000;
    alice.car.gas = 7'000;
    alice.car.tires = 10'000;

}


float inflation(const int year) {
    switch (year) {
    case 2026: return (12.5);
    case 2027: return (14.0); 
    case 2028: return (13.0); 
    case 2029: return (11.5); 
    }
}


void alice_food(const int month, const int year)
{
    if (month == 12) alice.vtb.account_rub -= 2000;

    alice.food += alice.food * (inflation(year) / 100. / 12.);

    alice.vtb.account_rub -= alice.food;
}


void alice_utilities(const int month, const int year)
{
    if (month == 2) alice.vtb.account_rub -= alice.utilities - (3'500 / 30) * 2;

    alice.utilities += alice.utilities * (inflation(year) / 100. / 12.);

    alice.vtb.account_rub -= alice.utilities;
}


void alice_rent(const int year){
    alice.rent += alice.rent * (inflation(year) / 100. / 12.);

    alice.vtb.account_rub -= alice.rent;
}


void alice_trip(const int month,const int year)
{
    if (year == 2026 && month == 11) {
        alice.vtb.account_usd -= 10'000;
        return;
    }

    if (month == 11) {
        alice.vtb.account_usd -= alice.trip;
    }
}


void alice_cat(const int month, const int year)
{
    if (month == 1 && year == 2027) {
        alice.vtb.account_rub -= 10'000;  //cat got sick
    }

    alice.cat += alice.cat * (inflation(year) / 100. / 12.);

    alice.vtb.account_rub -= alice.cat;
}


void alice_salary(const int month, const int year)
{
    if (month == 3) {
        alice.salary *= 1.5;  //
    }

    if (month == 2 && year == 2026) {
        alice.vtb.account_rub += 5000;  //
    }

    alice.vtb.account_rub += alice.salary;
}


void alice_deposit(const int month)
{
    if (month == 1) {
        alice.vtb.deposit *= alice.vtb.persent_deposit / 100 + 1;
        alice.vtb.deposit += 20'000;
        alice.vtb.account_rub -= 20'000;
    }
}


void alice_emotions() {
    if (rand() % 7 == 0) {
        alice.vtb.account_rub += alice.emotions;
        return;
    }
    alice.vtb.account_rub -= alice.emotions;
}


void alice_freelancing(int month, int year) {
    if (month >= 2 and year >= 2027) {
        alice.vtb.account_rub -= (alice.tax.NPD / 100) * alice.freelance;
        alice.vtb.deposit += alice.freelance;
    }

    alice.vtb.account_rub -= alice.tax.insurance;
}


void print_results()
{
    printf("Salary = %lld\n", alice.salary);

    RUB capital = 0;
    capital += alice.vtb.account_rub;
    capital += alice.vtb.deposit;
    capital += alice.vtb.account_usd * alice.vtb.rate_usd_rub;
    capital += alice.car.value;
    printf("Capital = %lld", capital);
}


void alice_car(int month, int year)
{   
    if (year == 2028) {
        alice.car.gas == 6'000;  //повышение водительского стажа
    }

    if (month == 3) {
        alice.vtb.account_rub -= alice.tax.car_log + alice.car.osago;
    }

    alice.vtb.account_rub -= alice.car.gas;

    if (month == 3 and year % 2 == 0) {
        alice.vtb.account_rub -= alice.car.tires;
    }
}


void simulation()
{
    int year = 2026;
    int month = 2;

    while (!(year == 2029 && month == 2)) {
        alice_salary(month, year);
        alice_car(month, year);
        alice_utilities(month, year);
        alice_cat(month, year);
        alice_trip(month, year);
        alice_rent(year);
        alice_deposit(month);
        alice_freelancing(month, year);
        alice_emotions();
        alice_food(month, year);

        ++month;
        if (month == 13) {
            ++year;
            month = 1;
        }
    }
}


int main()
{
    alice_init();
    simulation();
    print_results();
}

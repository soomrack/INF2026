void record_tax_paid(Person& person, RUB tax_amount) {
    person.tax_deductions.total_tax_paid_year += tax_amount;
}


void education_deduction(Person& person, RUB education_cost) {
    const RUB MAX_EDUCATION_DEDUCTION = 120'000;
    if (education_cost <= MAX_EDUCATION_DEDUCTION) {
        person.tax_deductions.education_deduction += education_cost;
    }
    else {
        person.tax_deductions.education_deduction += MAX_EDUCATION_DEDUCTION;
    }
}


void medical_deduction(Person& person, RUB medical_cost) {
    const RUB MAX_MEDICAL_DEDUCTION = 120'000; // максимум 120 тыс руб в год

    bool is_expensive_treatment = (medical_cost > 100'000);

    if (is_expensive_treatment) {
        person.tax_deductions.medical_deduction += medical_cost;
    }
    else {
        RUB deduction = min(medical_cost, MAX_MEDICAL_DEDUCTION);
        person.tax_deductions.medical_deduction += deduction;
    }
}


void property_deduction(Person& person, RUB property_cost) {
    if (!person.tax_deductions.has_property_deduction) {
        person.tax_deductions.has_property_deduction = true;

        RUB deduction_amount = min(property_cost, person.tax_deductions.property_deduction_max);
        person.tax_deductions.property_deduction_used = deduction_amount;
        person.tax_deductions.property_deduction_remaining =
        person.tax_deductions.property_deduction_max - deduction_amount;
    }
}


void iis_deduction(Person& person, RUB contribution) {
    if (person.tax_deductions.has_iis) {
        const RUB MAX_IIS_CONTRIBUTION = 400'000;
        person.tax_deductions.iis_contribution += min(contribution, MAX_IIS_CONTRIBUTION);
    }
}


RUB calculate_professional_deduction(Person& person, RUB freelance_income) {
    if (person.tax_deductions.has_professional_deduction) {
        RUB deduction = freelance_income * person.tax_deductions.professional_rate;
        return deduction;
    }
    return 0;
}


RUB calculate_standard_deduction(Person& person) {
    if (person.tax_deductions.uses_standard_deduction) {
        return person.tax_deductions.standard_deduction_amount;
    }
    return 0;
}


RUB calculate_total_deduction(Person& person) {
    RUB total_deduction = 0;

    total_deduction += person.tax_deductions.education_deduction;
    total_deduction += person.tax_deductions.medical_deduction;
    total_deduction += person.tax_deductions.charity_deduction;
    total_deduction += person.tax_deductions.pension_deduction;

    if (person.tax_deductions.has_property_deduction) {
        RUB yearly_property_deduction = min(person.tax_deductions.property_deduction_remaining,
            person.salary * 12);
        total_deduction += yearly_property_deduction;
        person.tax_deductions.property_deduction_remaining -= yearly_property_deduction;
        person.tax_deductions.property_deduction_used += yearly_property_deduction;
    }

    if (person.tax_deductions.has_iis && person.tax_deductions.iis_contribution > 0) {
        total_deduction += person.tax_deductions.iis_contribution;
    }

    return total_deduction;
}


void file_tax_return(Person& person, int year) {
    if (person.tax_deductions.filed_tax_return) return;

    RUB total_deduction = calculate_total_deduction(person);

    RUB tax_base = person.salary * 12 + person.freelance * 12;
    RUB tax_without_deduction = tax_base * 0.13;
    RUB tax_with_deduction = max(0LL, tax_base - total_deduction) * 0.13;

    person.tax_deductions.tax_refund_due = tax_without_deduction - tax_with_deduction;

    person.tax_deductions.tax_refund_due = min(person.tax_deductions.tax_refund_due,
        person.tax_deductions.total_tax_paid_year);

    if (person.tax_deductions.tax_refund_due > 0) {
        person.vtb.account_rub += person.tax_deductions.tax_refund_due;
        person.tax_deductions.tax_refund_received = person.tax_deductions.tax_refund_due;

        person.tax_deductions.filed_tax_return = true;

        if (person.tax_deductions.hires_accountant) {
            RUB accountant_fee = person.tax_deductions.accountant_cost;
            person.vtb.account_rub -= accountant_fee;
        }
    }
}


    void person_salary(Person & person, const int month, const int year)
    {
        float political_salary_factor = 1.0;

        political_salary_factor -= person.politics.economic_sanctions * 0.15;
        political_salary_factor -= person.politics.tension_level * 0.1;

        if (person.politics.has_protests) {
            political_salary_factor -= 0.05;
        }

        if (person.politics.is_election_year && (month == 3 || month == 8)) {     // социальные программы
            political_salary_factor += 0.1;
        }

        if (political_salary_factor < 0.7) political_salary_factor = 0.7;
        if (political_salary_factor > 1.2) political_salary_factor = 1.2;

        RUB adjusted_salary = person.salary * political_salary_factor;

        if (month == 3) {
            adjusted_salary *= 1.5;
        }

        RUB monthly_standard_deduction = calculate_standard_deduction(person);
        RUB taxable_income = max(0LL, adjusted_salary - monthly_standard_deduction);
        RUB ndfl = taxable_income * 0.13; // 13% НДФЛ

        record_tax_paid(person, ndfl);

        person.vtb.account_rub += adjusted_salary - ndfl;

        if (month == 2 && year == 2026) {
            person.vtb.account_rub += 5000;
        }
    }



RUB calculate_capital(Person& person)
{
    RUB capital = 0;
    capital += person.vtb.account_rub;
    capital += person.vtb.deposit;
    capital += person.vtb.invest.stocks;
    capital += person.T.invest.stocks;
    capital += person.alfa.invest.stocks;
    capital += person.Gazprom.obligation;
    capital += person.Rosatom.obligation;
    capital += person.vtb.account_usd * person.vtb.rate_usd_rub;
    capital += person.car.value;
    return capital;
}



void alice_calculate_transport_tax() {
	alice.tax.transport = static_cast<RUB>(alice.car.value * transport_tax_rate / 12.0);
}

void alice_calculate_property_tax() {
	RUB property_value = alice.home.apartment_value + alice.home.dacha_value;
	alice.tax.property = static_cast<RUB>(property_value * property_tax_rate / 12.0); // месячный налог
}

void alice_calculate_income_tax() {
	alice.tax.income = static_cast<RUB>(alice.salary * income_tax_rate);
}
bool alice_pay_taxes() {
	RUB total_taxes = alice.tax.transport + alice.tax.property + alice.tax.income;

	if (alice.vtb.account < total_taxes) {
		std::cout << "Not enough funds to pay taxes! Balance: " << alice.vtb.account
			<< ", Required: " << total_taxes << std::endl;
		return false;
	}

	alice.vtb.account -= total_taxes;
	alice.tax.total_taxes_paid += total_taxes;

	std::cout << "Taxes paid: " << total_taxes
		<< " (Income: " << alice.tax.income
		<< ", Property: " << alice.tax.property
		<< ", Transport: " << alice.tax.transport << ")" << std::endl;
	return true;
}



void alice_index_property(float yearly_rate) {
	alice.home.apartment_value += alice.home.apartment_value * yearly_rate;
	alice.home.dacha_value += alice.home.dacha_value * yearly_rate;

	float depreciation = 0.85f;  // 15% амортизация в год
	alice.car.value = alice.car.value * depreciation * (1.0f + yearly_rate);
}

void apply_yearly_inflation_alice(int year) {

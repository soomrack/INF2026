struct Inflation {
	float rate;              // текущая ставка инфляции
	float monthly_rate;      // месячная ставка инфляции
	float cumulative;        // накопленная инфляция за период
};
Inflation inflation;


void inflation_init() {
	inflation.rate = 0.09f;        // 9% годовых в 2026 году
	inflation.monthly_rate = 0.0072f;  // ~0.72% в месяц
	inflation.cumulative = 1.0f;
}

void inflation_update_rate(int year) {
	if (year == 2026) {
		inflation.rate = 0.09f;
		inflation.monthly_rate = 0.0072f;
	}
	else if (year == 2027) {
		inflation.rate = 0.08f;
		inflation.monthly_rate = 0.0064f;
	}
	else if (year == 2028) {
		inflation.rate = 0.07f;
		inflation.monthly_rate = 0.0056f;
	}
	else if (year == 2029) {
		inflation.rate = 0.06f;
		inflation.monthly_rate = 0.0049f;
	}
}


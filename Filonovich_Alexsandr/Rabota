void alice_update_prices_by_inflation(int month, int year) {
    Percent inflation = inflation_for_year(year);

    apply_monthly_inflation(alice.food, inflation);
    apply_monthly_inflation(alice.car.gas, inflation);
    apply_monthly_inflation(alice.apartment.utilities, inflation);
    apply_monthly_inflation(alice.hobbies, inflation);
    apply_monthly_inflation(alice.subscriptions, inflation);

    if (alice.family.child.exists) {
        apply_monthly_inflation(alice.family.child.monthly_cost_base, inflation);
        apply_monthly_inflation(alice.family.child.kindergarten_cost, inflation);
        apply_monthly_inflation(alice.family.child.school_cost, inflation);
        apply_monthly_inflation(alice.family.child.activities_cost, inflation);
    }

    if (alice.family.support_parents_monthly > 0) {
        apply_monthly_inflation(alice.family.support_parents_monthly, inflation);
    }

    if (month == 1) {
        char buffer[128];
        std::snprintf(buffer, sizeof(buffer), "Inflation updated costs for year %d", year);
        print_month_event(month, year, buffer);
    }
}

void alice_change_usd_rate(int month, int year) {
    float delta = random_float(-3.0f, 5.0f);
    alice.vtb.rate_usd_rub *= (1.0f + delta / 100.0f);

    if (alice.vtb.rate_usd_rub < 50.0f) alice.vtb.rate_usd_rub = 50.0f;
    if (alice.vtb.rate_usd_rub > 160.0f) alice.vtb.rate_usd_rub = 160.0f;

    if (month == 1 || month == 6 || month == 12) {
        std::printf("[%s %d] USD/RUB rate = %.2f\n", month_name(month), year, alice.vtb.rate_usd_rub);
    }
}

void alice_lifestyle_choice(int month, int year) {
    if (alice.vtb.account_rub < 50000) {
        if (alice.mode != ECONOMY) {
            alice.mode = ECONOMY;
            print_month_event(month, year, "Alice switched to economy lifestyle.");
        }
    }
    else if (alice.vtb.account_rub > 700000 && alice.stress < 40) {
        if (alice.mode != RICH && random_percent() < 20.0f) {
            alice.mode = RICH;
            print_month_event(month, year, "Alice switched to rich lifestyle.");
        }
    }
    else {
        if (alice.mode != NORMAL) {
            alice.mode = NORMAL;
            print_month_event(month, year, "Alice switched to normal lifestyle.");
        }
    }
}

void alice_burnout_logic(int month, int year) {
    if (!alice.health.burnout) {
        float burnout_risk = 0.0f;
        if (alice.stress > 75) burnout_risk += 10.0f;
        if (alice.career.months_without_raise > 18) burnout_risk += 4.0f;
        if (alice.career.has_side_job) burnout_risk += 5.0f;
        if (alice.family.child.exists) burnout_risk += 3.0f;
        if (alice.career.employed && random_percent() < burnout_risk) {
            alice.health.burnout = true;
            alice.health.burnout_months_left = random_int(2, 5);
            print_month_event(month, year, "Alice is experiencing burnout.");
            add_stress(12);
        }
    }
    else {
        alice.health.burnout_months_left--;
        if (alice.health.burnout_months_left <= 0) {
            alice.health.burnout = false;
            print_month_event(month, year, "Alice recovered from burnout.");
            add_stress(-15);
        }
    }
}

void alice_side_job_logic(int month, int year) {
    if (!alice.career.employed || alice.career.on_maternity_leave) return;

    if (!alice.career.has_side_job) {
        float chance = 0.0f;
        if (alice.vtb.account_rub < 150000) chance += 10.0f;
        if (alice.goal.type == GOAL_EARLY_MORTGAGE) chance += 5.0f;
        if (alice.family.child.exists) chance += 5.0f;
        if (alice.stress < 60) chance += 4.0f;

        if (random_percent() < chance) {
            alice.career.has_side_job = true;
            alice.career.side_job_income = random_rub(15000, 50000);
            print_month_event_rub(month, year, "Alice started a side job, monthly income", alice.career.side_job_income);
            add_stress(5);
        }
    }
    else {
        if (alice.stress > 85 || alice.health.burnout) {
            alice.career.has_side_job = false;
            print_month_event(month, year, "Alice quit her side job.");
            add_stress(-8);
        }
        else {
            RUB side_income = alice.career.side_job_income;
            RUB tax = static_cast<RUB>(side_income * 0.06f);
            RUB net = side_income - tax;
            alice.vtb.account_rub += net;
            alice.total_side_income += net;
        }
    }
}

void alice_profession_change_logic(int month, int year) {
    if (!alice.career.employed) return;
    if (month != 5 && month != 10) return;
    if (alice.career.changed_profession_ever) return;

    float chance = 0.0f;
    if (alice.career.track == CAREER_OFFICE && alice.stress > 60) chance += 8.0f;
    if (alice.career.track == CAREER_OFFICE && alice.career.experience_years >= 5) chance += 4.0f;
    if (alice.portfolio.current_value + alice.deposit.balance > 500000) chance += 3.0f;

    if (random_percent() < chance) {
        CareerTrack old_track = alice.career.track;
        RUB old_salary = alice.salary;

        if (old_track == CAREER_OFFICE) {
            alice.career.track = CAREER_IT;
            alice.salary = static_cast<RUB>(alice.salary * random_float(1.05f, 1.30f));
        }
        else if (old_track == CAREER_IT) {
            alice.career.track = CAREER_MANAGEMENT;
            alice.salary = static_cast<RUB>(alice.salary * random_float(1.00f, 1.25f));
        }
        else {
            alice.career.track = CAREER_SELF_EMPLOYED;
            alice.salary = static_cast<RUB>(alice.salary * random_float(0.80f, 1.10f));
        }

        alice.career.changed_profession_ever = true;
        print_month_event(month, year, "Alice changed profession/career track.");
        print_month_event_rub(month, year, "Old salary", old_salary);
        print_month_event_rub(month, year, "New salary", alice.salary);
        add_stress(10);
    }
}

void alice_unemployment_logic(int month, int year) {
    if (alice.career.on_maternity_leave) return;

    if (alice.career.employed) {
        float risk = 2.0f;
        if (alice.stress > 70) risk += 2.5f;
        if (alice.health.burnout) risk += 4.0f;
        if (alice.career.track == CAREER_SELF_EMPLOYED) risk += 3.0f;

        if (random_percent() < risk) {
            alice.career.employed = false;
            alice.career.unemployment_months_left = random_int(2, 5);
            alice.career.previous_salary = alice.salary;
            print_month_event(month, year, "Alice lost her job.");
            add_stress(20);
        }
    }
    else {
        alice.career.unemployment_months_left--;
        if (alice.career.unemployment_months_left <= 0) {
            alice.career.employed = true;
            float coeff = random_float(0.9f, 1.2f);
            alice.salary = static_cast<RUB>(alice.career.previous_salary * coeff);
            print_month_event_rub(month, year, "Alice found a new job, salary", alice.salary);
            add_stress(-15);
        }
    }
}

void alice_salary_income(int month, int year) {
    if (alice.career.on_maternity_leave) {
        RUB maternity_payment = 45000;
        alice.vtb.account_rub += maternity_payment;
        print_month_event_rub(month, year, "Maternity leave payment", maternity_payment);

        alice.career.maternity_months_left--;
        if (alice.career.maternity_months_left <= 0) {
            alice.career.on_maternity_leave = false;
            print_month_event(month, year, "Alice returned from maternity leave.");
        }
        return;
    }

    if (!alice.career.employed) return;

    if (month == 3) {
        RUB old_salary = alice.salary;
        Percent indexation = alice.annual_salary_indexation;

        if (alice.career.track == CAREER_IT) indexation += 2.0f;
        if (alice.career.track == CAREER_MANAGEMENT) indexation += 1.0f;
        if (alice.health.burnout) indexation -= 3.0f;
        if (alice.career.experience_years > 8) indexation += 2.0f;

        if (random_percent() < 25.0f) {
            indexation += random_float(5.0f, 12.0f);
            print_month_event(month, year, "Alice got a promotion.");
        }
        else if (random_percent() < 15.0f) {
            indexation = 0.0f;
            print_month_event(month, year, "Alice got no raise this year.");
            alice.career.months_without_raise += 12;
        }
        else {
            alice.career.months_without_raise = 0;
        }

        if (indexation < 0.0f) indexation = 0.0f;

        alice.salary += static_cast<RUB>(alice.salary * indexation / 100.0f);

        if (alice.salary != old_salary) {
            print_month_event_rub(month, year, "New salary", alice.salary);
        }

        alice.career.experience_years++;
    }

    if (month == 2 && year == 2026) {
        alice.vtb.account_rub += 5000;
        print_month_event_rub(month, year, "One-time work bonus", 5000);
    }

    RUB gross = alice.salary;
    RUB tax = static_cast<RUB>(gross * alice.income_tax / 100.0f);
    RUB net = gross - tax;

    alice.total_tax_paid += tax;
    alice.vtb.account_rub += net;
}

void alice_quarter_bonus(int month, int year) {
    if (!alice.career.employed || alice.career.on_maternity_leave) return;
    if (month != 3 && month != 6 && month != 9 && month != 12) return;

    float chance = 20.0f;

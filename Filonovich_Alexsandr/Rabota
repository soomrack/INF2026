    if (alice.mode == ECONOMY) {
        hobby_cost /= 2;
    }
    else if (alice.mode == RICH) {
        hobby_cost *= 2;
        food_cost = food_cost * 12 / 10;
    }

    if (month == 12) {
        RUB gifts = 15000;
        alice.vtb.account_rub -= gifts;
        alice.total_unexpected_paid += gifts;
        print_month_event_rub(month, year, "New Year gifts", gifts);
    }

    alice.vtb.account_rub -= food_cost;
    alice.vtb.account_rub -= hobby_cost;
    alice.vtb.account_rub -= subs_cost;

    alice.total_hobby_paid += hobby_cost;
}

void alice_utilities(int month, int year) {
    if (!alice.apartment.purchased) return;

    RUB bill = alice.apartment.utilities;
    alice.vtb.account_rub -= bill;
    alice.total_utilities_paid += bill;

    if (month == 1) {
        RUB cap_repair = 5000;
        alice.vtb.account_rub -= cap_repair;
        alice.total_utilities_paid += cap_repair;
        print_month_event_rub(month, year, "Annual apartment maintenance", cap_repair);
    }
}

void alice_mortgage(int month, int year) {
    if (!alice.apartment.purchased || alice.apartment.mortgage_debt <= 0) return;

    RUB interest_part = static_cast<RUB>(
        alice.apartment.mortgage_debt * (alice.apartment.mortgage_rate_year / 100.0f / 12.0f)
        );

    RUB payment = alice.apartment.monthly_payment;
    RUB full_need = interest_part + alice.apartment.mortgage_debt;
    if (payment > full_need) payment = full_need;

    alice.vtb.account_rub -= payment;
    alice.total_mortgage_paid += payment;

    if (payment > interest_part) {
        RUB real_principal = payment - interest_part;
        alice.apartment.mortgage_debt -= real_principal;
    }

    if (alice.apartment.mortgage_debt < 0) {
        alice.apartment.mortgage_debt = 0;
    }

    if (alice.apartment.mortgage_debt == 0) {
        print_month_event(month, year, "Mortgage fully paid.");
    }

    if (alice.goal.type == GOAL_EARLY_MORTGAGE &&
        alice.vtb.account_rub > 500000 &&
        alice.apartment.mortgage_debt > 0) {
        RUB extra_payment = alice.vtb.account_rub / 5;
        if (extra_payment > alice.apartment.mortgage_debt) {
            extra_payment = alice.apartment.mortgage_debt;
        }
        alice.vtb.account_rub -= extra_payment;
        alice.apartment.mortgage_debt -= extra_payment;
        alice.total_mortgage_paid += extra_payment;
        print_month_event_rub(month, year, "Extra mortgage payment", extra_payment);
    }
}

void alice_check_health(int month, int year) {
    if (alice.health.is_sick) {
        if (year > alice.health.recovery_year ||
            (year == alice.health.recovery_year && month >= alice.health.recovery_month)) {
            alice.health.is_sick = false;
            alice.health.disease_id = -1;
            alice.health.severity = 0;
            alice.health.monthly_treatment_cost = 0;
            print_month_event(month, year, "Alice recovered.");
            add_stress(-10);
        }
        return;
    }

    for (int i = 0; i < DISEASE_COUNT; ++i) {
        float risk_modifier = 1.0f + alice.stress / 200.0f;
        float roll = random_percent();

        if (roll < diseases[i].probability_per_month * risk_modifier) {
            alice.health.is_sick = true;
            alice.health.disease_id = i;
            alice.health.severity = random_int(1, 3);

            alice.health.start_day = random_int(1, 28);
            alice.health.start_month = month;
            alice.health.start_year = year;

            int duration = random_int(diseases[i].min_duration, diseases[i].max_duration);
            int total_months = month + duration - 1;

            alice.health.recovery_month = total_months % 12;
            if (alice.health.recovery_month == 0) alice.health.recovery_month = 12;
            alice.health.recovery_year = year + (total_months - 1) / 12;
            alice.health.recovery_day = random_int(1, 28);

            RUB cost = 5000LL * alice.health.severity;
            if (alice.health.has_dms) cost /= 2;
            alice.health.monthly_treatment_cost = cost;

            char buffer[256];
            std::snprintf(buffer, sizeof(buffer), "Alice got sick with %s", diseases[i].name);
            print_month_event(month, year, buffer);
            add_stress(15);
            break;
        }
    }
}

void alice_treatment(int month, int year) {
    if (!alice.health.is_sick) return;

    alice.vtb.account_rub -= alice.health.monthly_treatment_cost;
    alice.total_treatment_paid += alice.health.monthly_treatment_cost;

    if (alice.health.has_dms) {
        RUB dms_fee = 3000;
        alice.vtb.account_rub -= dms_fee;
        alice.total_treatment_paid += dms_fee;
    }

    if (alice.health.severity == 3 && random_percent() < 15.0f) {
        RUB extra_tests = 12000;
        alice.vtb.account_rub -= extra_tests;
        alice.total_treatment_paid += extra_tests;
        print_month_event_rub(month, year, "Extra medical tests", extra_tests);
    }
}


void apply_monthly_inflation(RUB& value, Percent yearly_inflation) {
    value += static_cast<RUB>(value * (yearly_inflation / 100.0f / 12.0f));
}

Percent inflation_for_year(int year) {
    switch (year) {
    case 2026: return 12.5f;
    case 2027: return 14.0f;
    case 2028: return 13.0f;
    case 2029: return 11.5f;
    default: return 10.0f;
    }
}

void alice_update_prices_by_inflation(int month, int year) {
    Percent inflation = inflation_for_year(year);

    apply_monthly_inflation(alice.food, inflation);
    apply_monthly_inflation(alice.car.gas, inflation);
    apply_monthly_inflation(alice.apartment.utilities, inflation);
    apply_monthly_inflation(alice.hobbies, inflation);
    apply_monthly_inflation(alice.subscriptions, inflation);

    if (alice.family.has_child) {
        apply_monthly_inflation(alice.family.child_monthly_cost, inflation);
    }

    if (month == 1) {
        char buffer[128];
        std::snprintf(buffer, sizeof(buffer), "Inflation updated costs for year %d", year);
        print_month_event(month, year, buffer);
    }
}

void alice_salary_income(int month, int year) {
    if (!alice.career.employed) return;

    if (month == 3) {
        RUB old_salary = alice.salary;
        Percent indexation = alice.annual_salary_indexation;

        if (random_percent() < 25.0f) {
            indexation += random_float(5.0f, 12.0f);
            print_month_event(month, year, "Alice got a promotion.");
        }
        else if (random_percent() < 15.0f) {
            indexation = 0.0f;
            print_month_event(month, year, "Alice got no raise this year.");
        }

        alice.salary += static_cast<RUB>(alice.salary * indexation / 100.0f);

        if (alice.salary != old_salary) {
            print_month_event_rub(month, year, "New salary", alice.salary);
        }
    }

    if (month == 2 && year == 2026) {
        alice.vtb.account_rub += 5000;
        print_month_event_rub(month, year, "One-time work bonus", 5000);
    }

    RUB gross = alice.salary;
    RUB tax = static_cast<RUB>(gross * alice.income_tax / 100.0f);
    RUB net = gross - tax;

    alice.total_tax_paid += tax;
    alice.vtb.account_rub += net;
}

void alice_quarter_bonus(int month, int year) {
    if (!alice.career.employed) return;
    if (month != 3 && month != 6 && month != 9 && month != 12) return;

    if (random_percent() < 20.0f) {
        float multiplier = random_float(0.5f, 2.0f);
        RUB bonus = static_cast<RUB>(alice.salary * multiplier);
        RUB tax = static_cast<RUB>(bonus * alice.income_tax / 100.0f);
        RUB net = bonus - tax;

        alice.total_tax_paid += tax;
        alice.vtb.account_rub += net;
        print_month_event_rub(month, year, "Quarter bonus after tax", net);
        add_stress(-5);
    }
}

void alice_unemployment_logic(int month, int year) {
    if (alice.career.employed) {
        float risk = 2.0f;
        if (alice.stress > 70) risk += 2.0f;
        if (random_percent() < risk) {
            alice.career.employed = false;
            alice.career.unemployment_months_left = random_int(2, 5);
            alice.career.previous_salary = alice.salary;
            print_month_event(month, year, "Alice lost her job.");
            add_stress(20);
        }
    }
    else {
        alice.career.unemployment_months_left--;
        if (alice.career.unemployment_months_left <= 0) {
            alice.career.employed = true;
            float coeff = random_float(0.9f, 1.2f);
            alice.salary = static_cast<RUB>(alice.career.previous_salary * coeff);
            print_month_event_rub(month, year, "Alice found a new job, salary", alice.salary);
            add_stress(-15);
        }
    }
}

void alice_car_expenses(int month, int year) {
    alice.vtb.account_rub -= alice.car.gas;

    float breakdown_chance = 8.0f;
    if (random_percent() < breakdown_chance) {
        int repair_type = random_int(1, 3);
        RUB repair_cost = 0;

        if (repair_type == 1) {
            repair_cost = 5000;
            print_month_event(month, year, "Minor car repair.");
        }
        else if (repair_type == 2) {
            repair_cost = 25000;
            print_month_event(month, year, "Medium car repair.");
        }
        else {
            repair_cost = 120000;
            print_month_event(month, year, "Major car repair.");
        }

        alice.car.last_repair_cost = repair_cost;
        alice.vtb.account_rub -= repair_cost;
        alice.total_repairs_paid += repair_cost;
        alice.car.value -= repair_cost / 5;
        if (alice.car.value < 400000) alice.car.value = 400000;
        add_stress(10);
    }

    if (month == 11) {
        RUB insurance = 18000;
        alice.vtb.account_rub -= insurance;
        alice.total_repairs_paid += insurance;
        print_month_event_rub(month, year, "Annual car insurance", insurance);
    }
}

void alice_food_and_life(int month, int year) {

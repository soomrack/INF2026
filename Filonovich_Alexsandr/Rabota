void alice_check_health(int month, int year) {
    if (alice.health.is_sick) {
        if (year > alice.health.recovery_year ||
            (year == alice.health.recovery_year && month >= alice.health.recovery_month)) {
            alice.health.is_sick = false;
            alice.health.disease_id = -1;
            alice.health.severity = 0;
            alice.health.monthly_treatment_cost = 0;
            print_month_event(month, year, "Alice recovered.");
            add_stress(-10);
        }
        return;
    }

    for (int i = 0; i < DISEASE_COUNT; ++i) {
        float risk_modifier = 1.0f + alice.stress / 200.0f;
        if (alice.family.child.exists && alice.family.child.stage == CHILD_KINDERGARTEN) {
            risk_modifier += 0.15f;
        }
        float roll = random_percent();

        if (roll < diseases[i].probability_per_month * risk_modifier) {
            alice.health.is_sick = true;
            alice.health.disease_id = i;
            alice.health.severity = random_int(1, 3);

            alice.health.start_day = random_int(1, 28);
            alice.health.start_month = month;
            alice.health.start_year = year;

            int duration = random_int(diseases[i].min_duration, diseases[i].max_duration);
            int total_months = month + duration - 1;

            alice.health.recovery_month = total_months % 12;
            if (alice.health.recovery_month == 0) alice.health.recovery_month = 12;
            alice.health.recovery_year = year + (total_months - 1) / 12;
            alice.health.recovery_day = random_int(1, 28);

            RUB cost = 5000LL * alice.health.severity;
            if (alice.health.has_dms) cost /= 2;
            alice.health.monthly_treatment_cost = cost;

            char buffer[256];
            std::snprintf(buffer, sizeof(buffer), "Alice got sick with %s", diseases[i].name);
            print_month_event(month, year, buffer);
            add_stress(15);
            break;
        }
    }
}


void alice_vacation(int month, int year) {
    if (alice.took_vacation_this_year) return;
    if (month != 7 && month != 8) return;

    float chance = 60.0f;
    if (alice.mode == ECONOMY) chance = 30.0f;
    if (alice.mode == RICH) chance = 90.0f;

    if (random_percent() < chance) {
        RUB vacation_cost = 0;

        if (alice.mode == ECONOMY) vacation_cost = random_rub(30000, 70000);
        else if (alice.mode == NORMAL) vacation_cost = random_rub(70000, 150000);
        else vacation_cost = random_rub(150000, 300000);

        if (alice.vtb.account_rub > vacation_cost || alice.goal.type == GOAL_TRAVEL) {
            alice.vtb.account_rub -= vacation_cost;
            alice.total_travel_paid += vacation_cost;
            alice.took_vacation_this_year = true;
            print_month_event_rub(month, year, "Vacation spending", vacation_cost);
            add_stress(-20);
        }
    }
}


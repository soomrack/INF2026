void simulation() {
    int year = 2026;
    int month = 2;

    while (!(year == 2031 && month == 2)) {
        std::printf("\n %s %d \n", month_name(month), year);

        alice_new_year_reset(month, year);
        alice_lifestyle_choice(month, year);
        alice_change_usd_rate(month, year);
        alice_update_prices_by_inflation(month, year);

        alice_unemployment_logic(month, year);
        alice_salary_income(month, year);
        alice_quarter_bonus(month, year);

        alice_utilities(month, year);
        alice_mortgage(month, year);
        alice_car_expenses(month, year);
        alice_food_and_life(month, year);

        alice_check_health(month, year);
        alice_treatment(month, year);

        alice_family_costs();
        alice_furniture_and_appliances(month, year);
        alice_unexpected_events(month, year);
        alice_vacation(month, year);

        alice_lottery(month, year);
        alice_tax_deduction(month, year);

        alice_deposit_logic(month, year);
        alice_investments(month, year);
        alice_apartment_market(month, year);

        alice_stress_update(month, year);
        alice_goal_logic(month, year);
        alice_buy_new_car_if_goal_reached(month, year);

        std::printf("Month-end RUB balance: %lld\n", alice.vtb.account_rub);
        std::printf("Month-end deposit: %lld\n", alice.deposit.balance);
        std::printf("Month-end portfolio: %lld\n", alice.portfolio.current_value);
        std::printf("Month-end mortgage debt: %lld\n", alice.apartment.mortgage_debt);
        std::printf("Stress: %d\n", alice.stress);

        ++month;
        if (month == 13) {
            ++year;
            month = 1;
        }
    }
}

int main() {
    std::srand(static_cast<unsigned int>(std::time(nullptr)));

    alice_init();
    simulation();
    print_results();

    return 0;
}

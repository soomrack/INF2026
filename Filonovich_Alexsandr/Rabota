const char* month_name(int m) {
    static const char* names[] = {
        "", "Jan", "Feb", "Mar", "Apr", "May", "Jun",
        "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"
    };
    if (m < 1 || m > 12) return "Unknown";
    return names[m];
}

const char* lifestyle_name(LifestyleMode mode) {
    switch (mode) {
    case ECONOMY: return "ECONOMY";
    case NORMAL: return "NORMAL";
    case RICH: return "RICH";
    default: return "UNKNOWN";
    }
}

const char* career_track_name(CareerTrack track) {
    switch (track) {
    case CAREER_OFFICE: return "Office";
    case CAREER_IT: return "IT";
    case CAREER_MANAGEMENT: return "Management";
    case CAREER_SELF_EMPLOYED: return "Self-employed";
    default: return "Unknown";
    }
}

const char* child_stage_name(ChildStage st) {
    switch (st) {
    case CHILD_NONE: return "None";
    case CHILD_BABY: return "Baby";
    case CHILD_KINDERGARTEN: return "Kindergarten";
    case CHILD_SCHOOL: return "School";
    default: return "Unknown";
    }
}

float random_percent() {
    return static_cast<float>(rand()) / RAND_MAX * 100.0f;
}

int random_int(int min_value, int max_value) {
    return min_value + rand() % (max_value - min_value + 1);
}

RUB random_rub(RUB min_value, RUB max_value) {
    if (max_value <= min_value) return min_value;
    RUB range = max_value - min_value + 1;
    return min_value + static_cast<RUB>(rand()) % range;
}

float random_float(float min_value, float max_value) {
    return min_value + (static_cast<float>(rand()) / RAND_MAX) * (max_value - min_value);
}

void add_stress(int value) {
    alice.stress += value;
    if (alice.stress > 100) alice.stress = 100;
    if (alice.stress < 0) alice.stress = 0;
}

void print_month_event(int month, int year, const char* text) {
    std::printf("[%s %d] %s\n", month_name(month), year, text);
}

void print_month_event_rub(int month, int year, const char* text, RUB value) {
    std::printf("[%s %d] %s: %lld RUB\n", month_name(month), year, text, value);
}

void apply_monthly_inflation(RUB& value, Percent yearly_inflation) {
    value += static_cast<RUB>(value * (yearly_inflation / 100.0f / 12.0f));
}

Percent inflation_for_year(int year) {
    switch (year) {
    case 2026: return 12.5f;
    case 2027: return 14.0f;
    case 2028: return 13.0f;
    case 2029: return 11.5f;
    case 2030: return 10.0f;
    default: return 10.0f;
    }
}


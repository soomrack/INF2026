void alice_business_logic(int month, int year) {
    if (!alice.business.active) {
        float chance = 0.0f;
        if (alice.deposit.balance > 800000) chance += 6.0f;
        if (alice.career.has_side_job) chance += 6.0f;
        if (alice.career.track == CAREER_SELF_EMPLOYED) chance += 5.0f;

        if (random_percent() < chance) {
            RUB invest = random_rub(300000, 900000);
            if (alice.deposit.balance >= invest || alice.vtb.account_rub >= invest) {
                if (alice.vtb.account_rub >= invest) {
                    alice.vtb.account_rub -= invest;
                }
                else {
                    RUB from_cash = alice.vtb.account_rub;
                    alice.vtb.account_rub = 0;
                    alice.deposit.balance -= (invest - from_cash);
                }

                alice.business.active = true;
                alice.business.invested = invest;
                alice.business.monthly_profit = random_rub(-30000, 80000);
                alice.business.months_active = 0;
                print_month_event_rub(month, year, "Alice started a small business, invested", invest);
                add_stress(10);
            }
        }
    }
    else {
        alice.business.months_active++;
        RUB result = alice.business.monthly_profit + random_rub(-20000, 30000);
        alice.vtb.account_rub += result;
        alice.total_business_profit += result;

        if (result >= 0) {
            print_month_event_rub(month, year, "Business monthly profit", result);
        }
        else {
            print_month_event_rub(month, year, "Business monthly loss", -result);
        }

        if (alice.business.months_active > 12 && result < 0 && random_percent() < 25.0f) {
            alice.business.active = false;
            print_month_event(month, year, "Alice closed the business.");
            add_stress(-5);
        }
    }
}


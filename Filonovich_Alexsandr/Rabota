    }
    else if (type == 5) {
        amount = random_rub(5000, 25000);
        alice.vtb.account_rub += amount;
        print_month_event_rub(month, year, "Tax overpayment refund", amount);
    }
    else {
        amount = random_rub(10000, 100000);
        alice.vtb.account_rub -= amount;
        alice.total_unexpected_paid += amount;
        print_month_event_rub(month, year, "Unexpected emergency spending", amount);
        add_stress(12);
    }
}

void alice_change_usd_rate(int month, int year) {
    float delta = random_float(-3.0f, 5.0f);
    alice.vtb.rate_usd_rub *= (1.0f + delta / 100.0f);

    if (alice.vtb.rate_usd_rub < 50.0f) alice.vtb.rate_usd_rub = 50.0f;
    if (alice.vtb.rate_usd_rub > 160.0f) alice.vtb.rate_usd_rub = 160.0f;

    if (month == 1 || month == 6 || month == 12) {
        std::printf("[%s %d] USD/RUB rate = %.2f\n", month_name(month), year, alice.vtb.rate_usd_rub);
    }
}

void alice_apartment_market(int month, int year) {
    float delta = random_float(-1.0f, 1.5f);

    if (random_percent() < 8.0f) {
        delta = random_float(-4.0f, -1.0f);
        print_month_event(month, year, "Real estate market downturn.");
    }

    alice.apartment.value += static_cast<RUB>(alice.apartment.value * delta / 100.0f);
    if (alice.apartment.value < 3500000) alice.apartment.value = 3500000;
}

void alice_deposit_logic(int month, int year) {
    if (!alice.deposit.active) return;

    if (alice.vtb.account_rub > 400000) {
        RUB transfer = alice.vtb.account_rub - 300000;
        alice.vtb.account_rub -= transfer;
        alice.deposit.balance += transfer;
        print_month_event_rub(month, year, "Moved to deposit", transfer);
    }

    if (alice.deposit.balance > 0) {
        RUB interest = static_cast<RUB>(alice.deposit.balance * alice.deposit.rate_year / 100.0f / 12.0f);
        alice.deposit.balance += interest;

        if (alice.vtb.account_rub < 0 && alice.deposit.balance > 0) {
            RUB withdraw = (-alice.vtb.account_rub) + 50000;
            if (withdraw > alice.deposit.balance) withdraw = alice.deposit.balance;
            alice.deposit.balance -= withdraw;
            alice.vtb.account_rub += withdraw;
            print_month_event_rub(month, year, "Withdraw from deposit", withdraw);
        }
    }
}

void alice_investments(int month, int year) {
    if (alice.vtb.account_rub > 250000 && alice.mode != ECONOMY) {
        RUB invest = 30000;
        if (invest > alice.vtb.account_rub - 150000) invest = alice.vtb.account_rub - 150000;
        if (invest > 0) {
            alice.vtb.account_rub -= invest;
            alice.portfolio.invested_total += invest;
            alice.portfolio.current_value += invest;
            alice.total_invested += invest;
            print_month_event_rub(month, year, "Investment purchase", invest);
        }
    }

    if (alice.portfolio.current_value > 0) {
        float monthly_return = random_float(-8.0f, 10.0f);
        alice.portfolio.current_value += static_cast<RUB>(alice.portfolio.current_value * monthly_return / 100.0f);
        if (alice.portfolio.current_value < 0) alice.portfolio.current_value = 0;

        if (random_percent() < 4.0f) {
            print_month_event(month, year, "Stock market volatility affected portfolio.");
        }
    }
}

void alice_tax_deduction(int month, int year) {
    if (month != 4) return;
    if (!alice.apartment.purchased) return;

    RUB deduction = 0;
    if (alice.total_tax_paid > 0) {
        deduction = 52000;
        if (deduction > alice.total_tax_paid) deduction = alice.total_tax_paid;
    }

    alice.vtb.account_rub += deduction;
    alice.total_tax_deduction_received += deduction;
    if (deduction > 0) {
        print_month_event_rub(month, year, "Mortgage tax deduction", deduction);
    }
}

void alice_lifestyle_choice(int month, int year) {
    if (alice.vtb.account_rub < 50000) {
        if (alice.mode != ECONOMY) {
            alice.mode = ECONOMY;
            print_month_event(month, year, "Alice switched to economy lifestyle.");
        }
    }
    else if (alice.vtb.account_rub > 700000 && alice.stress < 40) {
        if (alice.mode != RICH && random_percent() < 20.0f) {
            alice.mode = RICH;
            print_month_event(month, year, "Alice switched to rich lifestyle.");
        }
    }
    else {
        if (alice.mode != NORMAL) {
            alice.mode = NORMAL;
            print_month_event(month, year, "Alice switched to normal lifestyle.");
        }
    }
}

void alice_stress_update(int month, int year) {
    add_stress(1);

    if (alice.vtb.account_rub < 0) add_stress(15);
    else if (alice.vtb.account_rub < 50000) add_stress(8);
    else if (alice.vtb.account_rub > 400000) add_stress(-4);

    if (alice.health.is_sick) add_stress(4);
    if (!alice.career.employed) add_stress(7);
    if (alice.family.has_child) add_stress(2);
    if (month == 12) add_stress(4);

    if (alice.stress > 80) {
        RUB anti_stress = 10000;
        if (alice.vtb.account_rub > anti_stress) {
            alice.vtb.account_rub -= anti_stress;
            alice.total_hobby_paid += anti_stress;
            print_month_event_rub(month, year, "Anti-stress spending", anti_stress);
            add_stress(-10);
        }
    }
}

void alice_goal_logic(int month, int year) {
    RUB net_worth = 0;
    net_worth += alice.vtb.account_rub;
    net_worth += alice.deposit.balance;
    net_worth += static_cast<RUB>(alice.vtb.account_usd * alice.vtb.rate_usd_rub);
    net_worth += alice.car.value;
    net_worth += (alice.apartment.value - alice.apartment.mortgage_debt);
    net_worth += alice.apartment.furniture_value;
    net_worth += alice.portfolio.current_value;

    if (!alice.goal.achieved) {
        if (alice.goal.type == GOAL_EMERGENCY_FUND) {
            if (alice.vtb.account_rub + alice.deposit.balance >= alice.goal.target_amount) {
                alice.goal.achieved = true;
                print_month_event(month, year, "Emergency fund goal achieved.");
                alice.goal.type = GOAL_EARLY_MORTGAGE;
                alice.goal.target_amount = 0;
                alice.goal.achieved = false;
            }
        }
        else if (alice.goal.type == GOAL_EARLY_MORTGAGE) {
            if (alice.apartment.mortgage_debt == 0) {
                alice.goal.achieved = true;
                print_month_event(month, year, "Mortgage repayment goal achieved.");
                alice.goal.type = GOAL_NEW_CAR;
                alice.goal.target_amount = 3000000;
                alice.goal.achieved = false;
            }
        }
        else if (alice.goal.type == GOAL_NEW_CAR) {
            if (alice.vtb.account_rub + alice.deposit.balance >= alice.goal.target_amount) {
                alice.goal.achieved = true;
                print_month_event(month, year, "Goal for a new car achieved.");
            }
        }
        else if (alice.goal.type == GOAL_TRAVEL) {
            if (alice.total_travel_paid >= alice.goal.target_amount) {
                alice.goal.achieved = true;
                print_month_event(month, year, "Travel goal achieved.");
            }
        }
    }

    if (net_worth < 0) {
        print_month_event(month, year, "Warning: negative net worth zone.");
    }
}

void alice_buy_new_car_if_goal_reached(int month, int year) {
    if (alice.goal.type == GOAL_NEW_CAR && alice.goal.achieved) {
        RUB price = 3000000;
        if (alice.vtb.account_rub + alice.deposit.balance >= price) {
            if (alice.vtb.account_rub < price) {
                RUB need = price - alice.vtb.account_rub;
                if (need > alice.deposit.balance) need = alice.deposit.balance;
                alice.deposit.balance -= need;
                alice.vtb.account_rub += need;
            }

            alice.vtb.account_rub -= price;
            alice.car.value = 3000000;
            alice.car.gas = 18000;
            print_month_event_rub(month, year, "Alice bought a new car", price);

            alice.goal.type = GOAL_TRAVEL;
            alice.goal.target_amount = 400000;
            alice.goal.achieved = false;
            add_stress(-5);
        }
    }
}


void alice_mortgage(int month, int year) {
    if (!alice.apartment.purchased || alice.apartment.mortgage_debt <= 0) return;

    RUB interest_part = static_cast<RUB>(
        alice.apartment.mortgage_debt * (alice.apartment.mortgage_rate_year / 100.0f / 12.0f)
        );

    RUB payment = alice.apartment.monthly_payment;
    RUB full_need = interest_part + alice.apartment.mortgage_debt;
    if (payment > full_need) payment = full_need;

    alice.vtb.account_rub -= payment;
    alice.total_mortgage_paid += payment;

    if (payment > interest_part) {
        RUB real_principal = payment - interest_part;
        alice.apartment.mortgage_debt -= real_principal;
    }

    if (alice.apartment.mortgage_debt < 0) alice.apartment.mortgage_debt = 0;
    if (alice.apartment.mortgage_debt == 0) {
        print_month_event(month, year, "Mortgage fully paid.");
    }

    if (alice.goal.type == GOAL_EARLY_MORTGAGE &&
        alice.vtb.account_rub > 500000 &&
        alice.apartment.mortgage_debt > 0) {
        RUB extra_payment = alice.vtb.account_rub / 5;
        if (extra_payment > alice.apartment.mortgage_debt) {
            extra_payment = alice.apartment.mortgage_debt;
        }
        alice.vtb.account_rub -= extra_payment;
        alice.apartment.mortgage_debt -= extra_payment;
        alice.total_mortgage_paid += extra_payment;
        print_month_event_rub(month, year, "Extra mortgage payment", extra_payment);
    }
}

void alice_car_loan_logic(int month, int year) {
    if (!alice.car.loan.active) return;

    RUB interest = static_cast<RUB>(alice.car.loan.debt * alice.car.loan.rate_year / 100.0f / 12.0f);
    RUB payment = alice.car.loan.monthly_payment;
    RUB full_need = interest + alice.car.loan.debt;
    if (payment > full_need) payment = full_need;

    alice.vtb.account_rub -= payment;
    alice.total_car_loan_paid += payment;

    if (payment > interest) {
        alice.car.loan.debt -= (payment - interest);

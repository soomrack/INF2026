class Clock {
private:
    int hours;
    int minutes; 
public:
    Clock() : hours(12), minutes(0) {}  
    
    void update() {
        minutes++;
        if (minutes >= 60) {
            minutes = 0;
            hours++;
            if (hours >= 24) {
                hours = 0;
            }
        }
    }
    
    int get_hours() const { return hours; }
    int get_minutes() const { return minutes; }  
    
    bool is_night() const {
        return (hours >= 20 || hours < 6);
    }
    
    bool is_day() const {
        return !is_night();
    }
};



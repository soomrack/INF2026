void control_temperature(const Thermometer& thermometer, Heater& heater, Fan& fan, Conditioner& conditioner)  {
    float temp = thermometer.get_temperature();
    
    if (temp > 40) {  
        heater.off();
        conditioner.on();
        fan.on();      
    }
    else if (temp < 20) {  
        heater.on();
        conditioner.off();
        fan.on();     
    }
    else {  
        heater.off();
        conditioner.off();
        fan.off();    
    }
}



void control_illumination(const Light& light, Clock& clock, Lamp& lamp)
{
    
    if (clock.is_night()) {
        lamp.off();
        return;
    }
    

    float ill = light.get_illumination();

    if (ill > 5000) {  
        lamp.off();     
    }
    else if (ill < 3000) {  
        lamp.on();     
    }
}



void control_humidity(const Hygrometer& hygrometer, Pump& pump, Heater& heater, Fan& fan)
{
    float hum = hygrometer.get_humidity();  
    
    if (hum > 80) {  
        heater.on();
        pump.off();
        fan.on();      
    }
    else if (hum < 60) {  
        heater.off();
        pump.on();
        fan.off();     
    }
    else {  
        heater.off();
        pump.off();
        fan.off();    
    }
}


int main()
{    
    Thermometer thermometer(10);
    Heater heater;
    Fan fan;
    Conditioner conditioner;
    Hygrometer hygrometer(11);
    Pump pump;
    Light light(12);
    Lamp lamp;
    Clock clock;

    for (int count = 10; count > 0; --count) {

        thermometer.get_temperature();
        hygrometer.get_humidity();
        light.get_illumination();

        control_temperature(thermometer, heater, fan, conditioner);
        control_humidity(hygrometer, pump, heater, fan);
        control_illumination(light, clock, lamp);

        lamp.power();
        heater.power();
        pump.power();
        fan.power();
        conditioner.power();
    }
    
};

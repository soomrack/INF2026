// Вспомогательные функции

void update_year_index(int year)
{
    dasha.current_year_index = year - 2026;
    masha.current_year_index = year - 2026;
}

void add_income_dasha(RUB amount)
{
    dasha.bank.account_rub += amount;
    dasha.total_earned += amount;
    dasha.stats[dasha.current_year_index].income += amount;
}

void add_expense_dasha(RUB amount)
{
    dasha.bank.account_rub -= amount;
    dasha.total_spent += amount;
    dasha.stats[dasha.current_year_index].expenses += amount;
}

void add_income_masha(RUB amount)
{
    masha.bank.account_rub += amount;
    masha.total_earned += amount;
    masha.stats[masha.current_year_index].income += amount;
}

void add_expense_masha(RUB amount)
{
    masha.bank.account_rub -= amount;
    masha.total_spent += amount;
    masha.stats[masha.current_year_index].expenses += amount;
}

// Образование Даши

void dasha_education(const int month, const int year)
{
    if (!dasha.edu.isStudying) return;

    if (month != 7 && month != 8) {
        add_income_dasha(dasha.edu.scholarship);
    }

    if (dasha.dorm.isLiving) {
        add_expense_dasha(dasha.dorm.monthly_fee + dasha.dorm.internet);
    }

    if (month == 6 && year == 2026) {
        add_expense_dasha(dasha.edu.diploma_cost);
    }

    if (month == 5 && year == 2026) {

void apply_inflation(const int month, const int year)
{
    float inflation = 0.0f;

    switch (year) {
    case 2026: inflation = 0.5f; break;
    case 2027: inflation = 0.7f; break;
    case 2028: inflation = 0.9f; break;
    case 2029: inflation = 0.6f; break;
    case 2030: inflation = 0.5f; break;
    case 2031: inflation = 0.4f; break;
    }

    if (dasha.move.isInPoland) {
        inflation = 0.3f;
    }

    if (!masha.flat.hasMortgage) {
        masha.flat.rent += (RUB)(masha.flat.rent * (inflation / 100.0f));
    }
    masha.flat.utilities += (RUB)(masha.flat.utilities * (inflation / 100.0f));

    if (month == 6 || month == 12) {
        float change = 0.95f + (rand() % 10) / 100.0f;
        dasha.bank.rate_pln_rub *= change;
        dasha.bank.rate_usd_rub *= change;
        masha.bank.rate_usd_rub *= change;
    }
}


    RUB total = harchololi.child.monthly_expenses + harchololi.child.clothes / 3 + 
                harchololi.child.toys / 4 + harchololi.child.pocket_money + 
                harchololi.child.music_school + harchololi.child.sports_section;
    
    if (month == 8) total += harchololi.child.school_supplies;
    if (month == 5) total += harchololi.child.excursions;
    if (month == 6) total += harchololi.child.summer_camp;
    
    harchololi.bank.account -= total;
    harchololi.child.monthly_total = total;
    harchololi.yearly_expenses += total;
    

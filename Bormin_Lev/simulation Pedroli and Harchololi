void apply_inflation(int year, int month)
{
    if (month != 1) return;
    
    global_inflation = global_inflation + 0.3;
    if (global_inflation > 12.0) global_inflation = 12.0;
    
    INFLATION factor = 1.0 + global_inflation / 100.0;
    

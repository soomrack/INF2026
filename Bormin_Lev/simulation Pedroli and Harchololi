        pedroli_big_life_events(month, year);
        harchololi_big_life_events(month, year);
        
        pedroli_invest_and_save(month, year);
        harchololi_credit_management(month, year);
        
        calculate_taxes(pedroli, year, month);
        calculate_taxes(harchololi, year, month);
        
        if (month == 12) {
            collect_yearly_stats(pedroli, year);
            collect_yearly_stats(harchololi, year);
        }
        
        month++;
        if (month == 13) {
            month = 1;
            year++;
        }
    }
}


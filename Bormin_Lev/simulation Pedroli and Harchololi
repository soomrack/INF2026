void calculate_taxes(Person& p, int year, int month)
{
    if (month != 12) return;
    
    RUB income_tax = p.yearly_income * 13 / 100;
    p.taxes.income_tax_paid = income_tax;
    p.taxes.total_taxes = income_tax + p.taxes.property_tax + p.taxes.car_tax;
    
    p.bank.account -= p.taxes.total_taxes;
    p.yearly_expenses += p.taxes.total_taxes;
    
    static int last_year = 0;
    if (last_year != year) {
        p.taxes.property_tax = p.taxes.property_tax * p.taxes.inflation_rate;
        p.taxes.car_tax = p.taxes.car_tax * p.taxes.inflation_rate;
        last_year = year;
    }
}

void collect_yearly_stats(Person& p, int year)
{
    if (p.stats_count >= 15) return;
    
    p.yearly_stats[p.stats_count].year = year;
    p.yearly_stats[p.stats_count].total_income = p.yearly_income;
    p.yearly_stats[p.stats_count].total_expenses = p.yearly_expenses;
    p.yearly_stats[p.stats_count].taxes_paid = p.taxes.total_taxes;
    p.yearly_stats[p.stats_count].savings = p.yearly_income - p.yearly_expenses;
    p.stats_count++;
    
    p.yearly_income = 0;
    p.yearly_expenses = 0;
    p.taxes.total_taxes = 0;
    p.taxes.income_tax_paid = 0;
}


}

void pedroli_invest_and_save(int month, int year)
{
    if (pedroli.bank.account > 200000) {
        RUB to_deposit = pedroli.bank.account * 0.6;
        pedroli.bank.deposite += to_deposit;
        pedroli.bank.account -= to_deposit;
    }
    
    if (year == 2026) pedroli.bank.interest = 14.5;
    else if (year == 2027) pedroli.bank.interest = 13.5;
    else if (year == 2028) pedroli.bank.interest = 12.5;
    else if (year == 2029) pedroli.bank.interest = 11.5;
    else if (year >= 2030) pedroli.bank.interest = 10.5;
    
    pedroli.bank.deposite += pedroli.bank.deposite * (pedroli.bank.interest / 12.0 / 100.0);
}

void harchololi_credit_management(int month, int year)
{
    if (harchololi.bank.account > 100000 && harchololi.credit.consumer_credit > 0) {
        RUB extra = harchololi.bank.account - 50000;
        if (extra > 0) {
            harchololi.bank.account -= extra;
            harchololi.credit.consumer_credit -= extra;
            if (harchololi.credit.consumer_credit < 0) harchololi.credit.consumer_credit = 0;
        }
    }
    
    if (harchololi.bank.account > 50000) {
        RUB to_save = harchololi.bank.account * 0.15;
        harchololi.bank.deposite += to_save;
        harchololi.bank.account -= to_save;
    }
    
    if (year == 2026) harchololi.bank.interest = 14.5;
    else if (year == 2027) harchololi.bank.interest = 13.5;
    else if (year >= 2028) harchololi.bank.interest = 12.5;
    
    harchololi.bank.deposite += harchololi.bank.deposite * (harchololi.bank.interest / 12.0 / 100.0);
}


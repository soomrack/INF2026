void pedroli_salary(int month, int year)
{
    if (month == 1 && year > pedroli.start_year) {
        pedroli.salary.base = pedroli.salary.base * (100 + pedroli.salary.indexation) / 100;
    }
    
    if (year == pedroli.salary.promotion_year && month == 1) {
        pedroli.salary.base = pedroli.salary.base * pedroli.salary.promotion_multiplier;
    }
    
    if (month == 12) {
        pedroli.salary.bonus = pedroli.salary.base;
        pedroli.bank.account += pedroli.salary.bonus;
        pedroli.yearly_income += pedroli.salary.bonus;
    }
    
    pedroli.bank.account += pedroli.salary.base;
    pedroli.yearly_income += pedroli.salary.base;
}


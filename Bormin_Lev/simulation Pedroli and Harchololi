void calculate_total_capital(Person& p)
{
    RUB capital = p.bank.account + p.bank.deposite + p.car.value + p.emergency_fund +
                  p.wedding_fund + p.investment_portfolio - p.credit.consumer_credit - p.credit.mortgage;
    
    p.total_capital = capital;
}


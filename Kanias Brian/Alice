{
	float stocks_return = 1.0 + (victoria.portfolio.stocks_growth_rate / 12);
	victoria.portfolio.stocks = victoria.portfolio.stocks * stocks_return;

	float crypto_change = 1.0 + ((rand() % 200 - 100) / 100.0 * victoria.portfolio.crypto_volatility / 12);
	victoria.portfolio.crypto = victoria.portfolio.crypto * crypto_change;

	float bonds_return = 1.0 + (0.06 / 12);
	victoria.portfolio.bonds = victoria.portfolio.bonds * bonds_return;

	float gold_return = 1.0 + (victoria.portfolio.gold_growth_rate / 12);
	victoria.portfolio.gold = victoria.portfolio.gold * gold_return;

	float etf_return = 1.0 + (victoria.portfolio.etf_growth_rate / 12);
	victoria.portfolio.etf = victoria.portfolio.etf * etf_return;

	if (year == 2029 and month == 1 and victoria.portfolio.startup > 0) {
		RUB exit_income = victoria.portfolio.startup * 3;
		victoria.vtb.account_rub += exit_income;
		victoria.portfolio.startup = 0;
	}

	if (victoria.vtb.account_rub > 100'000) {
		RUB investment_amount = victoria.vtb.account_rub * 0.1;
		if (investment_amount > 50'000) investment_amount = 50'000;

		victoria.vtb.account_rub -= investment_amount;

		victoria.portfolio.stocks += investment_amount * 0.4;
		victoria.portfolio.bonds += investment_amount * 0.2;
		victoria.portfolio.etf += investment_amount * 0.2;
		victoria.portfolio.gold += investment_amount * 0.15;
		victoria.portfolio.crypto += investment_amount * 0.05;
	}
}


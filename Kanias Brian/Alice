		victoria_entertainment_expenses(month, year);
		victoria_charity_donations();
		victoria_vacation_expenses(month, year);
		victoria_family_expenses(month);
		victoria_monthly_others(month);

		victoria_alcohol_addiction();

		victoria_bank_operations(month, year);
		victoria_tax_optimization(month, year);
		victoria_lottery();

		maxim_salary(month, year);
		maxim_career_change(month, year);
		maxim_investments(month, year);
		maxim_food(month, year);
		maxim_car(month);
		maxim_business_income();
		maxim_different_choices(month, year);
		maxim_monthly_others(month);
		maxim_bank_operations(month, year);
		maxim_lottery();

		++month;
		if (month == 13) {
			++year;
			month = 1;
		}
	}
}


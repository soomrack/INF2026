// кризис влияет сразу на доходы и базовые расходы
void victoria_economic_crisis(const int month, const int year)
{
	if (year == 2033 and month == 10) {
		victoria.economic_crisis_impact = 1;
		victoria.salary = victoria.salary * 0.85;
		victoria.food = victoria.food * 1.2;
		victoria.car.gas = victoria.car.gas * 1.3;
		victoria.home.utilities = victoria.home.utilities * 1.25;
	}

	if (victoria.economic_crisis_impact == 1 and year >= 2035 and month == 10) {
		victoria.economic_crisis_impact = 0;
		victoria.salary = victoria.salary * 1.18;
	}
}

// здесь собраны решения Максима, которые отличаются от Виктории
void maxim_different_choices(const int month, const int year)
{
	if (maxim.home.apartment_value == 0 and !maxim.family.is_married) {
		RUB rent_cost = 25'000;
		maxim.vtb.account_rub -= rent_cost;

		if (month == 12) { // годовая премия или траты
			RUB rent_deposit = 25'000;
			maxim.vtb.account_rub -= rent_deposit;
		}
	}

	if (!maxim.mining.has_mining_rig and year == 2029 and month == 4) {
		maxim.mining.has_mining_rig = 1;
		maxim.mining.rig_cost = 250'000;
		maxim.mining.monthly_electricity = 8'000;
		maxim.mining.monthly_reward = 15'000;
		maxim.vtb.account_rub -= maxim.mining.rig_cost;
	}

	if (maxim.mining.has_mining_rig) {
		maxim.vtb.account_rub -= maxim.mining.monthly_electricity;
		maxim.vtb.account_rub += maxim.mining.monthly_reward;
		maxim.mining.mining_active_years++;

		if (maxim.mining.mining_active_years >= 36) {
			maxim.mining.monthly_reward = maxim.mining.monthly_reward * 0.7;
		}

		if (rand() % 100 < 5) {
			RUB mining_breakdown = 30'000;
			maxim.vtb.account_rub -= mining_breakdown;
		}
	}

	if (!maxim.family.is_married and year == 2034 and month == 9) {
		maxim.salary = maxim.salary * 2.5;
		maxim.vtb.rate_usd_rub = 95.00;
		maxim.vtb.account_usd += 5'000;
		maxim.food = maxim.food * 1.5;
		maxim.home.utilities = 30'000;
		maxim.car.gas = maxim.car.gas * 1.2;
	}
}

// второй ребенок появляется не сразу, а через отдельное событие
void victoria_second_pregnancy(const int month, const int year)
{
	if (victoria.family.has_child and !victoria.health.is_pregnant and !victoria.family.has_second_child) {
		if (year == 2035 and month == 2) {
			int pregnancy_chance = rand() % 100;
			if (pregnancy_chance < 40) {
				victoria.health.is_pregnant = 1;
				victoria.health.pregnancy_month = month;
				victoria.health.pregnancy_year = year;
			}
		}
	}

	if (victoria.health.is_pregnant and victoria.family.has_child) {
		int months_pregnant = 0;
		if (year > victoria.health.pregnancy_year) {
			months_pregnant = (12 - victoria.health.pregnancy_month) + month;
		}
		else {

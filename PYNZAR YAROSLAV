void simulation()
{
    int month = 2;
    int year = 2026;

    while (!((month == 3) && (year == 2030)) ) {
        ira_cat(month, year);
        ira_trip(month, year);
        ira_food(month, year);
        ira_car(month, year);
        ira_bank_interest(month, year);
        ira_salary(month, year);
        ira_freelance(month, year);
      
       
       yarik_bank_mortage_payment(month, year);
       yarik_food(month, year);
       yarik_moto(month, year);
       yarik_chips(month, year);
       yarik_salary(month, year);
       yarik_freelance(month, year);
     
        
        ++month;
        if (month == 13) {
            month = 1;
            ++year;
        }
    }
}



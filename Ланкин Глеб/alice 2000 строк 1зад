void check_alice_unemployment(const int month, const int year) {
    if (economy_state.unemployment > 8 && alice.salary > 0) {
        int chance = static_cast<int>((economy_state.unemployment - 8) * 2);

        if (rand() % 100 < chance) {
            alice.salary = 0;
            alice.stress += 40;
            alice.happiness -= 20;
            printf("Alice lost job due to high unemployment! (%d/%d)\n", month, year);
        }
    }

    if (economy_state.unemployment < 5 && alice.salary == 0) {
        if (rand() % 100 < 15) {
            alice.salary = 180000;
            alice.stress -= 20;
            alice.happiness += 15;
            printf("Alice found a new job! (%d/%d)\n", month, year);
        }
    }
}



        int chance = static_cast<int>((economy_state.unemployment - 8) * 2);

        if (rand() % 100 < chance) {
            bob.salary = 0;
            bob.stress += 40;
            bob.happiness -= 20;
            printf("Bob lost job due to high unemployment! (%d/%d)\n", month, year);
        }
    }

    if (economy_state.unemployment < 5 && bob.salary == 0) {
        if (rand() % 100 < 15) {
            bob.salary = 150000;
            bob.stress -= 20;
            bob.happiness += 15;
            printf("Bob found a new job! (%d/%d)\n", month, year);
        }
    }
}


void alice_tax()
{
    if (alice.salary <= 0) return;

    Percent tax_rate = 13.0;
    RUB tax = alice.salary * tax_rate / 100;

    alice.vtb.rub_balance -= tax;
}


Percent get_inflation(const int year)
{
    switch (year) {
    case 2026: return 12.5;
    case 2027: return 14.0;
    case 2028: return 13.0;
    case 2029: return 11.5;
    }
    return 12.0;
}


void alice_credit(const int month, const int year) {
    if (alice.credit.remaining_debt_rub <= 0) return;

    alice.credit.remaining_debt_rub += alice.credit.remaining_debt_rub * alice.credit.annual_interest_rate / 100 / 12;

    if (alice.vtb.rub_balance >= alice.credit.monthly_payment_rub) {
        alice.vtb.rub_balance -= alice.credit.monthly_payment_rub;
        alice.credit.remaining_debt_rub -= alice.credit.monthly_payment_rub;
    }
    else {
        RUB paid = alice.vtb.rub_balance;
        alice.vtb.rub_balance = 0;
        alice.credit.remaining_debt_rub -= paid;
    }

    if (alice.credit.remaining_debt_rub <= 0) {
        alice.credit.initial_debt_rub = 0;
        alice.credit.remaining_debt_rub = 0;
        printf("Alice paid off credit!\n");
    }
}


void alice_deposit(const int month, const int year) {
    if (month % 2 != 0) return;
    if (alice.vtb.rub_balance < alice.vtb.monthly_deposit_contribution_rub) return;

    alice.vtb.rub_balance -= alice.vtb.monthly_deposit_contribution_rub;
    alice.vtb.deposit_balance_rub += alice.vtb.monthly_deposit_contribution_rub;
    alice.vtb.deposit_balance_rub += alice.vtb.deposit_balance_rub * (alice.vtb.deposit_interest_percent / 100) / 12;
}



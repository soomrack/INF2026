void process_alice_hobby(Hobby& hobby, int month) {
    if (!hobby.is_active) return;

    if (alice.vtb.rub_balance < hobby.monthly_cost) {
        printf("Alice cannot afford %s\n", hobby.name);
        return;
    }

    alice.vtb.rub_balance -= hobby.monthly_cost;
    hobby.months_practiced++;

    alice.happiness += hobby.happiness_bonus;
    alice.stress -= hobby.stress_reduction;
    alice.health += hobby.health_bonus;

    if (alice.happiness > 100) alice.happiness = 100;
    if (alice.happiness < 0) alice.happiness = 0;
    if (alice.stress > 100) alice.stress = 100;
    if (alice.stress < 0) alice.stress = 0;
    if (alice.health > 100) alice.health = 100;
    if (alice.health < 0) alice.health = 0;

    if (hobby.type == HOBBY_READING) alice.creativity += 1;
    if (hobby.type == HOBBY_SPORTS) alice.discipline += 1;
    if (hobby.type == HOBBY_MUSIC) alice.creativity += 2;

    if (hobby.months_practiced % 12 == 0) {
        printf("Alice improved skill in %s!\n", hobby.name);
    }
}



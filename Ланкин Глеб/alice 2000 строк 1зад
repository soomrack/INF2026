}


void alice_take_mortgage(const int month, const int year)
{
    if (alice.house.is_owned) return;
    if (alice.mortgage.is_active) return;
    if (alice.mortgage.monthly_payment_rub > alice.salary / 2) return;

    RUB first_payment = alice.house.purchase_price_rub / 5;
    RUB safety = 200000; // запас денег

    if (alice.vtb.rub_balance >= first_payment + safety) {

        alice.vtb.rub_balance -= first_payment;

        alice.mortgage.remaining_debt_rub = alice.house.purchase_price_rub - first_payment;
        alice.mortgage.monthly_payment_rub = alice.mortgage.remaining_debt_rub / 240; // 20 лет
        alice.mortgage.annual_interest_rate = 9.5;
        alice.mortgage.is_active = true;
        alice.house.is_owned = true;
        alice.mortgage.monthly_payment_rub *= (1 + economy_state.key_rate / 200);

        printf("Alice took mortgage in %d/%d\n", month, year);
    }
}


void alice_mortgage_payment(const int month, const int year)
{
    if (!alice.mortgage.is_active) return;

    alice.mortgage.remaining_debt_rub += alice.mortgage.remaining_debt_rub * (alice.mortgage.annual_interest_rate / 100) / 12;

    alice.vtb.rub_balance -= alice.mortgage.monthly_payment_rub;
    alice.mortgage.remaining_debt_rub -= alice.mortgage.monthly_payment_rub;

    if (alice.mortgage.remaining_debt_rub <= 0) {
        alice.mortgage.is_active = false;
        printf("Mortgage fully paid in %d/%d\n", month, year);
    }
}



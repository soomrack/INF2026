void inflation_update(const int month, const int year)
{
    if (month == 1) {
        if (year % 2 == 0) {
            economy_state.inflation += 1.0;
        }
        else {
            economy_state.inflation -= 0.5;
        }

        if (economy_state.inflation < 2.0) economy_state.inflation = 2.0;
        if (economy_state.inflation > 15.0) economy_state.inflation = 15.0;
    }
}


void economy_system(const int month, const int year)
{
    if (month == 1) {

        if (year % 3 == 0) {
            economy_state.crisis = true;

            economy_state.inflation += 4;
            economy_state.market_growth -= 5;
            economy_state.key_rate += 3;
            economy_state.unemployment += 2;
        }
        else {
            economy_state.crisis = false;

            economy_state.inflation -= 1;
            economy_state.market_growth += 2;
            economy_state.key_rate -= 1;
            economy_state.unemployment -= 0.5;
        }
    }
    if (economy_state.inflation < 1) economy_state.inflation = 1;
    if (economy_state.market_growth < -10) economy_state.market_growth = -10;
    if (economy_state.key_rate < 5) economy_state.key_rate = 5;
    if (economy_state.unemployment < 2) economy_state.unemployment = 2;

    alice.salary *= (1 + economy_state.inflation / 100 / 12);
    bob.salary *= (1 + economy_state.inflation / 100 / 12);

    RUB spend = 40000 * (1 + economy_state.inflation / 100);
    alice.vtb.rub_balance -= spend;

    if (economy_state.crisis) {
        alice.vtb.rub_balance -= 20000;
    }
}


void apply_alice_crisis_effects(const int month, const int year) {
    if (!economy_state.crisis) return;

    if (month == 1) {
        alice.invest_account = static_cast<RUB>(alice.invest_account * 0.85);
        printf("Alice lost 15%% of investments due to crisis!\n");

        if (rand() % 100 < 15 && alice.salary > 0) {
            alice.salary = 0;
            alice.stress += 30;
            if (alice.stress > 100) alice.stress = 100;
            printf("Alice lost job due to economic crisis!\n");
        }
    }
}



void Boba_metro(double multiplier)
{
	if (Boba.has_car) return;

	Boba.metro.price = (RUB)(Boba.metro.price * multiplier);
	Boba.vtb.account -= Boba.metro.price;
}


void Boba_car(const int month, const int year, double multiplier)
{
	// покупка машины
	if (!Boba.has_car and Boba.vtb.deposit >= 3'000'000)
	{
		Boba.vtb.deposit -= Boba.car.value;
		Boba.has_car = true;
		printf("==========================\n");
		printf("   Боба купил машину!\n");
		printf("остаток на депозите: %lld\n", Boba.vtb.deposit);
		printf("==========================\n\n");
	}

	// Если есть машина
	if (!Boba.has_car) return;

	Boba.car.gaz = (RUB)(Boba.car.gaz * multiplier);
	Boba.car.service = (RUB)(Boba.car.service * multiplier);
	Boba.car.tires = (RUB)(Boba.car.tires * multiplier);
	Boba.car.oil = (RUB)(Boba.car.oil * multiplier);

	Boba.vtb.account -= Boba.car.gaz;

	if (month == 3 or month == 9) {
		Boba.vtb.account -= Boba.car.oil;
		Boba.vtb.account -= Boba.car.service; // сервис и замена масла 2 раза в год
	}

	if (year % 4 == 0 and month == 10) {
		Boba.vtb.account -= Boba.car.tires; // покупка новых шин
	}
}


void Biba_house(int month, int year, double multiplier) // покупка дома
{
	Biba.rent = (RUB)(Biba.rent * multiplier);
	Biba.vtb.account -= Biba.rent;
	
	if (!Biba.house.has_house and Biba.vtb.deposit >= 5'000'000) {
		// покупка дома
		Biba.house.price = 15'000'000;
		Biba.house.first_payment = 2'000'000;

		Biba.vtb.deposit -= Biba.house.first_payment;

		Biba.house.has_house = true;
		Biba.house.has_mortgage = true;

		printf("==========================\n");
		printf("   Биба купил дом!\n");
		printf("остаток на депозите: %lld\n", Biba.vtb.deposit);
		printf("==========================\n\n");

		Biba.house.debt = (Biba.house.price - Biba.house.first_payment) * (1 + Biba.house.mortgage / 100);

		Biba.rent = 6'000; // расход на ренту превращается в коммунальные платежи за дом

		Biba.house.mortgage = 14;

		Biba.house.payment = (RUB)(Biba.house.debt / 30 / 12.0);
	}
}


void Boba_house(double multiplier)
{
	Boba.rent = (RUB)(Boba.rent * multiplier);
	Boba.vtb.account -= Boba.rent;
}


void Biba_mortgage()
{
	if (!Biba.house.has_mortgage) return;
	
		if (Biba.vtb.deposit >= Biba.house.payment)
		{
			Biba.vtb.deposit -= Biba.house.payment;
			Biba.house.debt -= Biba.house.payment;

			if (Biba.house.debt < 0) Biba.house.debt = 0;

			if (Biba.house.debt <= 0)
			{
				Biba.house.has_mortgage = false;
				printf("Ипотека выплачена!\n\n");
			}
		}

		else
		{
			//здесь можно добавить штраф за просрочку
		}
	
}


void Biba_random_ivents()
{
	int random_balance = 0;
	RUB events_net = 0;

	int roll = rand() % 100;
	if (roll < 15) {
		Biba.vtb.account += 20'000; // премия
		random_balance++;
		events_net += 20'000;
	}

	roll = rand() % 100;
	if (roll < 15 and Biba.has_car) {
		Biba.vtb.account -= 5'000;    // штраф
		random_balance--;
		events_net -= 5'000;
	}
}


void Biba_deposite(const int month, const int year)
{
	if (year < 2035) Boba.vtb.interest = 8;
	else if (year < 2040) Boba.vtb.interest = 7.5;
	else if (year < 2045) Boba.vtb.interest = 8;
	else if (year < 2050) Boba.vtb.interest = 7.8;

	Biba.vtb.deposit += Biba.vtb.deposit * (Biba.vtb.interest / 12 / 100.0);

	Biba.vtb.deposit += Biba.vtb.account;
	Biba.vtb.account = 0;
}


void Boba_deposite(const int month, const int year)
{
	if (year < 2035) Boba.vtb.interest = 8;
	else if (year < 2040) Boba.vtb.interest = 7.8;
	else if (year < 2045) Boba.vtb.interest = 8.1;
	else if (year < 2050) Boba.vtb.interest = 7.6;

	Boba.vtb.deposit += Boba.vtb.deposit * (Boba.vtb.interest / 12 / 100.0);

	Boba.vtb.deposit += Boba.vtb.account;
	Boba.vtb.account = 0;
}


void print_annual_result(const int year, const int month)
{
	if (!(month == 12)) return;

	printf("Год: %d\n\n", year);

	printf("Депозит Бибы: %lld\n", Biba.vtb.deposit);
	printf("Зарплата Бибы: %lld\n", Biba.salary);
	RUB wastes = Biba.food + Biba.internet + Biba.cat + Biba.dog + Biba.rent;
	printf("Расходы Бибы: %lld\n", wastes);
	printf("Биба заплатил налогов за год: %lld\n\n", Biba.tax.annual_total);
	if (Biba.house.has_mortgage)
	{
		printf("Остаток долга: %lld\n\n", Biba.house.debt);
	}
	
	printf("Депозит Бобы: %lld\n", Boba.vtb.deposit);
	printf("Зарплата Бобы: %lld\n", Boba.salary);
	wastes = Boba.food + Boba.internet + Boba.cat + Boba.dog + Boba.rent;
	printf("Расходы Бобы: %lld\n", wastes);
	printf("Боба заплатил налогов за год: %lld\n\n", Boba.tax.annual_total);
}


void print_result()
{
	printf("=== РЕЗУЛЬТАТ ===\n\n");
	printf("Зарплата Бибы на 2050: %lld\n", Biba.salary);

	RUB capital = 0;
	capital += Biba.vtb.account;
	capital += Biba.vtb.deposit;
	capital += Biba.car.value;
	capital += (Biba.house.price - Biba.house.debt);
	printf("Капитал Бибы на 2050: %lld\n\n", capital);

	printf("Зарплата Бобы на 2050: %lld\n", Boba.salary);

	capital = 0;
	capital += Boba.vtb.account;
	capital += Boba.vtb.deposit;
	if (Boba.has_car) 
	{
		capital += Boba.car.value;
	}
	printf("Капитал Бобы на 2050: %lld\n", capital);

	printf("\nДанные сохранены в simulation.csv\n");
}


void simulation(int month, int year) 
{
	double multiplier = apply_inflation(year, month);

	Biba_salary(month, year);

	Biba_food(multiplier);
	Biba_internet(multiplier);
	Biba_pets(multiplier);
	Biba_car(month, year, multiplier);
	Biba_taxes(month, year);
	Biba_house(month, year, multiplier);
	Biba_mortgage();

	Biba_deposite(month, year);

	Boba_salary(month, year);

	Boba_food(multiplier);
	Biba_internet(multiplier);
	Boba_pets(multiplier);
	Boba_metro(multiplier);
	Boba_car(month, year, multiplier);
	Boba_taxes(month, year);
	Boba_house(multiplier);

	Boba_deposite(month, year);
}


int main()
{
	SetConsoleCP(1251);
	SetConsoleOutputCP(1251);
	setlocale(LC_ALL, "Russian");

	printf("=== НАЧАЛО СИМУЛЯЦИИ ===\n\n");
	int month = 3;
	int year = 2030;

	Biba_init();
	Boba_init();

	while (not (month == 3 and year == 2050))
	{
		simulation(month, year);

		month++;
		if (month == 13)
		{
			year++;
			month = 1;
		}

		print_annual_result(year, month);
	}

	print_result();

	return 0;
}
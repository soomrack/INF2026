double apply_inflation(int year, int month)
{
	if (month == 1 and year > 2030)
	{
		double inflation_rate = inflation(gen);
		double multiplier = 1.0 + inflation_rate / 100.0;

		printf("Инфляция в %d году: +%.2f%%\n\n", year, inflation_rate);

		return multiplier;
	}
	return 1.0;
}


void Biba_salary(const int month, const int year)
{
	if (month == 12)
	{
		Biba.vtb.account += Biba.salary; // 13-я зарплата
	}
	Biba.vtb.account += Biba.salary;

	if (month == 1 and year > 2030) {
		double salary_index = inflation(gen) * 0.8;
		Biba.salary = (RUB)(Biba.salary * (1 + salary_index / 100));
	}

	Biba.tax.income_tax = (RUB)(Biba.salary * Biba.tax.key_rate);
	Biba.vtb.account -= Biba.tax.income_tax;
}


void Boba_salary(const int month, const int year)
{
	if (month == 12) {
		Boba.vtb.account += Boba.salary; // 13-я зарплата
	}

	Boba.vtb.account += Boba.salary;

	if (month == 1 and year > 2030) {
		double salary_index = inflation(gen) * 0.8;
		Boba.salary = (RUB)(Boba.salary * (1 + salary_index / 100));
	}

	Boba.tax.income_tax = (RUB)(Boba.salary * Boba.tax.key_rate);
	Boba.vtb.account -= Boba.tax.income_tax;
}


void Biba_food(double multiplier)
{
	Biba.food = (RUB)(Biba.food * multiplier);
	
	Biba.vtb.account -= (RUB)(Biba.food * food(gen) / 100);

	Biba.tax.food_VAT = (RUB)(Biba.food * Biba.tax.VAT_rate);
	Biba.vtb.account -= Biba.tax.food_VAT;
}


void Biba_internet(double multiplier)
{
	Biba.internet = (RUB)(Biba.internet * multiplier);

	Biba.vtb.account -= Biba.internet;

	Biba.tax.internet_VAT = (RUB)(Biba.internet * Biba.tax.VAT_rate);
	Biba.vtb.account -= Biba.tax.internet_VAT;
}


void Biba_pets(const int month, double multiplier)
{
	Biba.cat = (RUB)(Biba.cat * multiplier);
	Biba.dog = (RUB)(Biba.dog * multiplier);

	Biba.vtb.account -= Biba.cat;
	Biba.vtb.account -= Biba.dog;

	if (month == 6 and (Biba.has_cat or Biba.has_dog)) 
		Biba.vtb.account -= 5'000; // плановый осмотр у ветеринара

	Biba.tax.pets_VAT = (RUB)((Biba.cat + Biba.dog) * Biba.tax.VAT_rate);
	Biba.vtb.account -= Biba.tax.pets_VAT;
}


void Biba_metro(double multiplier)
{
	if (Biba.has_car and Biba.random.recovery == 0) return;

	Biba.metro.price = (RUB)(Biba.metro.price * multiplier);
	Biba.vtb.account -= Biba.metro.price;
}


void Biba_car(const int month, const int year, double multiplier)
{
	Biba.car.gaz = (RUB)(Biba.car.gaz * multiplier);
	Biba.car.service = (RUB)(Biba.car.service * multiplier);
	Biba.car.tires = (RUB)(Biba.car.tires * multiplier);
	Biba.car.oil = (RUB)(Biba.car.oil * multiplier);

	if (Biba.random.recovery == 0) Biba.vtb.account -= Biba.car.gaz;

	if (month == 3 or month == 9) {
		Biba.vtb.account -= Biba.car.oil;
		Biba.vtb.account -= Biba.car.service;

		Biba.tax.car_VAT += Biba.car.service + Biba.car.oil;
	}

	if (year % 4 == 0 and month == 10) {
		Biba.vtb.account -= Biba.car.tires;

		Biba.tax.car_VAT += Biba.car.tires;
	}

	if (Biba.has_car and month == 12) {
		Biba.tax.car_tax = (RUB)(Biba.car.value * 0.01);
		Biba.vtb.deposit -= Biba.tax.car_tax;
	}

	if (Biba.has_car) {
		Biba.tax.car_VAT = Biba.car.gaz;
		Biba.tax.car_VAT = (RUB)(Biba.tax.car_VAT * Biba.tax.VAT_rate);
		Biba.vtb.account -= Biba.tax.car_VAT;
	}
}



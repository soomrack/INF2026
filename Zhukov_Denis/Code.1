void Biba_random_medicine(const int month)
{
	RUB dentistry = 0; // лечение зубов
	int roll = rand() % 1000;
	if (roll < 5) {
		dentistry = 50'000;
		Biba.random.balance--;
		printf("У Бибы глубокий кариес, цена лечения: %lld\n\n", dentistry);
	}
	else if (roll < 10) {
		dentistry = 20'000;
		Biba.random.balance--;
		printf("У Бибы кариес, цена лечения: %lld\n\n", dentistry);
	}
	else if (roll < 20) {
		dentistry = 10'000;
		Biba.random.balance--;
	}
	else if (roll < 35) {
		dentistry = 5'000;
		Biba.random.balance--;
	}
	Biba.random.events_net -= dentistry;
	Biba.vtb.deposit -= dentistry;

	 // травмы
	roll = rand() % 1000;
	if (roll < 5) {
		Biba.random.recovery = 3;
		Biba.random.treatment = 5'000;
		Biba.random.balance--;
		printf("Биба сломал ногу!\n\n");
	}
	else if (roll < 10) {
		Biba.random.recovery = 1;
		Biba.random.treatment = 5'000;
		Biba.random.balance--;
		printf("Биба повредил колено!\n\n");
	}
	else if (roll < 30) {
		Biba.vtb.account -= 2'000;
		Biba.random.events_net -= 2'000;
		Biba.random.balance--;
	}

	if (Biba.random.recovery > 0) {
		Biba.vtb.account -= Biba.random.treatment;
		Biba.random.events_net -= Biba.random.treatment;
		Biba.random.recovery--;
	}

	// болезни
	if (month > 8 and month < 12) {
		roll = rand() % 100;
		if (roll < 1) {
			Biba.random.treatment = 10'000;
			Biba.random.balance--;
			printf("Биба заболел пневмонией!\n\n");
		}
		else if (roll < 5) {
			Biba.random.treatment = 5'000;
			Biba.random.balance--;
			printf("Биба заболел гриппом!\n\n");
		}
		else if (roll < 15) {
			Biba.random.treatment = 3'000;
			Biba.random.balance--;
			printf("Биба простудился!\n\n");
		}
		else if (roll < 20) {
			Biba.random.treatment = 3'000;
			Biba.random.balance--;
			printf("Биба купил витамины и лекарства.\n\n");
		}
	}
}


void Biba_random_pets() {
	int roll = rand() % 100;
	if (!Biba.has_dog and !Biba.has_cat and roll < 7) {
		if (rand() % 2 == 0) {
			Biba.has_dog = true;
			printf("Биба завёл собаку!\n\n");
			Biba.random.balance++;
		}
		else {
			Biba.has_cat = true;
			printf("Биба завёл кота!\n\n");
			Biba.random.balance++;
		}
	}

	if (!Biba.has_cat and !Biba.has_dog) return;

	roll = rand() % 100;
	if (roll < 5 and Biba.has_cat) {
		printf("Кот Бибы заболел! ");
		Biba.random.balance--;
		roll = rand() % 100;
		if (roll < 5) {
			Biba.has_cat = false;
			printf("Кот Бибы умер!\n\n");
		}
		else if (roll < 25) {
			Biba.vtb.account -= 10'000;
			printf("Цена лечения: %d\n\n", 10'000);
			Biba.random.events_net -= 10'000;
		}
		else if (roll < 70) {
			Biba.vtb.account -= 5'000;
			printf("Цена лечения: %d\n\n", 5'000);
			Biba.random.events_net -= 5'000;
		}
		else printf("Кот поправился сам.\n\n");
	}

	roll = rand() % 100;
	if (roll < 3 and Biba.has_dog) {
		printf("Пёс Бибы заболел! ");
		Biba.random.balance--;
		roll = rand() % 100;
		if (roll < 5) {
			Biba.has_dog = false;
			printf("Пёс Бибы умер!\n\n");
		}
		else if (roll < 25) {
			Biba.vtb.account -= 12'000;
			printf("Цена лечения: %d\n\n", 12'000);
			Biba.random.events_net -= 12'000;
		}
		else if (roll < 70) {
			Biba.vtb.account -= 5'000;
			printf("Цена лечения: %d\n\n", 5'000);
			Biba.random.events_net -= 5'000;
		}
		else printf("Пёс поправился сам.\n\n");
	}
}


void Biba_random_startup()
{
	int roll = rand() % 100;

	if (roll < 3 and Biba.vtb.deposit > 100'000) {
		printf("Друг предложил Бибе инвестировать в стартап! ");
		roll = rand() % 100;

		RUB invest = (RUB)(Biba.vtb.deposit * 0.1);

		if (roll < 20) {
			RUB profit = invest * 3;
			Biba.vtb.deposit += profit;
			printf("Стартап выстрелил! +%lld руб\n", profit);
		}
		else if (roll < 50) {
			RUB profit = (RUB)(invest * 1.2);
			Biba.vtb.deposit += profit;
			printf("Небольшая прибыль: +%lld руб\n", profit - invest);
		}
		else if (roll < 80) {
			Biba.vtb.deposit -= invest;
			printf("Стартап прогорел: -%lld руб\n", invest);
		}
		else {
			printf("Передумал инвестировать\n");
		}
	}
}


void Biba_random_courses(const int year)
{
	int roll = rand() % 100;

	if (roll < 2 && year % 3 == 0) {
		printf("Биба пошёл на курсы!");
		Biba.vtb.account -= 30'000;

		roll = rand() % 100;
		if (roll < 40) {
			Biba.salary = (RUB)(Biba.salary * 1.15);
			printf("Зарплата выросла на 15%%!\n");
		}
		else if (roll < 70) {
			Biba.business.experience += 10;
			printf("Опыт бизнеса +10\n");
		}
		else {
			printf("Зря потратил время и деньги\n");
		}
	}
}


void Biba_random_ivents(const int month, const int year)
{
	Biba_random_prize(month);
	Biba_random_medicine(month);
	Biba_random_pets();
	Biba_random_startup();
	Biba_random_courses(year);
	if (Biba.random.recovery > 0) return;
	Biba_random_fines();
}



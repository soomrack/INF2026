void Boba_lottery()
{
	if (Boba.vtb.account < 1'000) return;

	Boba.vtb.account -= 500;
	printf("Боба купил лотерейный билет.\n");

	int roll = rand() % 10000;
	RUB win = 0;

	if (roll < 5) {
		win = 5'000'000;
		printf("ДЖЕКПОТ! %lld руб!\n", win);
		Boba.random.balance += 10;
	}
	else if (roll < 20) {
		win = 1'000'000;
		printf("СУПЕРПРИЗ! %lld руб!\n", win);
		Boba.random.balance += 5;
	}
	else if (roll < 50) {
		win = 100'000;
		printf("Крупный выигрыш: %lld руб!\n", win);
		Boba.random.balance += 3;
	}
	else if (roll < 200) {
		win = 20'000;
		printf("Выигрыш: %lld руб\n", win);
		Boba.random.balance++;
	}
	else if (roll < 500) {
		win = 5'000;
		printf("Выигрыш: %lld руб\n", win);
		Boba.random.balance++;
	}
	else if (roll < 1500) {
		win = 1'000;
		printf("Утешительный приз: %lld руб\n", win);
	}
	else if (roll < 3000) {
		win = 500;
		Boba.vtb.account += win;
		printf("Билет невыигрышный, но деньги вернули\n");
		return;
	}
	else {
		printf("Билет проигрышный\n\n");
		Boba.random.balance--;
		Boba.random.events_net -= 500;
		return;
	}

	// Выплата выигрыша
	Boba.vtb.account += win;
	Boba.random.events_net += (win - 500);

	// Налог на выигрыш (13%)
	if (win > 15'000) {
		RUB tax = (RUB)(win * 0.13);
		Boba.vtb.account -= tax;
		Boba.random.events_net -= tax;
		printf("Налог на выигрыш: -%lld руб\n", tax);
	}

	printf("Баланс после лотереи: %lld руб\n\n", Boba.vtb.account);
}



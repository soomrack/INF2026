}


void Biba_deposite(const int month, const int year)
{
	if (year < 2035) Boba.vtb.interest = 9;
	else if (year < 2040) Boba.vtb.interest = 8.5;
	else if (year < 2045) Boba.vtb.interest = 9;
	else if (year < 2050) Boba.vtb.interest = 8.8;

	Biba.vtb.deposit += Biba.vtb.deposit * (Biba.vtb.interest / 12 / 100.0);

	Biba.vtb.deposit += Biba.vtb.account;
	Biba.vtb.account = 0;

	if (Biba.vtb.deposit < 0) Biba.vtb.deposit = 0;

	if (Biba.vtb.deposit > 1'000'000) {
		Biba.tax.deposit_tax = (RUB)(Biba.vtb.deposit * Biba.vtb.interest / 100.0 * Biba.tax.key_rate);
		Biba.vtb.deposit -= Biba.tax.deposit_tax;
	}
}


void Boba_deposite(const int month, const int year)
{
	if (year < 2035) Boba.vtb.interest = 9;
	else if (year < 2040) Boba.vtb.interest = 8.8;
	else if (year < 2045) Boba.vtb.interest = 9.1;
	else if (year < 2050) Boba.vtb.interest = 8.6;

	Boba.vtb.deposit += Boba.vtb.deposit * (Boba.vtb.interest / 12 / 100.0);

	Boba.vtb.deposit += Boba.vtb.account;
	Boba.vtb.account = 0;

	if (Boba.vtb.deposit < 0) Boba.vtb.deposit = 0;

	if (Boba.vtb.deposit > 1'000'000) {
		Boba.tax.deposit_tax = (RUB)(Boba.vtb.deposit * Boba.vtb.interest / 100.0 * Boba.tax.key_rate);
		Boba.vtb.deposit -= Boba.tax.deposit_tax;
	}
}


void create_csv()
{
	std::ofstream file("simulation.csv", std::ios::app);

	static bool first = true;

	if (!first) return;

	file.seekp(0, std::ios::end);
	if (file.tellp() == 0) {
		file << "Год;Месяц;Персонаж;"
			<< "Депозит;Доход_с_депозита;"
			<< "Зарплата;Еда;Питомцы;Рента;"
			<< "Расходы_на_машину;Ипотека;Долг;"
			<< "Налоги;Баланс_событий;Деньги_с_событий;"
			<< "Бизнес;Доход_сбизнеса;Инфляция\n";
	}
	first = false;
}


void save_to_csv(int year, int month, double multiplier)
{
	std::ofstream file("simulation.csv", std::ios::app);

	file << year << ";"
		<< month << ";"
		<< "Биба" << ";"
		<< Biba.vtb.deposit << ";"
		<< (RUB)(Biba.vtb.deposit * (Biba.vtb.interest / 12 / 100.0)) << ";"
		<< Biba.salary << ";"
		<< Biba.food << ";"
		<< (Biba.cat + Biba.dog) << ";"
		<< Biba.rent << ";"
		<< (Biba.car.gaz + Biba.car.oil + Biba.car.service + Biba.car.tires) << ";"
		<< Biba.house.payment << ";"
		<< Biba.house.debt << ";"
		<< Biba.tax.total << ";"
		<< Biba.random.balance << ";"
		<< Biba.random.events_net << ";"
		<< Biba.business.value << ";"
		<< Biba.business.profit << ";";

	if (multiplier == 1) {
		file << "\n";  // пустая ячейка
	}
	else {
		file << std::fixed << std::setprecision(2) << (multiplier - 1) << "\n";
	}

	file << year << ";"
		<< month << ";"
		<< "Боба" << ";"
		<< Boba.vtb.deposit << ";"
		<< (RUB)(Boba.vtb.deposit * (Boba.vtb.interest / 12 / 100.0)) << ";"
		<< Boba.salary << ";"
		<< Boba.food << ";"
		<< (Boba.cat + Boba.dog) << ";"
		<< Boba.rent << ";"
		<< (Boba.car.gaz + Boba.car.oil + Boba.car.service + Boba.car.tires) << ";"
		<< Boba.house.payment << ";"
		<< Boba.house.debt << ";"
		<< Boba.tax.total << ";"
		<< Boba.random.balance << ";"
		<< Boba.random.events_net << ";"
		<< Boba.business.value << ";"
		<< Boba.business.profit << ";";

	if (multiplier == 1) {
		file << "\n";  // пустая ячейка
	}
	else {
		file << std::fixed << std::setprecision(2) << (multiplier - 1) << "\n";
	}

	file.close();
}


void print_annual_result(const int year, const int month)
{
	if (!(month == 12)) return;

	printf("-------------------------\n");
	printf("Год: %d\n", year);
	printf("-------------------------\n");

	printf("Депозит Бибы: %lld\n", Biba.vtb.deposit);
	printf("Зарплата Бибы: %lld\n", Biba.salary);
	RUB wastes = Biba.food + Biba.internet + Biba.cat + Biba.dog + Biba.rent;
	printf("Расходы Бибы: %lld\n", wastes);

	Biba.tax.total = Biba.tax.food_VAT + Biba.tax.pets_VAT + Biba.tax.car_VAT + Biba.tax.income_tax + Biba.tax.deposit_tax
		+ Biba.tax.property_tax + Biba.tax.car_tax + Biba.tax.profit_tax + Biba.tax.business_property_tax + Biba.tax.staff_insurance;
	Biba.tax.annual_total += Biba.tax.total;
	if (month == 1) Biba.tax.annual_total = 0;
	printf("Биба заплатил налогов за год: %lld\n", Biba.tax.annual_total);

	if (Biba.house.has_mortgage)
	{
		printf("\nОстаток долга: %lld\n", Biba.house.debt);
	}
	if (Biba.business.has_business) {
		printf("\nКапитал бизнеса Бибы: %lld\n", Biba.business.value);
		printf("Площадь помещений бизнеса: %d\n", Biba.business.area);
		printf("Количество сотрудников: %d\n", Biba.business.staff_count);
		printf("Репутация бизнеса Бибы: %d\n", Biba.business.reputation);
		printf("Опыт предпринимательства Бибы: %d\n", Biba.business.experience);
	}
	
	printf("\nДепозит Бобы: %lld\n", Boba.vtb.deposit);
	printf("Зарплата Бобы: %lld\n", Boba.salary);
	wastes = Boba.food + Boba.internet + Boba.cat + Boba.dog + Boba.rent;
	printf("Расходы Бобы: %lld\n", wastes);

	if (month == 1) Boba.tax.annual_total = 0;
	Boba.tax.total = Boba.tax.food_VAT + Boba.tax.internet_VAT + Boba.tax.pets_VAT + Boba.tax.car_VAT
		+ Boba.tax.income_tax + Boba.tax.deposit_tax + Boba.tax.property_tax + Boba.tax.car_tax;
	Boba.tax.annual_total += Boba.tax.total;
	printf("Боба заплатил налогов за год: %lld\n", Boba.tax.annual_total);

	printf("-------------------------\n\n");
}


void print_result()
{
	printf("=== РЕЗУЛЬТАТ ===\n\n");
	printf("Зарплата Бибы на 2050: %lld\n", Biba.salary);

	RUB capital = 0;
	capital += Biba.vtb.account;
	capital += Biba.vtb.deposit;
	capital += Biba.car.value;
	capital += (Biba.house.price - Biba.house.debt);
	capital += Biba.business.value;
	capital += Biba.business.tbank.account + Biba.business.tbank.deposit;
	printf("Капитал Бибы на 2050: %lld\n", capital);
	printf("Баланс случайных событий для Бибы: %d\n", Biba.random.balance);
	printf("Денежный баланс случайных событий для Бибы: %lld\n\n", Biba.random.events_net);

	printf("Зарплата Бобы на 2050: %lld\n", Boba.salary);

	capital = 0;
	capital += Boba.vtb.account;
	capital += Boba.vtb.deposit;
	if (Boba.has_car) 
	{
		capital += Boba.car.value;
	}
	printf("Капитал Бобы на 2050: %lld\n", capital);
	printf("Баланс случайных событий для Бобы: %d\n", Boba.random.balance);
	printf("Денежный баланс случайных событий для Бобы: %lld\n", Boba.random.events_net);

	printf("\nДанные сохранены в simulation.csv\n");
}


void simulation(int month, int year) 
{
	double multiplier = apply_inflation(year, month);

	Biba_salary(month, year);

	Biba_business(month, year, multiplier);

	Biba_food(multiplier);
	Biba_internet(multiplier);
	Biba_pets(month, multiplier);
	Biba_car(month, year, multiplier);
	Biba_house(month, year, multiplier);
	Biba_mortgage();
	Biba_random_ivents(month, year);

	Biba_deposite(month, year);

	Boba_salary(month, year);
	Boba_freelance(month, year);

	Boba_food(multiplier);
	Boba_internet(multiplier);
	Boba_pets(month, multiplier);
	Boba_metro(multiplier);
	Boba_car(month, year, multiplier);
	Boba_house(multiplier);
	Boba_random_ivents(month);

	Boba_casino();

	Boba_deposite(month, year);

	create_csv();
	save_to_csv(year, month, multiplier);
}


int main()
{
	SetConsoleCP(1251);
	SetConsoleOutputCP(1251);
	setlocale(LC_ALL, "Russian");

	printf("=== НАЧАЛО СИМУЛЯЦИИ ===\n\n");
	int month = 3;
	int year = 2030;

	Biba_init();
	Boba_init();

	while (!(month == 3 and year == 2050))
	{
		simulation(month, year);

		print_annual_result(year, month);

		month++;
		if (month == 13)
		{
			year++;
			month = 1;
		}
	}

	print_result();

	return 0;
}
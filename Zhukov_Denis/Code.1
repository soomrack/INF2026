void Biba_house(int month, int year, double multiplier)
{
	Biba.rent = (RUB)(Biba.rent * multiplier);
	Biba.vtb.account -= Biba.rent;
	
	if (!Biba.house.has_house and Biba.vtb.deposit >= 5'000'000) {
		// покупка дома
		Biba.house.price = 15'000'000;
		Biba.house.first_payment = 2'000'000;

		Biba.vtb.deposit -= Biba.house.first_payment;

		Biba.house.has_house = true;
		Biba.house.has_mortgage = true;

		printf("==========================\n");
		printf("   Биба купил дом!\n");
		printf("остаток на депозите: %lld\n", Biba.vtb.deposit);
		printf("==========================\n\n");

		Biba.house.debt = (Biba.house.price - Biba.house.first_payment) * (1 + Biba.house.mortgage / 100);

		Biba.rent = 6'000; // расход на ренту превращается в коммунальные платежи за дом

		Biba.house.mortgage = 14;

		Biba.house.payment = (RUB)(Biba.house.debt / 30 / 12.0);
	}
}


void Boba_house(double multiplier)
{
	Boba.rent = (RUB)(Boba.rent * multiplier);
	Boba.vtb.account -= Boba.rent;
}


void Biba_mortgage()
{
	if (!Biba.house.has_mortgage) return;
	
		if (Biba.vtb.deposit >= Biba.house.payment)
		{
			Biba.vtb.deposit -= Biba.house.payment;
			Biba.house.debt -= Biba.house.payment;

			if (Biba.house.debt < 0) Biba.house.debt = 0;

			if (Biba.house.debt <= 0)
			{
				Biba.house.has_mortgage = false;
				printf("Ипотека выплачена!\n\n");
			}
		}

		else
		{
			//здесь можно добавить штраф за просрочку
		}
	
}


void Biba_random_prize(const int month)
{
	if (month % 3 != 0) return;

	RUB prize = 0;

	int roll = rand() % 100;
	if (roll < 15) {
		prize = 10'000;
		Biba.random.balance++;
		printf("Биба получил премию в размере %lld\n\n", prize);
	}
	else if (roll < 25) {
		prize = 20'000;
		Biba.random.balance++;
		printf("Биба получил премию в размере %lld\n\n", prize);
	}
	else if (roll < 30) {
		prize = 30'000;
		Biba.random.balance++;
		printf("Биба получил премию в размере %lld\n\n", prize);
	}
	Biba.vtb.account += prize;
	Biba.random.events_net += prize;
}


void Biba_random_fines()
{
	RUB fine = 0;

	int roll = rand() % 100;
	if (roll < 5 and Biba.has_car) {
		fine = 10'000;
		Biba.random.balance--;
		printf("Биба получил штраф в размере %lld\n\n", fine);
	}
	else if (roll < 10 and Biba.has_car) {
		fine = 5'000;
		Biba.random.balance--;
		printf("Биба получил штраф в размере %lld\n\n", fine);
	}
	else if (roll < 15 and Biba.has_car) {
		fine = 2'000;
		Biba.random.balance--;
		printf("Биба получил штраф в размере %lld\n\n", fine);
	}

	Biba.vtb.account -= fine;
	Biba.random.events_net -= fine;
}


void Biba_random_medicine(const int month)
{
	RUB dentistry = 0; // лечение зубов
	int roll = rand() % 100;
	if (roll < 1) {
		dentistry = 50'000;
		Biba.random.balance--;
		printf("У Бибы глубокий кариес, цена лечения: %lld\n\n", dentistry);
	}
	else if (roll < 2) {
		dentistry = 20'000;
		Biba.random.balance--;
		printf("У Бибы кариес, цена лечения: %lld\n\n", dentistry);
	}
	else if (roll < 5) {
		dentistry = 10'000;
		Biba.random.balance--;
	}
	else if (roll < 9) {
		dentistry = 5'000;
		Biba.random.balance--;
	}
	Biba.random.events_net -= dentistry;
	Biba.vtb.deposit -= dentistry;

	 // травмы
	roll = rand() % 100;
	if (roll < 1) {
		Biba.random.recovery = 3;
		Biba.random.treatment = 10'000;
		Biba.random.balance--;
		printf("Биба сломал ногу!\n\n");
	}
	else if (roll < 2) {
		Biba.random.recovery = 1;
		Biba.random.treatment = 5'000;
		Biba.random.balance--;
		printf("Биба повредил колено!\n\n");
	}
	else if (roll < 6) {
		Biba.vtb.account -= 2'000;
		Biba.random.events_net -= 2'000;
		Biba.random.balance--;
	}

	if (Biba.random.recovery > 0) {
		Biba.vtb.account -= Biba.random.treatment;
		Biba.random.events_net -= Biba.random.treatment;
		Biba.random.recovery--;
	}
}


void Biba_random_pets() {
	int roll = rand() % 100;
	if (!Biba.has_dog and !Biba.has_cat and roll < 7) {
		if (rand() % 2 == 0) {
			Biba.has_dog = true;
			printf("Биба завёл собаку!\n\n");
			Biba.random.balance++;
		}
		else {
			Biba.has_cat = true;
			printf("Биба завёл кота!\n\n");
			Biba.random.balance++;
		}
	}

	if (!Biba.has_cat and !Biba.has_dog) return;

	roll = rand() % 100;
	if (roll < 5 and Biba.has_cat) {
		printf("Кот Бибы заболел! ");
		Biba.random.balance--;
		roll = rand() % 100;
		if (roll < 5) {
			Biba.has_cat = false;
			printf("Кот Бибы умер!\n\n");
		}
		else if (roll < 25) {
			Biba.vtb.account -= 10'000;
			printf("Цена лечения: %d\n\n", 10'000);
			Biba.random.events_net -= 10'000;
		}
		else if (roll < 70) {
			Biba.vtb.account -= 5'000;
			printf("Цена лечения: %d\n\n", 5'000);
			Biba.random.events_net -= 5'000;
		}
		else printf("Кот поправился сам.\n\n");
	}

	roll = rand() % 100;
	if (roll < 3 and Biba.has_dog) {
		printf("Пёс Бибы заболел! ");
		Biba.random.balance--;
		roll = rand() % 100;
		if (roll < 5) {
			Biba.has_dog = false;
			printf("Пёс Бибы умер!\n\n");
		}
		else if (roll < 25) {
			Biba.vtb.account -= 12'000;
			printf("Цена лечения: %d\n\n", 12'000);
			Biba.random.events_net -= 12'000;
		}
		else if (roll < 70) {
			Biba.vtb.account -= 5'000;
			printf("Цена лечения: %d\n\n", 5'000);
			Biba.random.events_net -= 5'000;
		}
		else printf("Пёс поправился сам.\n\n");
	}
}



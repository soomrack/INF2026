void Biba_business_deposit_development()
{
	if (!Biba.business.has_business) return;
	if (Biba.business.tbank.deposit < 2'000'000) return;

	int roll = rand() % 100;

	RUB bonus = 0;
	RUB loss = 0;

	if (roll < 3) {
		bonus = (RUB)(Biba.business.tbank.deposit * 0.2);
		Biba.business.tbank.deposit += bonus;
	}
	else if (roll < 8) {
		bonus = (RUB)(Biba.business.tbank.deposit * 0.1);
		Biba.business.tbank.deposit += bonus;
	}
	else if (roll < 15) {
		bonus = (RUB)(Biba.business.tbank.deposit * 0.05);
		Biba.business.tbank.deposit += bonus;
	}
	else if (roll < 20) {
		loss = (RUB)(Biba.business.tbank.deposit * 0.05);
		Biba.business.tbank.deposit -= loss;
	}
	else if (roll < 23) {
		loss = (RUB)(Biba.business.tbank.deposit * 0.15);
		Biba.business.tbank.deposit -= loss;
	}

	if (Biba.business.tbank.deposit < 0) Biba.business.tbank.deposit = 0;

	int choice = rand() % 6 + 1;
	switch (choice) {
	case 1: {
		Biba.vtb.account += 50'000;
		Biba.business.tbank.deposit -= 40'000;
		break;
	}

	case 2: {
		Biba.vtb.account += 100'000;
		Biba.business.tbank.deposit -= 80'000;
		break;
	}

	case 3: {
		Biba.business.area += 20;
		Biba.business.tbank.deposit -= 1'000'000;
		break;
	}

	case 4: {
		Biba.business.area += 40;
		Biba.business.tbank.deposit -= 2'000'000;
		break;
	}

	case 5: {
		Biba.business.tbank.account += 200'000;
		Biba.business.tbank.deposit -= 200'000;
		break;
	}

	case 6: {
		Biba.business.tbank.account += 300'000;
		Biba.business.tbank.deposit -= 300'000;
		break;
	}
	}
}


void Biba_business_taxes()
{
	Biba.tax.profit_tax = 0;
	Biba.tax.business_property_tax = 0;
	Biba.tax.staff_insurance = 0;

	if (Biba.business.has_business) {
		Biba.tax.profit_tax = (RUB)(Biba.business.income * 0.06);
		Biba.business.tbank.account -= Biba.tax.profit_tax;

		Biba.tax.business_property_tax = (RUB)(Biba.business.value * Biba.tax.key_rate);
		Biba.business.tbank.account -= Biba.tax.business_property_tax;

		Biba.tax.staff_insurance = (RUB)(Biba.business.staff_cost * 0.30);
		Biba.business.tbank.account -= Biba.tax.staff_insurance;
	}
}


void Biba_business(const int month, const int year, double multiplier)
{
	Biba_business_open();
	Biba_business_profit(month, year, multiplier);
	Biba_business_growth(month);
	Biba_business_development();
	Biba_business_deposit_development();
	Biba_business_taxes();

	Biba.business.value = (RUB)(Biba.business.value * (1 + Biba.business.area / 10000.0));
	if (Biba.business.value > 1'000'000'000)
		Biba.business.value = 1'000'000'000;
}


void Boba_freelance(const int month, const int year)
{
	int jobs = 2 + rand() % 5;

	Boba.freelance.income = 0;
	int job_hours = 0;

	for (int i = 0; i < jobs; i++) {
		job_hours = 2 + rand() % 8;
		RUB job_payment = job_hours * Boba.freelance.rate_per_hour;

		if (rand() % 100 < Boba.freelance.reputation) {
			job_payment = (RUB)(job_payment * 1.2);
		}

		Boba.freelance.income += job_payment;
	}

	Boba.vtb.account += Boba.freelance.income;
	Boba.freelance.jobs_completed += jobs;

	if (month == 3 or month == 9) {
		printf("ФРИЛАНС БОБЫ (%d/%d)\n", month, year);
		printf("   Заказов: %d, часов: %d\n", jobs, job_hours);
		printf("   Доход: %lld руб\n", Boba.freelance.income);

		Boba.freelance.reputation += 1 + rand() % 3;
		if (Boba.freelance.reputation > 100) Boba.freelance.reputation = 100;

		printf("   Репутация: %d)\n\n", Boba.freelance.reputation);
	}
}


void Boba_casino()
{
	if (Boba.vtb.account < 10'000) return;
	if (Boba.vtb.deposit <= 0) return;

	int choice = rand() % 12 + 1;
	RUB bet = 0;
	RUB win = 0;

	switch (choice) {
	case 1: {
		bet = 1'000;
		Boba.vtb.account -= bet;

		printf("Ставка на слотах: %lld руб\n", bet);

		if (rand() % 100 < 30) {
			win = bet * (2 + rand() % 4);
			Boba.vtb.account += win;
			printf("ДЖЕКПОТ! Выигрыш: %lld руб (x%d)\n",
				win, win / bet);
			Boba.random.events_net += (win - bet);
			Boba.random.balance++;
		}
		else {
			printf("Проигрыш на слотах\n");
			Boba.random.events_net -= bet;
			Boba.random.balance--;
		}
		break;
	}

	case 2: {
		bet = 2'000;
		Boba.vtb.account -= bet;

		printf("Рулетка, ставка на цвет: %lld руб\n", bet);

		if (rand() % 100 < 48) {
			win = bet * 2;
			Boba.vtb.account += win;
			printf("Угадал цвет! Выигрыш: %lld руб\n", win);
			Boba.random.events_net += bet;
			Boba.random.balance++;
		}
		else {
			printf("Не угадал цвет\n");
			Boba.random.events_net -= bet;
			Boba.random.balance--;
		}
		break;
	}

	case 3: {
		bet = 1'000;
		Boba.vtb.account -= bet;

		printf("Рулетка, ставка на число: %lld руб (шанс 2.7%%)\n", bet);

		if (rand() % 37 == 0) {
			win = bet * 36;

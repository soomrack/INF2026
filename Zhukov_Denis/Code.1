		Boba.vtb.deposit -= Boba.tax.property_tax;
	}

	if (Boba.has_car and month == 12) {
		Boba.tax.car_tax = (RUB)(Boba.car.value * 0.01);
		Boba.vtb.deposit -= Boba.tax.car_tax;
	}

	RUB capital = Boba.vtb.deposit + Boba.house.price + Boba.car.value;
	if (capital > 50'000'000) {
		Boba.tax.luxury_tax = (RUB)(capital * 0.01);
		Boba.vtb.deposit -= Boba.tax.luxury_tax;
	}

	Boba.tax.food_VAT = (RUB)(Boba.food * Boba.tax.VAT_rate);
	Boba.vtb.account -= Boba.tax.food_VAT;

	Boba.tax.internet_VAT = (RUB)(Boba.internet * Boba.tax.VAT_rate);
	Boba.vtb.account -= Boba.tax.internet_VAT;

	Boba.tax.pets_VAT = (RUB)((Boba.cat + Boba.dog) * Boba.tax.VAT_rate);
	Boba.vtb.account -= Boba.tax.pets_VAT;

	if (Boba.has_car) {
		Boba.tax.car_VAT = Boba.car.gaz;
		if (month == 3 or month == 9) {
			Boba.tax.car_VAT += Boba.car.service + Boba.car.oil;
		}
		if (year % 4 == 0 and month == 10) {
			Boba.tax.car_VAT += Boba.car.tires;

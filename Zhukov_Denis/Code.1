	if (roll < 10 and Boba.has_car) {
		fine = 2'000;
		Boba.random.balance--;
		Boba.random.events_net -= 2'000;
		printf("Боба получил штраф в размере %lld\n\n", fine);
	}
	else if (roll < 15 and Boba.has_car) {
		fine = 5'000;
		Boba.random.balance--;
		Boba.random.events_net -= 5'000;
		printf("Боба получил штраф в размере %lld\n\n", fine);
	}
	else if (roll < 20 and Boba.has_car) {
		fine = 10'000;
		Boba.random.balance--;
		Boba.random.events_net -= 10'000;
		printf("Боба получил штраф в размере %lld\n\n", fine);
	}

	Boba.vtb.account -= fine;
}


void Boba_random_medicine(const int month)
{
	RUB dentistry = 0; // лечение зубов
	int roll = rand() % 100;
	if (roll < 2) {
		dentistry = 20'000;
		Boba.random.balance--;
		printf("У Бобы кариес, цена лечения: %lld\n\n", dentistry);
	}
	else if (roll < 4) {
		dentistry = 10'000;
		Boba.random.balance--;
	}
	else if (roll < 7) {
		dentistry = 5'000;
		Boba.random.balance--;
	}
	Boba.random.events_net -= dentistry;
	Boba.vtb.deposit -= dentistry;

	// травмы
	roll = rand() % 100;
	if (roll < 1) {
		Boba.random.recovery = 3;
		Boba.random.treatment = 10'000;
		Boba.random.balance--;
		printf("Боба сломал ногу!\n\n");
	}
	else if (roll < 2) {
		Boba.random.recovery = 1;
		Boba.random.treatment = 5'000;
		Boba.random.balance--;
		printf("Боба повредил колено!\n\n");
	}
	else if (roll < 5) {
		Boba.vtb.account -= 2'000;
		Boba.random.events_net -= 2'000;
		Boba.random.balance--;
	}

	if (Boba.random.recovery > 0) {
		Boba.vtb.account -= Boba.random.treatment;
		Boba.random.events_net -= Boba.random.treatment;
		Boba.random.recovery--;
	}
}


void Boba_random_pets() {
	int roll = rand() % 100;
	if (!Boba.has_dog and !Boba.has_cat and roll < 5) {
		if (rand() % 2 == 0) {
			Boba.has_dog = true;
			printf("Боба завёл собаку!\n\n");
			Boba.random.balance++;
		}
		else {
			Boba.has_cat = true;
			printf("Боба завёл кота!\n\n");
			Boba.random.balance++;
		}
	}

	if (!Boba.has_cat and !Boba.has_dog) return;

	roll = rand() % 100;
	if (roll < 7 and Boba.has_cat) {
		printf("Кот Бобы заболел! ");
		Boba.random.balance--;
		roll = rand() % 100;
		if (roll < 5) {
			Boba.has_cat = false;
			printf("Кот Бобы умер!\n\n");
		}
		else if (roll < 25) {
			Boba.vtb.account -= 10'000;
			printf("Цена лечения: %d\n\n", 10'000);
			Boba.random.events_net -= 10'000;
		}
		else if (roll < 70) {
			Boba.vtb.account -= 5'000;
			printf("Цена лечения: %d\n\n", 5'000);
			Boba.random.events_net -= 5'000;
		}
		else printf("Кот поправился сам.\n\n");
	}

	roll = rand() % 100;
	if (roll < 5 and Boba.has_dog) {
		printf("Пёс Бобы заболел! ");
		Boba.random.balance--;
		roll = rand() % 100;
		if (roll < 5) {
			Boba.has_dog = false;
			printf("Пёс Бобы умер!\n\n");
		}
		else if (roll < 25) {
			Boba.vtb.account -= 12'000;
			printf("Цена лечения: %d\n\n", 12'000);
			Boba.random.events_net -= 12'000;
		}
		else if (roll < 70) {
			Boba.vtb.account -= 5'000;
			printf("Цена лечения: %d\n\n", 5'000);
			Boba.random.events_net -= 5'000;
		}
		else printf("Пёс поправился сам.\n\n");
	}
}



void Boba_random_ivents(const int month)
{
	Boba_random_prize(month);
	Boba_random_medicine(month);
	Boba_random_pets();
	if (Boba.random.recovery > 0) return;
	Boba_random_fines();
}


void Biba_deposite(const int month, const int year)
{
	if (year < 2035) Boba.vtb.interest = 8;
	else if (year < 2040) Boba.vtb.interest = 7.5;
	else if (year < 2045) Boba.vtb.interest = 8;
	else if (year < 2050) Boba.vtb.interest = 7.8;

	Biba.vtb.deposit += Biba.vtb.deposit * (Biba.vtb.interest / 12 / 100.0);

	Biba.vtb.deposit += Biba.vtb.account;
	Biba.vtb.account = 0;
}


void Boba_deposite(const int month, const int year)
{
	if (year < 2035) Boba.vtb.interest = 8;
	else if (year < 2040) Boba.vtb.interest = 7.8;
	else if (year < 2045) Boba.vtb.interest = 8.1;
	else if (year < 2050) Boba.vtb.interest = 7.6;

	Boba.vtb.deposit += Boba.vtb.deposit * (Boba.vtb.interest / 12 / 100.0);

	Boba.vtb.deposit += Boba.vtb.account;
	Boba.vtb.account = 0;
}


void print_annual_result(const int year, const int month)
{
	if (!(month == 12)) return;

	printf("-------------------------\n");
	printf("Год: %d\n", year);
	printf("-------------------------\n");

	printf("Депозит Бибы: %lld\n", Biba.vtb.deposit);
	printf("Зарплата Бибы: %lld\n", Biba.salary);
	RUB wastes = Biba.food + Biba.internet + Biba.cat + Biba.dog + Biba.rent;
	printf("Расходы Бибы: %lld\n", wastes);
	printf("Биба заплатил налогов за год: %lld\n\n", Biba.tax.annual_total);
	if (Biba.house.has_mortgage)
	{
		printf("Остаток долга: %lld\n\n", Biba.house.debt);
	}
	
	printf("Депозит Бобы: %lld\n", Boba.vtb.deposit);
	printf("Зарплата Бобы: %lld\n", Boba.salary);
	wastes = Boba.food + Boba.internet + Boba.cat + Boba.dog + Boba.rent;
	printf("Расходы Бобы: %lld\n", wastes);
	printf("Боба заплатил налогов за год: %lld\n", Boba.tax.annual_total);

	printf("-------------------------\n\n");
}


void print_result()
{
	printf("=== РЕЗУЛЬТАТ ===\n\n");
	printf("Зарплата Бибы на 2050: %lld\n", Biba.salary);

	RUB capital = 0;
	capital += Biba.vtb.account;
	capital += Biba.vtb.deposit;
	capital += Biba.car.value;
	capital += (Biba.house.price - Biba.house.debt);
	printf("Капитал Бибы на 2050: %lld\n", capital);
	printf("Баланс случайных событий для Бибы: %d\n", Biba.random.balance);
	printf("Денежный баланс случайных событий для Бибы: %lld\n\n", Biba.random.events_net);

	printf("Зарплата Бобы на 2050: %lld\n", Boba.salary);

	capital = 0;
	capital += Boba.vtb.account;
	capital += Boba.vtb.deposit;
	if (Boba.has_car) 
	{
		capital += Boba.car.value;
	}
	printf("Капитал Бобы на 2050: %lld\n", capital);
	printf("Баланс случайных событий для Бобы: %d\n", Boba.random.balance);
	printf("Денежный баланс случайных событий для Бобы: %lld\n", Boba.random.events_net);

	printf("\nДанные сохранены в simulation.csv\n");
}


void simulation(int month, int year) 
{
	double multiplier = apply_inflation(year, month);

	Biba_salary(month, year);

	Biba_food(multiplier);
	Biba_internet(multiplier);
	Biba_pets(month, multiplier);
	Biba_car(month, year, multiplier);
	Biba_taxes(month, year);
	Biba_house(month, year, multiplier);
	Biba_mortgage();
	Biba_random_ivents(month);

	Biba_deposite(month, year);

	Boba_salary(month, year);

	Boba_food(multiplier);
	Boba_internet(multiplier);
	Boba_pets(month, multiplier);
	Boba_metro(multiplier);
	Boba_car(month, year, multiplier);
	Boba_taxes(month, year);
	Boba_house(multiplier);
	Boba_random_ivents(month);

	Boba_deposite(month, year);
}


int main()
{
	SetConsoleCP(1251);
	SetConsoleOutputCP(1251);
	setlocale(LC_ALL, "Russian");

	printf("=== НАЧАЛО СИМУЛЯЦИИ ===\n\n");
	int month = 3;
	int year = 2030;

	Biba_init();
	Boba_init();

	while (!(month == 3 and year == 2050))
	{
		simulation(month, year);

		print_annual_result(year, month);

		month++;
		if (month == 13)
		{
			year++;
			month = 1;
		}
	}

	print_result();

	return 0;
}
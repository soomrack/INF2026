void Biba_business_open()
{
	if (Biba.business.has_business) return;
	if (Biba.vtb.deposit < 4'000'000) return;

	Biba.business.value = 2'500'000;
	Biba.business.tbank.account = 500'000;
	Biba.business.tbank.deposit = 0;
	Biba.vtb.deposit -= Biba.business.value + Biba.business.tbank.account;

	Biba.business.has_business = true;
	Biba.business.reputation = 10;
	Biba.business.experience = 1;
	Biba.business.income_per_visitor = 1'500;

	Biba.business.staff_count = 2;
	Biba.business.staff_salary = 40'000;

	Biba.business.area = 50;
	Biba.business.rent_per_m2 = 800;

	Biba.business.marketing = 20'000;

	Biba.business.share = 0.3;

	printf("=== БИБА ОТКРЫЛ БИЗНЕС! ===\n");
	printf("Стоимость бизнеса: %lld руб\n", Biba.business.value);
	printf("Персонал: %d чел, з/п %lld\n", Biba.business.staff_count, Biba.business.staff_salary);
	printf("Помещение: %d м², аренда %lld\n", Biba.business.area, Biba.business.rent);
	printf("============================\n\n");
}


void Biba_business_visitors()
{
	if (!Biba.business.has_business) return;

	Biba.business.base_visitors = Biba.business.staff_count * staff_effect(gen);

	Biba.business.visitors = Biba.business.base_visitors * Biba.business.area / 10;
	Biba.business.visitors = (int)(Biba.business.visitors * Biba.business.reputation / 10);

	if (Biba.business.marketing > 200'000) {
		Biba.business.visitors *= 2;
	}
	else 
		Biba.business.visitors = (int)(Biba.business.visitors * (1 + Biba.business.marketing / 200'000));

	Biba.business.visitors = (int)(Biba.business.visitors * visitors(gen));
}


void Biba_business_income(const int month, const int year, double multiplier)
{ 
	if (month == 1 and year > 2030) {
		Biba.business.income_per_visitor = (RUB)(Biba.business.income_per_visitor * multiplier);
	}
	Biba.business.income = Biba.business.income_per_visitor * Biba.business.visitors;

	Biba.business.income += (RUB)(Biba.business.income * Biba.business.experience / 100);
}


void Biba_business_profit(const int month, const int year, double multiplier)
{
	if (!Biba.business.has_business) return;

	if (month == 1 and year > 2030) {
		Biba.business.marketing = (RUB)(Biba.business.marketing * multiplier);
		Biba.business.rent_per_m2 = (RUB)(Biba.business.rent_per_m2 * multiplier);
		Biba.business.value = (RUB)(Biba.business.value * multiplier);
		Biba.business.income_per_visitor = (RUB)(Biba.business.income_per_visitor * multiplier);

		double salary_index = inflation(gen) * 0.8;
		Biba.business.staff_salary = (RUB)(Biba.business.staff_salary * (1 + salary_index / 100));
	}

	Biba_business_visitors();

	Biba.business.rent = Biba.business.area * Biba.business.rent_per_m2;
	Biba.business.staff_cost = Biba.business.staff_count * Biba.business.staff_salary;

	Biba_business_income(month, year, multiplier);

	Biba.business.profit = Biba.business.income - Biba.business.marketing - Biba.business.rent - Biba.business.staff_cost;

	if (Biba.business.profit > 200'000) {
		Biba.vtb.account += Biba.business.profit * Biba.business.share;
		Biba.business.profit -= Biba.business.profit * Biba.business.share;
		Biba.business.profit /= 2;
		Biba.business.tbank.deposit += Biba.business.profit;
		Biba.business.tbank.account += Biba.business.profit;
	}
	else if (Biba.business.profit > 0) {
		Biba.business.profit /= 3;
		Biba.business.tbank.deposit += Biba.business.profit;
		Biba.business.tbank.account += 2 * Biba.business.profit;
	}
	else {
		Biba.business.tbank.account += Biba.business.profit;
		if (Biba.business.tbank.account < 0 and Biba.business.tbank.deposit > -Biba.business.tbank.account) {
			Biba.business.tbank.deposit += Biba.business.tbank.account;
			Biba.business.tbank.account = 0;
		}
		else {
			Biba.vtb.deposit += Biba.business.tbank.account;
			Biba.business.tbank.account = 0;
		}
	}

	if (Biba.business.tbank.deposit > 0) {
		Biba.business.tbank.interest = (RUB)(Biba.business.tbank.deposit * 0.06 / 12.0);
		Biba.business.tbank.deposit += Biba.business.tbank.interest;
	}
}


void Biba_business_growth(const int month)
{
	if (!Biba.business.has_business) return;
	if (month != 1) return;

	if (Biba.business.reputation < 30)
		Biba.business.reputation += business(gen) * 2;
	else 
		Biba.business.reputation += business(gen);

	if (Biba.business.staff_count < 15)
		Biba.business.experience += business(gen);
	else
		Biba.business.experience += business(gen) * 2;

	Biba.business.reputation += (int)(Biba.business.marketing / 40'000);

	if (Biba.business.reputation > 100) Biba.business.reputation = 100;
	if (Biba.business.experience > 100) Biba.business.experience = 100;

	if (Biba.business.tbank.account > 500'000'000)
		Biba.business.tbank.account = 500'000'000;
	if (Biba.business.tbank.deposit > 500'000'000)
		Biba.business.tbank.deposit = 500'000'000;
}



// Зарплата Эммы
void emma_salary(int month, int year)
{
    if (month == 12)
        emma.bank.rubles += emma.salary;

    if (month == 1 && year == 2029)
        emma.salary *= 1.2;

    if (month == 1 && year == 2032)
        emma.salary *= 1.25;

    emma.bank.rubles += emma.salary;
    emma.bank.rubles += emma.partner_gift;
}

// Депозит Эммы
void emma_deposit(int month, int year)
{
    if (year == 2026)
        emma.bank.interest_rate = 14.5;
    else if (year == 2027)
        emma.bank.interest_rate = 13.5;
    else if (year == 2028)
        emma.bank.interest_rate = 12.5;
    else if (year >= 2029)
        emma.bank.interest_rate = 11.5;

    emma.bank.deposit += emma.bank.deposit * (emma.bank.interest_rate / 12.0 / 100.0);
    emma.bank.deposit += emma.bank.rubles;
    emma.bank.rubles = 0;
}


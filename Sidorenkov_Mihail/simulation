        // В исходном коде был флаг newflat_own, но мы используем new_apartment_price как индикатор: если >0, то не своя (аренда), после покупки - ипотека.
    }
    if (new_apartment_price > 0 && new_apartment_price < 15'000'000) // после первого взноса идёт ипотека

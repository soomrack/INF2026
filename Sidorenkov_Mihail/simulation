// Ипотека
void mortgage_payment()
{
    float annual_rate = 20.7;
    new_apartment_price += new_apartment_price * annual_rate / 100 / 12;
    float years = 15;
    float total_months = years * 12;
    float monthly_rate = (annual_rate / 100) / 12;
    float common_pow = std::pow(1 + monthly_rate, total_months);
    float annuity_payment = new_apartment_price * (monthly_rate * common_pow) / (common_pow - 1);

    alex.bank.rubles -= annuity_payment;
    new_apartment_price -= annuity_payment;
}


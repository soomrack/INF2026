#include <stdio.h>


using RUB = long long int;

struct Person {
    RUB salary;
    RUB car;
    RUB medicine;
};

struct Expenses {
    RUB food;
    RUB taxes;
};

struct Car {
    RUB cost_car;
    RUB gas;
};

struct Tbank {
    RUB bank_account;
    RUB deposit; // вклад
    const float pp = 14.5; // ставка вклада
    const float pr_ip = 7; // ставка ипотеки
};

struct Person Alice;
struct Expenses Expenses;
struct Car Car;
struct Tbank Tbank;

void init() {
    Alice.salary = 200'000;
    Car.cost_car = 2'500'000;
    Car.gas = 15'000;
    Expenses.food = 20'000; // в месяц на еду
    Expenses.taxes = 4'000; // в месяц на налоги
    Tbank.bank_account = 0;
    Tbank.deposit = 0;
    Alice.medicine = 7'000;
}

void Alice_career(const int month, const int year) {
    if ((month == 6) && (year == 2026)){ // повышение
        Alice.salary = Alice.salary * 1.3;
    }
}

void Alice_payday() {
    Tbank.bank_account += Alice.salary;
}

void Alice_deposit() {
    int to_deposit = 10'000; // сумма от зарплаты на депозит
    Tbank.deposit += Tbank.deposit * (Tbank.pp / 12.0 / 100.0); // проценты по вкладу
    Tbank.deposit += to_deposit; // пополнение вклада
    Tbank.bank_account -= to_deposit; 
}

void Alice_car_exp() {
    Tbank.bank_account -= Car.gas; // каждый месяц на бензин
    Car.cost_car += Car.cost_car * (15 / 12.0 / 100.0); // инфляция на машину в 15 процентов
}

void Alice_food_exp() {
    Tbank.bank_account -= Expenses.food; // каждый месяц на еду
    Expenses.food += Expenses.food * (5 / 12.0 / 100.0); // инфляция на еду в 5 процентов
}

void Alice_medicine(const int month, const int year) {
    Tbank.bank_account -= Alice.medicine; // страховка
    if (((month == 6) && (year == 2027)) || ((month == 8) && (year == 2027)) || ((month == 10) && (year == 2027)) || ((month == 12) && (year == 2027))) {
        Tbank.bank_account -= 30'000; // удаление зуба мудрости
    }
    if ((year == 2028) || year == 2029) { // брекеты
        if (month == 1) {
            Tbank.bank_account -= 25'000; // установка брекетов
        }
        Tbank.bank_account -= 5'000; //  ежемесячное обслуживание брекетов
        if ((month == 12) && (year == 2029)) {
            Tbank.bank_account -= 25'000; // снятие брекетов
        }
    }
}

void Alice_credits (const int month, const int year, const float pr_ip) {
    if ((month == 1) && (year == 2035)) {
        int ip_summa = 10'000'000;
        const float pr_first_payment = 0.4; // первый взнос на ипотеку 40%
        Tbank.bank_account -= (ip_summa * pr_first_payment); // первый взнос на ипотку
        ip_summa -= ip_summa * pr_first_payment;
        long int paymant_ip = ((6'000'000 / (20*12))+((1 + pr_ip)*6));
    }    
}

void Alice_house(const int month, const int year) {
    if ((year < 2035)) { // снимает жильё
        Tbank.bank_account -= 30'000;
    }
}

void simulation() {
    int month = 1;
    int year = 2026;
    while (!((month == 2) && (year == 2027))) {
        Alice_career(month, year);
        Alice_payday(); // зарплата
        Alice_deposit(); // депозит
        Alice_car_exp(); // + инфляция на машину
        Alice_food_exp(); // + инфляция на еду
        Alice_medicine(month, year); // медстраховка

        ++month;
        if (month == 13) {
            month = 1;
            ++year;
        }
    }
}

void result() {
    printf("Зарплата = %lld\n", Alice.salary);
    printf("Банковский acc = %lld\n", Tbank.bank_account);
    printf("Сумма депозита = %lld\n", Tbank.deposit);
    printf("Цена машины = %lld\n", Car.cost_car);
}

int main() {
    init();
    simulation();
    result();
}

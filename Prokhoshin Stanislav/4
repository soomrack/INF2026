        printf("Расход топлива: %.1f л/100км\n", user.car.fuel_consumption);
        printf("Год выпуска: %d\n", user.car.year_of_issue);
        printf("        Информация по кредиту на момент записи\n");
        
        if (user.credit_months > 0) {
            printf("Осталось платежей: %d мес.\n", user.credit_months);
            printf("Ежемесячный платеж: %d rub.\n", user.credit_payment);
        } else {
            printf("Кредит полностью выплачен\n");
        }
    }
}


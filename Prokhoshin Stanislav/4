    User Ignat;
    Ignat.capital = 1'000'000;
    Ignat.salary = 150'120;
    Ignat.koeff = 1;
    Ignat.trust_lvl = 2;
    Ignat.has_car = 0;
    Ignat.credit_payment = 0;
    Ignat.credit_months = 0;
    
    int purchase_year = 2027 + rand() % 8;
    int purchase_month = 1 + rand() % 11;
    while (year != 2035 || month != 6)
    {
        date();
        
        Ignat = calc_salary(Ignat);
        Ignat = calc_trust_lvl(Ignat);
        Ignat = calc_koef(Ignat);
        
        if (year == purchase_year && month == purchase_month && Ignat.has_car == 0) {
            Ignat = buy_car(Ignat);
        }
        
        Ignat = calc_capital(Ignat);
    }
    
    print_inf(Ignat);
    return 0;
}

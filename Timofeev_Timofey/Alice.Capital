//  Крупные запланированные покупки 

void large_purchases(const int year, const int month)
{


    // Покупка мебели

    if (year == 2027 and month == 3)
    {
        if (home.capital >= 45'000) 
        { 
            home.capital -= 45'000;      //диван
        }
    }


    if (year == 2029 and month == 2)
    {
        if (home.capital >= 28'000)
        {
            home.capital -= 28'000;      // шкаф
        }
    }


    if (year == 2031 and month == 5)
    {
        if (home.capital >= 38'000)
        {
            home.capital -= 38'000;      // кухонный гарнитур
        }
    }


    if (year == 2033 and month == 8)
    {
        if (home.capital >= 52'000)
        {
            home.capital -= 52'000;          // спальня
        }
    }


    if (year == 2035 and month == 4)
    {
        if (home.capital >= 34'000)
        {
            home.capital -= 34'000;          // столовая
        }
    }


    // Бытовая техника

    if (year == 2026 and month == 11)
    {
        if (home.capital >= 22'000)
        {
            home.capital -= 22'000;     // стиральная машина
        }
    }


    if (year == 2028 and month == 9)
    {
        if (home.capital >= 19'000)
        {
            home.capital -= 19'000;      // пылесос
        }
    }


    if (year == 2030 and month == 12)
    {
        if (home.capital >= 41'000)
        {
            home.capital -= 41'000; // холодильник
        }
    }


    if (year == 2032 and month == 6)
    {
        if (home.capital >= 26'000)
        {
            home.capital -= 26'000;     // посудомойка
        }
    }


    if (year == 2034 and month == 10)
    {
        if (home.capital >= 33'000)
        {
            home.capital -= 33'000;  // кондиционер
        }
    }


    // Электроника

    if (year == 2027 and month == 7)
    {
        if (alice.bank_account >= 17'000)
        {
            alice.bank_account -= 17'000;    // планшет
        }
    }


    if (year == 2029 and month == 11)
    {
        if (stas.bank_account >= 29'000)
        {
            stas.bank_account -= 29'000;      // монитор
        }
    }


    if (year == 2031 and month == 3)
    {
        if (home.capital >= 14'000)
        {
            home.capital -= 14'000;     // роутер
        }
    }


    if (year == 2033 and month == 5)
    {
        if (alice.bank_account >= 24'000)
        {
            alice.bank_account -= 24'000;    // фотоаппарат
        }
    }


    // Ремонт и строительство (если появилась дача)

    if (home.have_dacha)
    {
        if (year == 2030 and month == 7)
        {
            if (home.capital >= 60'000)
            {
                home.capital -= 60'000; // веранда
            }
        }


        if (year == 2032 and month == 4)
        {
            if (home.capital >= 45'000)
            {
                home.capital -= 45'000; // забор
            }
        }


        if (year == 2034 and month == 6)
        {
            if (home.capital >= 75'000)
            {
                home.capital -= 75'000;     // баня

            }
        }
    }
}



        if (stas.bank_account >= 15'000)
        {
            stas.bank_account -= 15'000;   // оплата второго блока
        }
    }

    if (year == 2034 and month == 5)
    {
        if (stas.bank_account >= 15'000)
        {
            stas.bank_account -= 15'000;   // оплата третьего блока
        }
    }

    if (year == 2034 and month == 6)
    {
        if (stas.bank_account >= 15'000)
        {
            stas.bank_account -= 15'000;   // оплата четвёртого блока
        }
    }


    // Бизнес-тренинг Алисы 

    if (year == 2035 and month == 10)
    {
        if (alice.bank_account >= 28'000)
        {
            alice.bank_account -= 28'000;  // оплата курса
        }
    }


    // Онлайн-курс Стаса по робототехнике 

    if (year == 2036 and month == 1)
    {
        if (stas.bank_account >= 14'000)
        {
            stas.bank_account -= 14'000;   // теория
        }
    }

    if (year == 2036 and month == 2)
    {
        if (stas.bank_account >= 16'000)
        {
            stas.bank_account -= 16'000;   // практика
        }
    }
}
void alice_has_boat(const int year, const int month)
{
    //Покупка яхты
    if (year == 2030 and month == 4)
    {
        if (alice.bank_account >= alice.has_boat)
        {
            alice.bank_account -= alice.has_boat;
            alice.has_boat = true;
        }
    }
}

//  Симуляция до целевой даты 

void simulate_until(int start_year, int start_month)
{
    int year = 2026;
    int month = 2;

    while (not (year > start_year or (year == start_year and month > start_month)))
    {
                //АЛИСА
        alice_salary(year, month);

        alice_food_cost();
        alice_gas_cost();
        alice_cloth_cost();
        alice_savings_add();
        alice_monthly_savings_interest(year);
        alice_dream_check();

        alice_has_boat(year, month);

                //СТАС
        stas_salary(year, month);

        stas_food_cost();
        stas_cloth_cost();
        stas_gas_cost();
        stas_credit_payment();
        stas_credit_interest();
        stas_dream_check();

                //СЕМЬЯ (ДОМ)
        mortgage_payment();                 //ипотека
        home_insurance();                   //страховка жилья
        mortgage_interest();                //проценты ипотеки
        family_dream_check();
        large_purchases(year, month);       //мебель в дом

     
                //ОБЩЕЕ
        monthly_special(year, month);       //случайные события
        education_courses(year, month);     //курсы
        annual_taxes(year, month);          //налоги
        investment_income(year, month);     //инвестиции и копилка
       
        inflation(year);                    //инфляция

        // Сезонные скачки
        if (month == 6 or month == 7 or month == 8) 
        {
            summer_gas_spike();   // летом бензин дороже
        }
     
        if (month == 12 or month == 1 or month == 2)
        {
            winter_food_spike();  // зимой еда дороже
        }

        month++;
        if (month == 13) 
        {
            month = 1;
            year++;
        }
    }
}



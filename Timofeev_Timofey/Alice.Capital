    family_dreams.new_house = 12'880'000;
    family_dreams.dacha = 2'500'000;
    family_dreams.paris_trip = 550'000;

    home.sea_trip = false;
    home.London_trip = false;
    home.have_new_house = false;
    home.have_dacha = false;
    home.Paris_trip = false;
}


//      Зарплата Алисы с повышениями и отложение зарплаты в капиталы

void alice_salary(const int year, const int month)
{
    if (month == 6 and year == 2026)
    {
        alice.salary = alice.salary * 6 / 5;
    }

    if (month == 6 and year == 2027)
    {
        alice.salary = alice.salary * 6 / 5;
    }

    if (month == 6 and year == 2029)
    {
        alice.salary = alice.salary * 11 / 10;
    }

    if (month == 2 and year == 2032)
    {
        alice.salary = alice.salary * 6 / 5;
    }

    if (month == 2 and year == 2034)
    {
        alice.salary = alice.salary * 6 / 5;
    }

    RUB alice_share = 60 * alice.salary / 100;       // Сначала считаем долю Алисы (60%)
    RUB home_share = alice.salary - alice_share;     // Всё остальное уходит в дом

    alice.bank_account += alice_share;
    home.capital += home_share;
}


//  Зарплата Стаса с повышениями и отложение зарплаты в капиталы  

void stas_salary(const int year, const int month)
{
    if (month == 2 and year == 2027)
    {
        stas.salary = stas.salary * 7 / 5;
    }

    if (month == 4 and year == 2029)
    {
        stas.salary = stas.salary * 6 / 5;
    }

    if (month == 6 and year == 2030)
    {
        stas.salary = stas.salary * 11 / 10;
    }

    if (month == 3 and year == 2033)
    {
        stas.salary = stas.salary * 11 / 10;
    }

    if (month == 4 and year == 2035)
    {
        stas.salary = stas.salary * 3 / 2;
    }


    RUB stas_share = 50 * stas.salary / 100;         // Сначала считаем долю Стаса (50%)
    RUB home_share = stas.salary - stas_share;      // Всё остальное уходит в дом

    stas.bank_account += stas_share;
    home.capital += home_share;
}


//  Расходы Алисы 

void alice_food_cost()
{
    alice.bank_account -= alice.food;
}

void alice_gas_cost()
{
    alice.bank_account -= alice.gas;
}

void alice_cloth_cost()
{
    alice.bank_account -= alice.cloth;
}

void alice_savings_add()
{
    alice.bank_account -= 5000;          // ежемесячное пополнение накоплений
    alice.savings += 5000;
}


//  Расходы Стаса 

void stas_food_cost()
{
    stas.bank_account -= stas.food;
}

void stas_cloth_cost()
{
    stas.bank_account -= stas.cloth;
}

void stas_gas_cost()
{
    stas.bank_account -= stas.gas;
}

void stas_credit_payment()          //кредит
{
    // Если кредит уже выплачен - ничего не делаем
    if (stas.credit_debt <= 0)
    {
        stas.credit_debt = 0;
        return;
    }

    // Если остаток меньше платежа, то закрываем только остаток
    if (stas.credit_debt < stas.payment)
    {
        stas.payment = stas.credit_debt;
    }

    stas.bank_account -= stas.payment;
    stas.credit_debt -= stas.payment;

    if (stas.credit_debt < 0)
    {
        stas.credit_debt = 0;
    }
}


// Проценты кредита (1% в месяц)

void stas_credit_interest()
{
    stas.credit_debt += stas.credit_debt * 1 / 100;
}


void mortgage_payment()
{
    // Аналогично кредиту то же самое
    if (home.mortgage_debt <= 0)
    {
        home.mortgage_debt = 0;
        return;
    }

    if (home.mortgage_debt < home.payment)
    {
        home.payment = home.mortgage_debt;
    }

    home.capital -= home.payment;
    home.mortgage_debt -= home.payment;

    if (home.mortgage_debt < 0)
    {
        home.mortgage_debt = 0;
    }
}

// страховка жилья

void home_insurance()
{
    home.capital -= 10'000;
}


// Проценты ипотеки (0.5% в месяц)

void mortgage_interest()
{
    home.mortgage_debt += home.mortgage_debt * 1 / 1000;
}


//  Ежегодные налоги и сборы 

void annual_taxes(const int year, const int month)
{
    // Налог на имущество 

    if (month == 4)
    {
        if (year == 2026)
        {
            home.capital -= 8'500;
        }

        if (year == 2027)
        {
            home.capital -= 9'000;
        }

        if (year == 2028)
        {
            home.capital -= 9'400;
        }

        if (year == 2029)
        {
            home.capital -= 10'200;
        }

        if (year == 2030)
        {
            home.capital -= 11'000;
        }

        if (year == 2031)
        {
            home.capital -= 11'800;
        }

        if (year == 2032)
        {
            home.capital -= 12'500;
        }

        if (year == 2033)
        {
            home.capital -= 13'300;
        }

        if (year == 2034)
        {
            home.capital -= 14'100;
        }

        if (year == 2035)
        {
            home.capital -= 15'000;
        }

        if (year == 2036)
        {
            home.capital -= 15'800;
        }
    }


    // Транспортный налог 

    if (month == 10)
    {
        if (year == 2026)
        {
            alice.bank_account -= 6'200;  stas.bank_account -= 8'400;
        }

        if (year == 2027)
        {
            alice.bank_account -= 6'500;  stas.bank_account -= 8'800;
        }

        if (year == 2028)
        {
            alice.bank_account -= 6'800;  stas.bank_account -= 9'200;
        }

        if (year == 2029)
        {
            alice.bank_account -= 7'200;  stas.bank_account -= 9'700;
        }

        if (year == 2030)
        {
            alice.bank_account -= 7'600;  stas.bank_account -= 10'200;
        }

        if (year == 2031)
        {
            alice.bank_account -= 8'000;  stas.bank_account -= 10'800;
        }

        if (year == 2032)
        {
            alice.bank_account -= 8'500;  stas.bank_account -= 11'500;
        }

        if (year == 2033)
        {
            alice.bank_account -= 9'000;  stas.bank_account -= 12'200;
        }

        if (year == 2034)
        {
            alice.bank_account -= 9'600;  stas.bank_account -= 13'000;
        }

        if (year == 2035)
        {
            alice.bank_account -= 10'200; stas.bank_account -= 13'800;
        }

        if (year == 2036)
        {
            alice.bank_account -= 10'800; stas.bank_account -= 14'600;
        }
    }


    // Земельный налог (если появится дача, после покупки) 

    if (month == 11 and home.have_dacha)
    {
        if (year >= 2029)
        {
            home.capital -= 3'500;
        }

        if (year >= 2032)
        {
            home.capital -= 4'200;
        }

        if (year >= 2035)
        {
            home.capital -= 5'000;
        }
    }
}

//  Ежемесячный процент на накопительный счёт Алисы
void alice_monthly_savings_interest(const int year)
{
    RUB year_rate = 0; // Годовая ставка

    if (year == 2026)
    {
        year_rate = 4;
    }
    if (year == 2027)
    {
        year_rate = 4;
    }
    if (year == 2028)
        year_rate = 5;

    if (year == 2029)
    {
        year_rate = 5;
    }
    if (year == 2030)
    {
        year_rate = 6;
    }
    if (year == 2031)
    {   
        year_rate = 7;
    }
    if (year == 2032)
    {
        year_rate = 8;
    }
    if (year == 2033) 
    {
        year_rate = 8;
    }
    if (year == 2034) 
    {
        year_rate = 10;
    }   
    if (year == 2035) 
    {
        year_rate = 12;
    }
    if (year == 2036) 
    {
        year_rate = 15;
    }

    // Ежемесячный процент: годовую ставку делим на 100 и на 12 месяцев
    alice.savings += alice.savings * year_rate / 100 / 12;
}


//  Годовой доход от инвестиций  

void investment_income(const int year, const int month)
{
    if (month != 12) return;

    // Дивиденды от акций 

    if (year == 2026)
    {
        home.capital += 4'500;
    }

    if (year == 2027)
    {
        home.capital += 5'200;
    }

    if (year == 2028)
    {
        home.capital += 6'100;
    }

    if (year == 2029)
    {
        home.capital += 7'300;
    }

    if (year == 2030)
    {
        home.capital += 8'500;
    }

    if (year == 2031)
    {
        home.capital += 9'800;
    }

    if (year == 2032)
    {
        home.capital += 11'200;
    }

    if (year == 2033)
    {
        home.capital += 12'600;
    }

    if (year == 2034)
    {
        home.capital += 14'000;
    }

    if (year == 2035)
    {
        home.capital += 15'500;
    }

    if (year == 2036)
    {
        home.capital += 17'000;
    }
}


//  Инфляция 

void inflation(const int year)
{
    RUB food_infl = 8;   // 0.8%  СТАВКА
    RUB gas_infl = 9;   // 0.9%
    RUB cloth_infl = 5;  // 0.5%

    if (year >= 2028)
    {
        food_infl += 1;  // 0.9%
        gas_infl += 2;  // 1.1%
    }
    if (year >= 2031)
    {
        food_infl += 2;  //  1.1%
        gas_infl += 3;  //  1.4%
        cloth_infl += 1; // 0.6%
    }
    if (year >= 2034)
    {
        food_infl += 3;  // 1.4%
        gas_infl += 4;  // 1.8%
        cloth_infl += 2; // 0.8%
    }

    // Применяем инфляцию (цена * (1000 + ставка) / 1000)
    alice.food = alice.food * (1000 + food_infl) / 1000;
   
    alice.gas = alice.gas * (1000 + gas_infl) / 1000;
    
    alice.cloth = alice.cloth * (1000 + cloth_infl) / 1000;


    
    stas.food = stas.food * (1000 + food_infl) / 1000;
    
    stas.gas = stas.gas * (1000 + gas_infl) / 1000;
    
    stas.cloth = stas.cloth * (1000 + cloth_infl) / 1000;

   
}

//  Летний скачок цен на бензин 
void summer_gas_spike()
{
    alice.gas = alice.gas * 1020 / 1000;  // +2%
    stas.gas = stas.gas * 1020 / 1000;
}

//  Зимний скачок цен на еду 
void winter_food_spike()
{
    alice.food = alice.food * 1015 / 1000;  // +1.5%
    stas.food = stas.food * 1015 / 1000;
}


//  Мечты Алисы 

void alice_dream_check()
{
    if (!alice.has_iphone and alice.bank_account >= alice_dreams.iphone)
    {
        alice.bank_account -= alice_dreams.iphone;
        alice.has_iphone = true;
    }

    if (!alice.Baikal_trip and alice.bank_account >= alice_dreams.Baikal_trip)
    {
        alice.bank_account -= alice_dreams.Baikal_trip;
        alice.Baikal_trip = true;
    }

    if (!alice.Korea_trip and alice.bank_account >= alice_dreams.Korea_trip)
    {
        alice.bank_account -= alice_dreams.Korea_trip;
        alice.Korea_trip = true;
    }

    if (!alice.has_flat_Moscow and home.capital   >= alice_dreams.flat_Moscow)
    {
        home.capital -= alice_dreams.flat_Moscow;
        alice.has_flat_Moscow = true;
    }

    if (!alice.has_laptop and alice.bank_account >= alice_dreams.laptop)
    {
        alice.bank_account -= alice_dreams.laptop;
        alice.has_laptop = true;
    }
}


//  Мечты Стаса 

void stas_dream_check()
{
    if (!stas.has_new_car and stas.bank_account >= stas_dreams.new_car)
    {
        stas.bank_account -= stas_dreams.new_car;
        stas.has_new_car = true;
    }

    if (!stas.has_garage and stas.bank_account >= stas_dreams.garage)
    {
        stas.bank_account -= stas_dreams.garage;
        stas.has_garage = true;
    }
}


//  Семейные мечты 

void family_dream_check()
{

    if (!home.sea_trip and home.capital >= family_dreams.sea_trip)
    {
        home.capital -= family_dreams.sea_trip;
        home.sea_trip = true;
    }

    if (!home.London_trip and home.capital >= family_dreams.London_trip)
    {
        home.capital -= family_dreams.London_trip;
        home.London_trip = true;
    }

    if (!home.have_dacha and home.capital >= family_dreams.new_house)
    {
        home.capital -= family_dreams.new_house;
        home.have_dacha = true;
    }

    if (!home.Paris_trip and home.capital >= family_dreams.paris_trip)
    {
        home.capital -= family_dreams.paris_trip;
        home.Paris_trip = true;
    }

}


//  Дополнительные события 

void monthly_special(const int year, const int month)
{

    // 2026 год

    if (year == 2026 and month == 2)
    {
        alice.bank_account += 4'000;    // подарок на 14 февраля
        stas.bank_account -= 7'800;     // ужин
    }

    if (year == 2026 and month == 3)
    {
        stas.bank_account -= 6'000;    // техосмотр
        stas.bank_account -= 4'000;  // 8 марта подарок
    }

    if (year == 2026 and month == 4)
    {
        home.capital -= 5'000;    // коммуналка
    }

    if (year == 2026 and month == 5)
    {
        alice.bank_account += 10'000;  // премия
    }

    if (year == 2026 and month == 6)
    {
        stas.bank_account += 10'000;  // отпускные
        home.capital -= 30'000;   // отпуск
    }

    if (year == 2026 and month == 7)
    {
        alice.bank_account -= 3'500;  // страховка машины
        stas.bank_account -= 4'500;
    }

    if (year == 2026 and month == 8)
    {
        alice.bank_account -= 5'000;  // день рождения Стаса (подарок)
        stas.bank_account += 10'000;   // деньги в качестве подарка
    }

    if (year == 2026 and month == 9)
    {
        home.capital -= 14'000;   // подготовка к зиме
    }

    if (year == 2026 and month == 10)
    {
        stas.bank_account += 3'000;   // подработка
    }

    if (year == 2026 and month == 11)
    {
        alice.bank_account -= 2'800;  // стоматолог
        stas.bank_account -= 4'000;  // день рождения Алисы (подарок)
        alice.bank_account += 14'000;   // деньги в качестве подарка
    }

    if (year == 2026 and month == 12)
    {
        alice.bank_account += 25'000; // годовая премия
        stas.bank_account += 30'000;
        home.capital -= 55'000;  // Новый год: подарки, ёлка
    }


    // 2027

    if (year == 2027 and month == 1)
    {
        home.capital -= 7'500;   // выходные
    }

    if (year == 2027 and month == 2)
    {
        alice.bank_account += 3'000;  // повышение оклада
        alice.bank_account += 4'500;    // подарок на 14 февраля
        stas.bank_account -= 6'000;     // ужин
    }

    if (year == 2027 and month == 3)
    {
        stas.bank_account -= 8'000;  // 8 марта подарок
        home.capital -= 5'000;      //коммуналка
        stas.bank_account -= 9'000;    // техосмотр
        alice.bank_account -= 5'500;    // техосмотр
    }

    if (year == 2027 and month == 4)
    {
        stas.bank_account += 7'000;   // премия
    }

    if (year == 2027 and month == 5)
    {
        stas.bank_account -= 4'500;   // шиномонтаж
    }

    if (year == 2027 and month == 6)
    {
        home.capital -= 35'000;  // отпуск 
    }

    if (year == 2027 and month == 7)
    {
        alice.bank_account -= 20'000;     // ремонт машины
        stas.bank_account -= 25'000;
    }

    if (year == 2027 and month == 8)
    {
        stas.bank_account += 6'000;   // помощь родителей
        alice.bank_account -= 5'000;  // день рождения Стаса (подарок)
        stas.bank_account += 14'000;   // деньги в качестве подарка
    }

    if (year == 2027 and month == 9)
    {
        home.capital -= 14'000;   // подготовка к зиме
    }

    if (year == 2027 and month == 10)
    {
        home.capital -= 10'000;  // ремонт кухни
    }

    if (year == 2027 and month == 11)
    {
        alice.bank_account -= 4'200;  // страховка жизни
        stas.bank_account -= 5'100;
        stas.bank_account -= 5'000;  // день рождения Алисы (подарок)
        alice.bank_account += 14'000;   // деньги в качестве подарка
    }

    if (year == 2027 and month == 12)
    {
        stas.bank_account += 28'000;  // премия
        alice.bank_account += 27'000;
        home.capital -= 60'000;  // праздники
    }


    // 2028

    if (year == 2028 and month == 1)
    {
        home.capital -= 6'000;   // отопление
    }

    if (year == 2028 and month == 2)
    {
        stas.bank_account -= 12'000;  // лечение зубов
        alice.bank_account += 5'000;    // подарок на 14 февраля
        stas.bank_account -= 7'000;     // ужин
    }

    if (year == 2028 and month == 3)
    {
        alice.bank_account += 4'500;  // кэшбэк
        stas.bank_account += 3'800;
        stas.bank_account -= 4'000;  // 8 марта подарок
    }

    if (year == 2028 and month == 4)
    {
        alice.bank_account -= 9'200;  // налог на машину
        stas.bank_account -= 11'500;
    }

    if (year == 2028 and month == 5)
    {
        home.capital -= 2'500;   // дератизация
    }

    if (year == 2028 and month == 6)
    {
        alice.bank_account += 15'000; // премия

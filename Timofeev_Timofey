		//   симулятор
void life_simulation()
{

	int year = 2026;
	int month = 2;

	while (not (year == 2036 and month == 3))
	{


		alice_salary(year, month);
		stas_salary(year, month);
		tim_salary(year, month);


		alice_food();
		alice_gas();
		alice_cloth();
		alice_dream();

		stas_food();
		stas_rent();
		stas_cloth();
		stas_dream();


		tim_stipend();
		tim_cash();
		tim_food();
		tim_rent();
		tim_cloth();
		tim_dream();


		lisa_cash();
		lisa_stipend();
		lisa_school_food();
		lisa_cloth();
		lisa_section();
		lisa_dream();


	}
	++month;
	if (month == 13)
	{

		++year;
		month = 1;

	}
	
	print_family_status();

}



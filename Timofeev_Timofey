// зарплата алисы
void alice_salary(const int year, const int month)
{
	if (month == 6 and year == 2026)
	{
		alice.salary *= 6 / 5;
	}

	if (month == 6 and year == 2027)
	{
		alice.salary *= 6 / 5;
	}

	if (month == 6 and year == 2029)
	{
		alice.salary *= 8 / 5;
	}

	if (month == 2 and year == 2032)
	{
		alice.salary *= 7 / 5;
	}

	if (month == 2 and year == 2034)
	{
		alice.salary *= 6 / 5;
	}

	alice.capital += 40 / 100 * alice.salary;
	Family.capital += 60 / 100 * alice.salary;
}


// зарплата мужа
void stas_salary(const int year, const int month)
{
	if (month == 2 and year == 2027)
	{
		stas.salary *= 7 / 5;
	}

	if (month == 4 and year == 2029)
	{
		stas.salary *= 6 / 5;
	}

	if (month == 6 and year == 2030)
	{
		stas.salary *= 11 / 10;
	}

	if (month == 3 and year == 2033)
	{
		stas.salary *= 8 / 5;
	}

	if (month == 4 and year == 2035)
	{
		stas.salary *= 3 / 2;
	}

	stas.capital += 35 / 100 * stas.salary;
	Family.capital += 65 / 100 * stas.salary;
}


// зарплата сына
void tim_salary(const int year, const int month)
{
	if (month == 9 and year == 2028)
	{
		tim.salary *= 9 / 5;
	}

	if (month == 10 and year == 2029)
	{
		tim.salary *= 3 / 2;
	}

	if (month == 3 and year == 2032)
	{
		tim.salary *= 5 / 2;
	}

	if (month == 3 and year == 2035)
	{
		tim.salary *= 8 / 5;
	}

	if (month >= 6 and year >= 2029)
	{
		tim.capital += 75 / 100 * tim.salary;
		Family.capital += 25 / 100 * tim.salary;
	}
	else
	{
		tim.capital += tim.salary;
	}
}


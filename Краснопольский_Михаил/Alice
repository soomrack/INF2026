Percent food_inflation(const int year)
{
    switch (year) {
    case 2026: return 12.5f;
    case 2027: return 14.0f;
    case 2028: return 13.0f;
    case 2029: return 11.5f;
    case 2030: return 10.0f;
    default:   return  8.0f;
    }
}


Percent utilities_inflation(const int year)
{
    switch (year) {
    case 2026: return  8.0f;
    case 2027: return 10.0f;
    case 2028: return  9.0f;
    case 2029: return  8.5f;
    default:   return  7.0f;
    }
}


Percent services_inflation(const int year)
{
    switch (year) {
    case 2026: return  7.0f;
    case 2027: return  8.5f;
    case 2028: return  8.0f;
    case 2029: return  7.5f;
    case 2030: return  7.0f;
    default:   return  6.0f;
    }
}


void alice_salary(const int month, const int year)
{

    if (month == 1 && year > 2026)
        alice.base.salary = (RUB)(alice.base.salary * 1.10f);


    if (month == 9 && year == 2031) {
        alice.base.salary = (RUB)(alice.base.salary * 1.40f);
        printf("  [АЛИСА] Стала старшим менеджером! Зарплата: %lld руб/мес\n",
               alice.base.salary);
    }


    RUB ndfl = (RUB)(alice.base.salary * 0.13f);
    alice.base.bank.capital += alice.base.salary - ndfl;


    if (month == 12)
        alice.base.bank.capital += 30'000;
}



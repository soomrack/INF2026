void alice_mortgage(const int month, const int year)
{
    if (!alice.mortgage.is_active) return;


    RUB monthly_interest = (RUB)(alice.mortgage.debt
                               * (alice.mortgage.rate / 100.0f / 12.0f));
    RUB monthly_body     = alice.mortgage.monthly_payment - monthly_interest;


    if (alice.mortgage.debt <= alice.mortgage.monthly_payment) {
        RUB last_interest = (RUB)(alice.mortgage.debt
                                * (alice.mortgage.rate / 100.0f / 12.0f));
        alice.base.bank.capital      -= alice.mortgage.debt + last_interest;
        alice.mortgage.interest_paid += last_interest;
        alice.mortgage.body_paid     += alice.mortgage.debt;
        alice.mortgage.debt           = 0;
        alice.mortgage.is_active      = 0;
        printf("  [ИПОТЕКА] Полностью выплачена! %d/%d\n", month, year);
        return;
    }

    alice.base.bank.capital      -= alice.mortgage.monthly_payment;
    alice.mortgage.debt          -= monthly_body;
    alice.mortgage.interest_paid += monthly_interest;
    alice.mortgage.body_paid     += monthly_body;
}


void alice_repair_loan(const int month, const int year)
{
    if (!alice.repair_loan.is_active) return;

    RUB monthly_interest = (RUB)(alice.repair_loan.debt
                               * (alice.repair_loan.rate / 100.0f / 12.0f));
    RUB monthly_body     = alice.repair_loan.monthly_payment - monthly_interest;

    alice.repair_loan.total_interest_paid += monthly_interest;

    if (alice.repair_loan.debt <= alice.repair_loan.monthly_payment) {
        RUB last_int = (RUB)(alice.repair_loan.debt
                           * (alice.repair_loan.rate / 100.0f / 12.0f));
        alice.base.bank.capital              -= alice.repair_loan.debt + last_int;
        alice.repair_loan.total_interest_paid += last_int;
        alice.repair_loan.debt                = 0;
        alice.repair_loan.is_active           = 0;
        printf("  [КРЕДИТ РЕМОНТ] Выплачен в %d/%d! Переплата: %lld руб\n",
               month, year, alice.repair_loan.total_interest_paid);
        return;
    }

    alice.base.bank.capital   -= alice.repair_loan.monthly_payment;
    alice.repair_loan.debt    -= monthly_body;
    alice.repair_loan.months_paid++;
}


void alice_apartment_upgrade(const int month, const int year)
{

    static int done = 0;
    if (done) return;
    if (year != 2032 || month != 6) return;


    RUB sale_price    = 12'000'000;
    RUB debt_left     = alice.mortgage.debt;
    RUB net_from_sale = sale_price - debt_left;

    alice.base.bank.capital       += net_from_sale;
    alice.mortgage.debt            = 0;
    alice.mortgage.is_active       = 0;
    alice.mortgage.apartment_value = 0;


    RUB new_price = 15'000'000;
    RUB new_down  =  5'000'000;
    RUB new_debt  = 10'000'000;

    alice.base.bank.capital        -= new_down;
    alice.mortgage.apartment_value  = new_price;
    alice.mortgage.debt             = new_debt;
    alice.mortgage.monthly_payment  = 130'000;
    alice.mortgage.rate             = 16.0f;
    alice.mortgage.is_active        = 1;

    done = 1;
    printf("  [АЛИСА] Продала квартиру за %lld руб. Купила новую за %lld руб.\n",
           sale_price, new_price);
    printf("  [АЛИСА] Чистая выгода от продажи: %lld руб\n", net_from_sale);
}


void alice_tax_deduction(const int month, const int year)
{
    if (month != 4) return;
    if (year == 2026) return;

    RUB refund = 0;


    if (alice.tax_deduction.property_refund_left > 0) {
        RUB ndfl_per_year = (RUB)(alice.base.salary * 0.13f * 12);
        RUB piece         = ndfl_per_year;
        if (piece > alice.tax_deduction.property_refund_left)
            piece = alice.tax_deduction.property_refund_left;

        alice.tax_deduction.property_refund_left -= piece;
        refund += piece;
    }


    int years_paid = year - 2026;
    if (years_paid < 1) years_paid = 1;
    RUB interest_per_year = alice.mortgage.interest_paid / years_paid;
    RUB interest_refund   = (RUB)(interest_per_year * 0.13f);



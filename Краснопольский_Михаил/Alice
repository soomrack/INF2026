                               * (bob.consumer_loan.rate / 100.0f / 12.0f));
    RUB monthly_body     = bob.consumer_loan.monthly_payment - monthly_interest;

    bob.consumer_loan.total_interest_paid += monthly_interest;

    if (bob.consumer_loan.debt <= bob.consumer_loan.monthly_payment) {
        RUB last_int = (RUB)(bob.consumer_loan.debt
                           * (bob.consumer_loan.rate / 100.0f / 12.0f));
        bob.base.bank.capital                 -= bob.consumer_loan.debt + last_int;
        bob.consumer_loan.total_interest_paid += last_int;
        bob.consumer_loan.debt                = 0;
        bob.consumer_loan.is_active           = 0;
        printf("  [КРЕДИТ БОБ] Потребительский выплачен в %d/%d! Переплата: %lld руб\n",
               month, year, bob.consumer_loan.total_interest_paid);
        return;
    }

    bob.base.bank.capital  -= bob.consumer_loan.monthly_payment;
    bob.consumer_loan.debt -= monthly_body;
    bob.consumer_loan.months_paid++;
}



{
    int month = 2;
    int year  = 2026;

    while (!(month == 2 && year == 2028)) {


        alice_salary(month, year);
        alice_rent_income(month, year);
        alice_deposit_interest();
        alice_mortgage(month, year);
        alice_repair_loan(month, year);
        alice_tax_deduction(month, year);
        alice_apartment_upgrade(month, year);
        alice_food(month, year);
        alice_utilities(month, year);
        alice_car(month);
        alice_car_depreciation(month);
        alice_cat(month, year);
        alice_other_expenses(month, year);
        alice_education(month, year);
        alice_health(month, year);
        alice_subscriptions(month, year);
        alice_insurance(month, year);
        alice_phone_and_internet(month, year);
        alice_apartment_upkeep(month, year);
        alice_professional_development(month, year);
        alice_social_expenses(month, year);
        alice_pension_contribute();
        alice_deposit(month);
        alice_healthy_food_simulate(month, year);
        alice_pvz_simulate(month, year);


        bob_salary(month, year);
        bob_deposit_interest();
        bob_relocation(month, year);
        bob_rent(month, year);
        bob_food(month, year);
        bob_car(month, year);
        bob_car_depreciation(month, year);
        bob_other_expenses(month, year);
        bob_education(month, year);
        bob_health(month, year);
        bob_subscriptions(month, year);
        bob_insurance(month, year);
        bob_phone_and_gadgets(month, year);
        bob_rental_extras(month, year);
        bob_professional_development(month, year);
        bob_social_expenses(month, year);
        bob_pension_contribute(year);
        bob_consumer_loan_take(month, year);
        bob_consumer_loan_pay(month, year);
        bob_car_upgrade_loan_take(month, year);
        bob_car_upgrade_loan_pay(month, year);
        bob_late_mortgage(month, year);
        bob_freelance_simulate(month, year);
        bob_saas_simulate(month, year);
        bob_invest(year);
        bob_emergency_fund();


        if (month == 12)
            print_year_results(year);

        ++month;
        if (month == 13) {
            month = 1;
            ++year;
        }
    }
}



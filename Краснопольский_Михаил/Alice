    alice.base.bank.capital -= alice.subscriptions.barbershop;


    if (month == 3 || month == 6 || month == 9 || month == 12)
        alice.base.bank.capital -= alice.subscriptions.books;


    if (year >= 2030 && alice.pvz.is_open)
        alice.base.bank.capital += alice.subscriptions.pvz_leisure_saved;
}


void bob_subscriptions(const int month, const int year)
{
    if (month == 1 && year > 2026) {
        Percent infl = services_inflation(year) / 100.0f;
        bob.subscriptions.streaming_video = (RUB)(bob.subscriptions.streaming_video * (1.0f + infl));
        bob.subscriptions.streaming_music = (RUB)(bob.subscriptions.streaming_music * (1.0f + infl));
        bob.subscriptions.restaurants     = (RUB)(bob.subscriptions.restaurants     * (1.0f + infl));
        bob.subscriptions.hobby           = (RUB)(bob.subscriptions.hobby           * (1.0f + infl));
        bob.subscriptions.barbershop      = (RUB)(bob.subscriptions.barbershop      * (1.0f + infl));
        bob.subscriptions.pro_tools       = (RUB)(bob.subscriptions.pro_tools       * (1.0f + infl));
        bob.subscriptions.gaming          = (RUB)(bob.subscriptions.gaming          * (1.0f + infl));
    }

    bob.base.bank.capital -= bob.subscriptions.streaming_video;
    bob.base.bank.capital -= bob.subscriptions.streaming_music;
    bob.base.bank.capital -= bob.subscriptions.pro_tools;
    bob.base.bank.capital -= bob.subscriptions.hobby;
    bob.base.bank.capital -= bob.subscriptions.barbershop;
    bob.base.bank.capital -= bob.subscriptions.gaming;


    if (year < 2032)
        bob.base.bank.capital -= bob.subscriptions.restaurants;
    else
        bob.base.bank.capital -= bob.subscriptions.restaurants
                                - bob.subscriptions.restaurants_saved;


    if (year == 2031 && month == 6) {
        bob.base.bank.capital -= bob.subscriptions.gaming_pc;
        printf("  [БОБ] Купил игровой ПК за %lld руб!\n",
               bob.subscriptions.gaming_pc);
    }
}


void alice_insurance(const int month, const int year)
{

    if (month == 1)
        alice.base.bank.capital -= alice.insurance.life_insurance;


    if (month == 2)
        alice.base.bank.capital -= alice.insurance.dms;


    if (month == 3 && alice.mortgage.is_active)
        alice.base.bank.capital -= alice.insurance.property;


    if (year >= 2031 && month == 6)
        alice.base.bank.capital -= alice.insurance.life_insurance_extra;
}


void bob_insurance(const int month, const int year)
{

    if (year >= 2029 && month == 3)
        bob.base.bank.capital -= bob.insurance.dms;


    if (year >= 2032 && month == 1)
        bob.base.bank.capital -= bob.insurance.life_insurance;


    if (year >= 2035 && month == 3)
        bob.base.bank.capital -= bob.insurance.property_after_buy;
}


void alice_pension_contribute()
{
    RUB contribution = (RUB)(alice.base.salary * 0.05f);

    alice.base.bank.capital   -= contribution;
    alice_pension.accumulated += contribution;
    alice_pension.total_paid  += contribution;

    alice_pension.accumulated += (RUB)(alice_pension.accumulated
                               * (alice_pension.annual_return / 100.0f / 12.0f));
}


void bob_pension_contribute(const int year)
{

    if (year < 2028) return;

    RUB contribution = (RUB)(bob.base.salary * 0.04f);

    bob.base.bank.capital   -= contribution;
    bob_pension.accumulated += contribution;
    bob_pension.total_paid  += contribution;

    bob_pension.accumulated += (RUB)(bob_pension.accumulated
                             * (bob_pension.annual_return / 100.0f / 12.0f));
}


void alice_car_depreciation(const int month)
{
    if (month != 12) return;


    alice.base.car.value = (RUB)(alice.base.car.value * 0.90f);
}


void bob_car_depreciation(const int month, const int year)
{
    if (month != 12) return;
    if (bob.base.car.value == 0) return;


    if (year < 2033)
        bob.base.car.value = (RUB)(bob.base.car.value * 0.88f);
    else
        bob.base.car.value = (RUB)(bob.base.car.value * 0.90f);
}


void pay_phone_expenses(RUB *capital, const Gadgets *gadgets,
                        const int month, const int year,
                        const int phone_month,
                        const int phone_years[], const int phone_years_count)
{
    *capital -= gadgets->mobile_extra;

    for (int i = 0; i < phone_years_count; ++i) {
        if (month == phone_month && year == phone_years[i]) {
            *capital -= gadgets->phone_price;
            break;
        }
    }
}


void alice_phone_and_internet(const int month, const int year)
{
    const int alice_phone_years[]     = {2027, 2030, 2033, 2036, 2039};
    const int alice_phone_years_count = 5;

    pay_phone_expenses(&alice.base.bank.capital, &alice.gadgets,
                       month, year,
                       9, alice_phone_years, alice_phone_years_count);
}


void bob_phone_and_gadgets(const int month, const int year)
{
    const int bob_phone_years[]     = {2027, 2029, 2031, 2033, 2035, 2037, 2039};
    const int bob_phone_years_count = 7;

    pay_phone_expenses(&bob.base.bank.capital, &bob.gadgets,
                       month, year,
                       10, bob_phone_years, bob_phone_years_count);


    if (month == 3 && (year == 2026 || year == 2030 || year == 2034 || year == 2038))
        bob.base.bank.capital -= bob.gadgets.laptop_price;
}



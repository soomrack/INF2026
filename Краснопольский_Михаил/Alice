RUB alice_net_worth()
{
    return alice.base.bank.capital
         + alice.base.bank.deposit
         + alice.mortgage.apartment_value
         - alice.mortgage.debt
         + alice.base.car.value
         + alice_pension.accumulated;
}


RUB bob_net_worth()
{
    return bob.base.bank.capital
         + bob.base.bank.deposit
         + bob.investments.portfolio
         + bob.base.car.value
         + bob_pension.accumulated;
}



struct Person alice;


int calculate_stress_level(const int stress_points)
{
    if (stress_points >= 20) return 5;
    if (stress_points >= 10) return 4;
    if (stress_points >=  0) return 3;
    if (stress_points >= -10) return 2;
    return 1;
}

const char* stress_level_name(const int stress_level)
{
    switch (stress_level) {
    case 5: return "Отличное";
    case 4: return "Хорошее";
    case 3: return "Нормальное";
    case 2: return "Плохое";
    default: return "Ужасное";
    }
}

RUB calculate_total_capital()
{
    RUB bank_rub_value         = alice.vtb.account_rub;
    RUB bank_usd_value_in_rub  = (RUB)(alice.vtb.account_usd * alice.vtb.exchange_rate_usd_to_rub);
    RUB car_current_value      = alice.car.value;
    RUB mortgage_net_equity    = alice.mortgage.apartment_value - alice.mortgage.remaining_loan_balance;
    RUB rental_apartment_value = alice.rental_apartment.is_owned ? alice.rental_apartment.apartment_value : 0;

    return bank_rub_value
         + bank_usd_value_in_rub
         + car_current_value
         + mortgage_net_equity
         + rental_apartment_value;
}


void alice_init()
{
    alice.vtb.exchange_rate_usd_to_rub = 78.76;
    alice.vtb.account_rub              = 0;
    alice.vtb.account_usd              = 1'000;

    alice.monthly_salary        = 180'000;
    alice.monthly_food_expenses = 3'000;

    alice.car.value             = 2'400'000;
    alice.car.monthly_fuel_cost = 15'000;
    alice.car.is_owned          = true;

    alice.cat.monthly_food_and_filler_cost = 4'500;

    alice.freelance.minimum_order_income = 20'000;
    alice.freelance.maximum_order_income = 80'000;

    alice.vacation.vacation_month           = 8;
    alice.vacation.total_spent_on_vacations = 0;

    alice.stress.stress_points = 0;
    alice.stress.stress_level  = 3;

    alice.mortgage.apartment_value        = 8'000'000;
    alice.mortgage.remaining_loan_balance = 6'400'000;
    alice.mortgage.fixed_monthly_payment  = 89'000;
    alice.mortgage.annual_interest_rate   = 16.0;

    alice.rental_apartment.apartment_value                   = 6'000'000;
    alice.rental_apartment.monthly_rent_price                = 50'000;
    alice.rental_apartment.is_owned                          = true;
    alice.rental_apartment.is_currently_occupied             = true;
    alice.rental_apartment.months_current_tenants_have_lived = 0;
    alice.rental_apartment.minimum_tenant_stay_months        = 4;
}


void alice_food(const int month, const int year)
{
    if (month == 12) {
        alice.vtb.account_rub -= 2'000;
    }

    Percent annual_inflation = 12.0;
    switch (year) {
    case 2026: annual_inflation = 12.5; break;
    case 2027: annual_inflation = 14.0; break;
    case 2028: annual_inflation = 13.0; break;
    case 2029: annual_inflation = 11.5; break;
    }

    alice.monthly_food_expenses +=
        (RUB)(alice.monthly_food_expenses * (annual_inflation / 100.0 / 12.0));
    alice.vtb.account_rub -= alice.monthly_food_expenses;
}


void alice_cat(const int year)
{
    Percent annual_inflation = 12.0;
    switch (year) {
    case 2026: annual_inflation = 12.5; break;
    case 2027: annual_inflation = 14.0; break;
    case 2028: annual_inflation = 13.0; break;
    case 2029: annual_inflation = 11.5; break;
    }

    alice.cat.monthly_food_and_filler_cost +=
        (RUB)(alice.cat.monthly_food_and_filler_cost * (annual_inflation / 100.0 / 12.0));
    alice.vtb.account_rub -= alice.cat.monthly_food_and_filler_cost;
}


void alice_salary(const int month, const int year)
{
    if (month == 1) {
        Percent annual_inflation = 12.0;
        switch (year) {
        case 2026: annual_inflation = 12.5; break;
        case 2027: annual_inflation = 14.0; break;
        case 2028: annual_inflation = 13.0; break;
        case 2029: annual_inflation = 11.5; break;
        }
        alice.monthly_salary = (RUB)(alice.monthly_salary * (1.0 + annual_inflation / 100.0));
    }

    if (month == 3) {
        alice.monthly_salary = (RUB)(alice.monthly_salary * 1.5);
    }

    if (month == 2 && year == 2026) {
        alice.vtb.account_rub += 5'000;
    }

    alice.vtb.account_rub += alice.monthly_salary;
}


void alice_car_expenses()
{
    if (!alice.car.is_owned) {
        return;
    }
    alice.vtb.account_rub -= alice.car.monthly_fuel_cost;
}


void alice_mortgage()
{
    if (alice.mortgage.remaining_loan_balance == 0) {
        return;
    }

    float monthly_interest_rate = alice.mortgage.annual_interest_rate / 100.0f / 12.0f;

    RUB interest_portion  = (RUB)(alice.mortgage.remaining_loan_balance * monthly_interest_rate);
    RUB principal_portion = alice.mortgage.fixed_monthly_payment - interest_portion;

    bool final_payment = (alice.mortgage.remaining_loan_balance + interest_portion) < alice.mortgage.fixed_monthly_payment;

    if (final_payment) {
        RUB actual_payment = alice.mortgage.remaining_loan_balance + interest_portion;
        alice.vtb.account_rub -= actual_payment;
        alice.mortgage.remaining_loan_balance = 0;
    } else {
        alice.vtb.account_rub -= alice.mortgage.fixed_monthly_payment;
        alice.mortgage.remaining_loan_balance -= principal_portion;
    }
}


void alice_freelance(const int month, const int year)
{
    int order_arrived = next_cyclic_value(freelance_order_arrival_cycler);
    if (!order_arrived) {
        return;
    }

    RUB freelance_income = (RUB)next_cyclic_value(freelance_order_amount_cycler);

    alice.vtb.account_rub += freelance_income;
    printf("  [%02d/%d] Фриланс: заказ выполнен, доход = %lld руб.\n",
        month, year, freelance_income);
}


void alice_sell_car(const int month, const int year)
{
    alice.vtb.account_rub += alice.car.value;
    alice.car.value             = 0;
    alice.car.monthly_fuel_cost = 0;
    alice.car.is_owned          = false;
    printf("  [%02d/%d] Машина продана.\n", month, year);
}


void alice_vacation(const int month, const int year)
{
    if (month != alice.vacation.vacation_month) {
        return;
    }

    RUB total_capital_this_year = calculate_total_capital();
    RUB vacation_cost           = total_capital_this_year / 10;

    if (alice.vtb.account_rub < vacation_cost && alice.car.is_owned) {
        printf("  [%02d/%d] Отпуск: рублей недостаточно (%lld руб.), продаёт машину за %lld руб.\n",
            month, year, alice.vtb.account_rub, alice.car.value);
        alice_sell_car(month, year);
    }

    if (vacation_cost > alice.vtb.account_rub) {
        vacation_cost = alice.vtb.account_rub > 0 ? alice.vtb.account_rub : 0;
    }

    alice.vtb.account_rub                   -= vacation_cost;
    alice.vacation.total_spent_on_vacations += vacation_cost;

        month, year, total_capital_this_year, vacation_cost);
}


void alice_stress(const int month, const int year)
{
    int event_is_positive = next_cyclic_value(stress_event_is_positive_cycler);

    const char* event_description = "";
    int points_change = 0;

    if (event_is_positive) {
        int event_index   = next_cyclic_value(stress_positive_event_index_cycler);
        event_description = POSITIVE_STRESS_EVENTS[event_index];
        points_change     = +5;
    } else {
        int event_index   = next_cyclic_value(stress_negative_event_index_cycler);
        event_description = NEGATIVE_STRESS_EVENTS[event_index];
        points_change     = -5;
    }

    alice.stress.stress_points += points_change;
    alice.stress.stress_level   = calculate_stress_level(alice.stress.stress_points);

    printf("  [%02d/%d] Стресс (%+d): %s → очки: %d, уровень: %s\n",
        month, year,
        points_change,
        event_description,
        alice.stress.stress_points,
        stress_level_name(alice.stress.stress_level));
}


void alice_rental_apartment(const int month, const int year)
{
    RentalApartment& apartment = alice.rental_apartment;

    if (!apartment.is_owned) {
        return;
    }

    Percent annual_inflation = 12.0;
    switch (year) {
    case 2026: annual_inflation = 12.5; break;
    case 2027: annual_inflation = 14.0; break;
    case 2028: annual_inflation = 13.0; break;
    case 2029: annual_inflation = 11.5; break;
    }
    apartment.monthly_rent_price +=
        (RUB)(apartment.monthly_rent_price * (annual_inflation / 100.0 / 12.0));

    if (apartment.is_currently_occupied) {

        alice.vtb.account_rub += apartment.monthly_rent_price;
        apartment.months_current_tenants_have_lived += 1;

        bool tenants_have_completed_minimum_stay =
            apartment.months_current_tenants_have_lived >= apartment.minimum_tenant_stay_months;

        if (tenants_have_completed_minimum_stay) {
            int tenants_move_out = next_cyclic_value(rental_tenants_move_out_cycler);

            if (tenants_move_out) {
                printf("  [%02d/%d] Аренда: жильцы съехали после %d месяцев.\n",
                    month, year,
                    apartment.months_current_tenants_have_lived);

                apartment.is_currently_occupied             = false;
                apartment.months_current_tenants_have_lived = 0;
            }
        }

    } else {

        int new_tenants_found = next_cyclic_value(rental_new_tenants_found_cycler);

        if (new_tenants_found) {
            apartment.is_currently_occupied             = true;
            apartment.months_current_tenants_have_lived = 0;
            printf("  [%02d/%d] Аренда: новые жильцы въехали.\n", month, year);
        } else {
            printf("  [%02d/%d] Аренда: квартира пустует — дохода нет.\n", month, year);
        }
    }
}


void alice_sell_car_if_balance_is_negative(const int month, const int year)
{
    if (alice.vtb.account_rub < 0 && alice.car.is_owned) {
        printf("  [%02d/%d] ЭКСТРЕННО: баланс = %lld руб. — продаёт машину за %lld руб.\n",
            month, year,
            alice.vtb.account_rub,
            alice.car.value);
        alice_sell_car(month, year);
        printf("  [%02d/%d] Баланс после продажи = %lld руб.\n",
            month, year,
            alice.vtb.account_rub);
    }
}


void print_results()
{
    printf("\nИтоги\n");
    printf("Зарплата в месяц           = %lld руб.\n", alice.monthly_salary);

    RUB bank_rub_value         = alice.vtb.account_rub;
    RUB bank_usd_value_in_rub  = (RUB)(alice.vtb.account_usd * alice.vtb.exchange_rate_usd_to_rub);
    RUB car_current_value      = alice.car.value;
    RUB mortgage_net_equity    = alice.mortgage.apartment_value - alice.mortgage.remaining_loan_balance;
    RUB rental_apartment_value = alice.rental_apartment.apartment_value;

    RUB total_capital =
        bank_rub_value         +
        bank_usd_value_in_rub  +
        car_current_value      +
        mortgage_net_equity    +
        rental_apartment_value;

    printf("\nКапитал\n");
    printf("Счёт (руб.)                = %lld руб.\n", bank_rub_value);
    printf("Счёт (USD)                 = %lld USD  =  %lld руб.\n",
        alice.vtb.account_usd, bank_usd_value_in_rub);

    if (alice.car.is_owned) {
        printf("Стоимость машины           = %lld руб.\n", car_current_value);
    } else {
        printf("Стоимость машины           = продана (0 руб.)\n");
    }

    printf("Остаток долга по ипотеке   = %lld руб.\n", alice.mortgage.remaining_loan_balance);
    if (alice.rental_apartment.is_owned) {
        printf("Арендная квартира          = %lld руб.\n", rental_apartment_value);
    } else {
        printf("Арендная квартира          = продана (0 руб.)\n");
    }
    printf("Потрачено на отпуск        = %lld руб.\n", alice.vacation.total_spent_on_vacations);
    printf("\n");
    printf("Итоговый капитал           = %lld руб.\n", total_capital);

    printf("\nСтресс\n");
    printf("Очки стресса               = %d\n", alice.stress.stress_points);
    printf("Уровень стресса            = %d / 5 (%s)\n",
        alice.stress.stress_level,
        stress_level_name(alice.stress.stress_level));
    printf("\n");
}


void simulation()
{
    int year  = 2026;
    int month = 2;

    printf("Симуляция: февраль 2026 -> февраль 2027\n");

    while (!(year == 2027 && month == 2)) {

        alice_salary(month, year);
        alice_freelance(month, year);
        alice_car_expenses();
        alice_food(month, year);
        alice_cat(year);
        alice_mortgage();
        alice_rental_apartment(month, year);
        alice_vacation(month, year);
        alice_stress(month, year);

        alice_sell_car_if_balance_is_negative(month, year);

        ++month;
        if (month == 13) {
            ++year;
            month = 1;
        }
    }
}


int main()
{
    alice_init();
    simulation();
    print_results();

    return 0;
}

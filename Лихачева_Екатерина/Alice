void alice_telephon(const int month)
{
    Alice.sber.account -= Alice.telephon.connection;
    Alice.telephon.connection *= (1.0 + 0.06 / 12); 

    if (month == 12){
        Alice.telephon.years++;
        Alice.telephon.cost *= 0.9;

        if (Alice.telephon.years == 3) {
            Alice.sber.account += Alice.telephon.cost;

            Alice.telephon.cost = 100'000;
            if (Alice.sber.account >= Alice.telephon.cost) {
                Alice.sber.account -= Alice.telephon.cost;            
            }
            else {
                Alice.sber.account += Alice.telephon.cost - Alice.sber.account;
                Alice.sber.account -= Alice.telephon.cost;
            };

            Alice.telephon.years = 0;

        };
    };

}


void alice_car(const int month)
{
    Alice.sber.account -= Alice.car.gas;
    Alice.car.gas *= (1.0 + 0.06 / 12);

    if (month == 12){
        Alice.car.years++;

        if (Alice.car.years <= 3) {
            Alice.car.value *= 1.07;
        }
        else {
            Alice.car.value *= 0.9;
        };

        if (Alice.car.years == 7){
            Alice.sber.account += Alice.car.value;

            Alice.car.value = 2'400'000;
            if (Alice.sber.account >= Alice.car.value) {
                Alice.sber.account -= Alice.car.value;            
            }
            else {
                Alice.sber.account += Alice.car.value - Alice.sber.account;
                Alice.sber.account -= Alice.car.value;
            };

            Alice.car.years = 0;
        };
    };
}



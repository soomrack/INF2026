struct Person Alice;


void alice_casino()
{
    Alice.casino.taxes = 0.13;
    Alice.casino.bet *= 1.06;

    Alice.casino.attempts = 10;

    if (Alice.sber.deposit >= Alice.casino.bet * Alice.casino.attempts){
        Alice.sber.account += Alice.casino.bet * Alice.casino.attempts;
        Alice.sber.deposit -= Alice.casino.bet * Alice.casino.attempts;

        for (int attempt = 0; attempt < Alice.casino.attempts; attempt++){
            Alice.casino.person_number = rand() % 10;
            Alice.casino.casino_number = rand() % 10;

            if (Alice.casino.person_number == Alice.casino.casino_number){
                Alice.casino.winning = Alice.casino.bet - (Alice.casino.bet * Alice.casino.taxes);
                Alice.sber.account += Alice.casino.winning;
            }
            else {
                Alice.sber.account -= Alice.casino.bet;
            };
        }
    }

}


void alice_income(const int month, const int year) 
{ 
    Alice.sber.account += Alice.sber.rent;

    if ((month == 12)){
        Alice.sber.salary *= 1.07;
        Alice.sber.rent *= 1.07;

        Alice.real_estate.apartment1 *= 1.07;
        Alice.real_estate.apartment2 *= 1.07;
        Alice.real_estate.apartment3 *= 1.07;
        Alice.real_estate.villa *= 1.07;
    };

    if ((month == 8) && (year == 2026)) { 
        Alice.sber.salary *= 1.05; 
    } 

    Alice.sber.account += Alice.sber.salary;
}


void alice_deposit()
{
    Alice.sber.deposit += Alice.sber.deposit * (Alice.sber.interest_rate / 12.0 / 100.0);

    RUB transfer_amount;
    RUB balance_amount;

    transfer_amount = Alice.sber.account - (Alice.sber.account * 0.4);
    balance_amount = Alice.sber.account * 0.4;

    Alice.sber.deposit += transfer_amount;
    Alice.sber.account = balance_amount;
}


void alice_capital() 
{
    Alice.capital += Alice.car.value; 
    Alice.capital += Alice.real_estate.apartment1;
    Alice.capital += Alice.real_estate.apartment2;
    Alice.capital += Alice.real_estate.apartment3;
    Alice.capital += Alice.real_estate.villa;
}


void utility_bills()
{
    Alice.sber.deposit -= Alice.utility_bills.apartment1;
    Alice.utility_bills.apartment1 *= (1.0 + 0.06 / 12);

    Alice.sber.deposit -= Alice.utility_bills.apartment2;
    Alice.utility_bills.apartment2 *= (1.0 + 0.06 / 12);

    Alice.sber.deposit -= Alice.utility_bills.apartment3;
    Alice.utility_bills.apartment3 *= (1.0 + 0.06 / 12);

    Alice.sber.deposit -= Alice.utility_bills.villa;
    Alice.utility_bills.villa *= (1.0 + 0.06 / 12);
}


void print_result() 
{ 
    printf("Salary = %lld\n", Alice.sber.salary);
    printf("Capital = %lld\n", Alice.capital);
    printf("Deposit = %lld\n", Alice.sber.deposit);
    printf("Account = %lld", Alice.sber.account);
}


void alice_vacation()
{
    Alice.vacation.cost *= 1.07;

    if (Alice.sber.deposit >= Alice.vacation.cost){
        Alice.sber.account += Alice.vacation.cost;
        Alice.sber.deposit -= Alice.vacation.cost;

        Alice.sber.account -= Alice.vacation.concerts;
        Alice.vacation.concerts *= (1.0 + 0.06 / 12);

        Alice.sber.account -= Alice.vacation.cruises;
        Alice.vacation.cruises *= (1.0 + 0.06 / 12);

        Alice.sber.account -=  Alice.vacation.excursions;
        Alice.vacation.excursions *= (1.0 + 0.06 / 12);

        Alice.sber.account -= Alice.vacation.hotel;
        Alice.vacation.hotel *= (1.0 + 0.06 / 12);

        Alice.sber.account -= Alice.vacation.restaurants;
        Alice.vacation.restaurants *= (1.0 + 0.06 / 12);

        Alice.sber.account -= Alice.vacation.souvenirs;
        Alice.vacation.souvenirs *= (1.0 + 0.06 / 12);

        Alice.sber.account -= Alice.vacation.tickets;
        Alice.vacation.tickets *= (1.0 + 0.06 / 12);
    }
}



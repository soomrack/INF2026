void simulation() 
{
    
    int month = 2;
    int year = 2026;

    while ( !((month == 3) && (year == 2057)) ) {
        month++;

        alice_income(month, year);

        alice_mall();
        alice_cat();
        alice_food();
        alice_car();
        alice_fitness();

        alice_deposit();

        if (month == 12) {
            alice_vacation();
            alice_casino();       
        }

        if (month == 12) {
            month = 1;
            ++year;
        }
    }

    alice_capital();
}




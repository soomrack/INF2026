    void simulation_alice()
    {
        int month = 2;
        int year = 2026;

        while (not (month == 3 and year == 2028)) {

            start_alice_study();  // начать обучение
            alice_salary(month, year);
            alice_freelance(month, year);
            alice_food();
            alice_car();
            alice_communication();
            pay_alice_entertainment();
            alice_shopping();
            alice_medical();
            alice_fine();
            alice_gifts();
            alice_repairs();
            alice_dog_price();
            alice_books();
            alice_deposite(month, year);

            if (month == 7) {
                pay_travel_expenses();
            }
            ++month;
            if (month == 13) {
                ++year;
                month = 1;
            }
        }
    }



void pet_expenses()
{
    for (auto& p : pets.pets)
    {
        if (!p.alive) continue;

        RUB cost = 1000;
        if (p.type == DOG) cost = 3000;
        if (p.type == HAMSTER) cost = 500;
        if (p.type == PARROT) cost = 1500;
        if (p.type == RABBIT) cost = 1200;
        if (p.type == TURTLE) cost = 800;

        if (rand() % 100 < 10)
            cost += 2000 + rand() % 5000;

        sell_assets(cost);
        alice.vtb.account_rub -= cost;
        alice.total_expenses += cost;
        pets.total_spent += cost;
        romance.romance_stats.spent_on_pets += cost;
    }
}



void pet_health(Pet& p)
{
    if (!p.alive) return;

    int age_years = p.age_months / 12;
    int chance = age_years * 2;

    if (rand() % 100 < chance)
    {
        RUB cost = 3000 + rand() % 7000;
        sell_assets(cost);
        alice.vtb.account_rub -= cost;
        alice.total_expenses += cost;
        pets.total_spent += cost;
        romance.romance_stats.spent_on_pets += cost;
    }
}



void pet_death_logic(Pet& p)
{
    if (!p.alive) return;

    int avg = 60;
    if (p.type == DOG) avg = 120;
    if (p.type == HAMSTER) avg = 36;
    if (p.type == PARROT) avg = 180;
    if (p.type == RABBIT) avg = 72;
    if (p.type == TURTLE) avg = 300;

    if (p.age_months < avg) return;

    if (rand() % 100 < p.death_chance)
    {
        p.lives--;
        p.death_chance = 1;

        if (p.lives <= 0)
        {
            p.alive = false;
            pets.died++;
            pets.grieving = true;
            pets.grief_left = p.grief_weight / 2;
            pets.grief_months_total += p.grief_weight / 2;
        }
    }
    else
        p.death_chance += 2;
}



void pets_update()
{
    for (auto& p : pets.pets)
    {
        if (!p.alive) continue;
        p.age_months++;
        pet_health(p);
        pet_death_logic(p);
    }
    pet_expenses();
}



bool pets_block_freelance()
{
    return pets.grieving;
}



Percent pets_food_multiplier()
{
    return pets.grieving ? 1.2 : 1.0;
}



void grief_update()
{
    if (!pets.grieving) return;

    pets.grief_left--;
    if (pets.grief_left <= 0)
    {
        pets.grieving = false;
        pets.adopt_chance = 8;
    }
}



bool can_afford_pet(RUB cost)
{
    RUB current_cash = alice.vtb.account_rub + alice.vtb.account_usd * economy.rate_usd_rub +
                        alice.vtb.deposit.capital + alice.vtb.stocks.capital;
    return current_cash >= cost + 50000;
}



void pets_try_adopt()
{
    if (pets.grieving) return;
    
    int alive_count = 0;
    for (auto& p : pets.pets)
        if (p.alive) alive_count++;
    
    if (alive_count >= 3) return;

    if (pets.adopt_cooldown > 0)
    {
        pets.adopt_cooldown--;
        return;
    }

    Percent chance = pets.adopt_chance;
    if (alive_count == 0)
        chance *= 2;
    else if (alive_count == 1)
        chance *= 1.5;

    if (rand() % 100 < chance)
    {
        RUB cost = 2000;
        if (!can_afford_pet(cost)) return;

        PetType t = (PetType)(rand() % 6);
        pets.pets.push_back(create_pet(t));
        pets.adopted++;
        pets.adopt_chance = 8;
        pets.adopt_cooldown = 6 + rand() % 12;
    }
    else
    {
        if (rand() % 8 == 0)
            pets.adopt_chance += 2;
    }
}




std::string get_pet_name(PetType t)
{
    if (t == CAT) return cat_names[rand() % 10];
    if (t == DOG) return dog_names[rand() % 10];
    if (t == HAMSTER) return hamster_names[rand() % 10];
    if (t == PARROT) return parrot_names[rand() % 10];
    if (t == RABBIT) return rabbit_names[rand() % 10];
    return turtle_names[rand() % 10];

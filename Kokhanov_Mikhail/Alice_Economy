void pets_init()
{
    pets.adopted = 0;
    pets.died = 0;
    pets.total_spent = 0;
    pets.grief_months_total = 0;
    pets.grieving = false;
    pets.grief_left = 0;
    pets.adopt_chance = 8;
    pets.adopt_cooldown = 0;

    int initial_pets = rand() % 3;
    for (int i = 0; i < initial_pets; i++)
    {
        PetType start = (PetType)(rand() % 6);
        pets.pets.push_back(create_pet(start));
        pets.adopted++;
    }
    
    if (pets.pets.empty())
    {
        PetType start = (PetType)(rand() % 6);
        pets.pets.push_back(create_pet(start));
        pets.adopted = 1;
    }

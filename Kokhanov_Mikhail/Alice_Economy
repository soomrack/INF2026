void handle_divorce()
{
    if (romance.status != MARRIED) return;

    bool partner_had_housing_before = romance.partner.housing_counted;
    
    if (partner_had_housing_before)
    {
        remove_partner_housing();
    }
    
    RUB partner_housing_value = 0;
    if (partner_had_housing_before)
    {
        partner_housing_value = alice.estate.flat_price;
    }
    
    RUB alice_assets = alice.total_capital;
    RUB partner_common = romance.partner.money + romance.partner.deposit + romance.partner.stocks;
    
    if (partner_had_housing_before)
    {
        alice_assets -= partner_housing_value;
    }
    
    RUB total_common = alice_assets + partner_common;
    RUB half = total_common / 2;
    
    if (alice_assets > half)
    {
        RUB excess = alice_assets - half;
        if (alice.vtb.account_rub >= excess)
        {
            alice.vtb.account_rub -= excess;
        }
        else
        {
            RUB remaining = excess - alice.vtb.account_rub;
            alice.vtb.account_rub = 0;
            alice.vtb.deposit.capital -= remaining;
            if (alice.vtb.deposit.capital < 0)
            {
                alice.vtb.stocks.capital += alice.vtb.deposit.capital;
                alice.vtb.deposit.capital = 0;
                if (alice.vtb.stocks.capital < 0)
                    alice.vtb.stocks.capital = 0;
            }
        }
    }
    else if (alice_assets < half)
    {
        RUB deficit = half - alice_assets;
        alice.vtb.account_rub += deficit;
        romance.partner.money -= deficit;
    }
    
    romance.status = SINGLE;
    romance.has_acquaintance_cooldown = true;
    romance.acquaintance_cooldown_months = 6;
    romance.months_since_meeting = 0;
    romance.partner.credit.active = false;
}



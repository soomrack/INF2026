        alice.vtb.account_rub -= price;
        alice.total_expenses += price;
        alice.estate.flats++;
        alice.estate.flats_alice++;
        alice.flats_bought++;
        alice.estate.total_spent_on_flats += price;
        romance.romance_stats.spent_on_flats += price;
    }
}




// ---------- REAL ESTATE ----------

void buy_flat_together()
{
    if (romance.status != MARRIED) return;
    
    RUB price = alice.estate.flat_price;
    RUB total_money = alice.cash_capital + romance.partner.money + romance.partner.deposit + romance.partner.stocks;
    
    if (total_money >= price)
    {
        RUB alice_share = std::min<long long>(alice.cash_capital, price);
        RUB remaining = price - alice_share;
        
        if (alice_share > 0)
        {
            sell_assets(alice_share);
        }
        
        if (remaining > 0)
        {
            if (romance.partner.money >= remaining)
            {
                romance.partner.money -= remaining;
            }
            else
            {
                remaining -= romance.partner.money;
                romance.partner.money = 0;
                
                if (romance.partner.deposit >= remaining)
                {
                    romance.partner.deposit -= remaining;
                }
                else
                {
                    remaining -= romance.partner.deposit;
                    romance.partner.deposit = 0;
                    romance.partner.stocks -= remaining;
                    if (romance.partner.stocks < 0)
                        romance.partner.stocks = 0;
                }
            }
        }
        
        alice.estate.flats++;
        alice.estate.flats_together++;
        alice.flats_bought_together++;
        alice.estate.total_spent_on_flats += price;
        romance.romance_stats.spent_on_flats += price;
        
        if (romance.partner.owns_housing)
        {
            romance.partner.owns_housing = false;
            alice.estate.rent_income += 25000;
        }
        
        alice.home.rent = 0;
    }
}



void alice_take_mortgage()
{
    update_total_capital();
    RUB price = alice.estate.flat_price;
    
    RUB total_capital_for_mortgage = alice.cash_capital;
    
    if (romance.status == MARRIED)
    {
        total_capital_for_mortgage += romance.partner.money + romance.partner.deposit + romance.partner.stocks;
    }
    
    RUB down_payment = price * 0.2;
    
    if (total_capital_for_mortgage < down_payment) return;
    if (alice.estate.mortgage.active) return;
    
    RUB alice_available = alice.cash_capital;
    
    if (alice_available < down_payment && romance.status != MARRIED) return;
    
    RUB alice_share = std::min<long long>(alice_available, down_payment);
    
    if (alice_share > 0)
    {
        sell_assets(alice_share);
    }
    
    RUB remaining = down_payment - alice_share;
    
    if (remaining > 0 && romance.status == MARRIED)
    {
        if (romance.partner.money >= remaining)
        {
            romance.partner.money -= remaining;
        }
        else
        {
            remaining -= romance.partner.money;
            romance.partner.money = 0;
            
            if (romance.partner.deposit >= remaining)
            {
                romance.partner.deposit -= remaining;
            }
            else
            {
                remaining -= romance.partner.deposit;
                romance.partner.deposit = 0;
                romance.partner.stocks -= remaining;
                if (romance.partner.stocks < 0)
                    romance.partner.stocks = 0;
            }
        }
    }
    
    alice.estate.mortgage.debt = price - down_payment;
    alice.estate.mortgage.payment = alice.estate.mortgage.debt * 0.01;
    alice.estate.mortgage.active = true;
    alice.estate.flats++;
    alice.estate.flats_mortgage++;
    alice.flats_bought++;
    alice.estate.total_spent_on_flats += down_payment;
    romance.romance_stats.spent_on_flats += down_payment;
    
    if (romance.status == MARRIED && romance.partner.owns_housing)
    {
        romance.partner.owns_housing = false;
    }
    
    alice.home.rent = 0;
}



void alice_pay_mortgage()
{
    if (!alice.estate.mortgage.active) return;

    RUB pay = alice.estate.mortgage.payment;
    sell_assets(pay);

    if (alice.vtb.account_rub < pay) return;

    alice.vtb.account_rub -= pay;
    alice.total_expenses += pay;
    alice.estate.mortgage.debt -= pay;

    if (alice.estate.mortgage.debt <= 0)
    {
        alice.estate.mortgage.active = false;
        alice.estate.mortgage.debt = 0;
    }
}



void alice_buy_flat()
{
    update_total_capital();
    
    RUB price = alice.estate.flat_price;
    
    if (romance.status == MARRIED)
    {
        RUB total_money = alice.cash_capital + romance.partner.money + romance.partner.deposit + romance.partner.stocks;
        if (total_money >= price)
        {
            buy_flat_together();
            return;

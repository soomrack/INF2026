// ---------- CREDIT SYSTEM ----------

Percent get_credit_rate()
{
    return 10 + economy.inflation * 0.5;
}



void take_credit(RUB amount)
{
    if (alice.vtb.credit.active) return;

    alice.vtb.credit.active = true;
    alice.vtb.credit.debt = amount;
    alice.vtb.credit.rate = get_credit_rate();
    alice.vtb.credit.monthly_payment = amount * (1 + alice.vtb.credit.rate / 100) / 24;

    alice.vtb.account_rub += amount;
}



void pay_credit()
{
    if (!alice.vtb.credit.active) return;

    RUB pay = alice.vtb.credit.monthly_payment;
    sell_assets(pay);

    alice.vtb.credit.rate = get_credit_rate();
    alice.vtb.credit.monthly_payment = alice.vtb.credit.debt * (1 + alice.vtb.credit.rate / 100) / 24;
    
    if (alice.vtb.account_rub >= pay)
    {
        alice.vtb.account_rub -= pay;
        alice.vtb.credit.debt -= pay;
        alice.vtb.credit.missed_payments = 0;
    }
    else
    {
        alice.vtb.credit.missed_payments++;
    }

    if (alice.vtb.credit.missed_payments >= 3)
    {
        alice.vtb.credit.active = false;
        alice.vtb.credit.debt = 0;

        if (alice.estate.flats > 0)
        {
            alice.estate.flats = 0;
            alice.home.rent = 30000;
        }

        alice.car.value = 0;
        alice.car.category = 0;
    }

    if (alice.vtb.credit.debt <= 0)
    {
        alice.vtb.credit.active = false;
        alice.vtb.credit.debt = 0;
    }
}



void partner_take_credit(RUB amount)
{
    if (romance.status != MARRIED) return;
    if (romance.partner.credit.active) return;

    romance.partner.credit.active = true;
    romance.partner.credit.debt = amount;
    romance.partner.credit.rate = get_credit_rate();
    romance.partner.credit.monthly_payment = amount * (1 + romance.partner.credit.rate / 100) / 24;

    romance.partner.money += amount;
}



void partner_pay_credit()
{
    if (romance.status != MARRIED) return;
    if (!romance.partner.credit.active) return;

    RUB pay = romance.partner.credit.monthly_payment;
    
    romance.partner.credit.rate = get_credit_rate();
    romance.partner.credit.monthly_payment = romance.partner.credit.debt * (1 + romance.partner.credit.rate / 100) / 24;
    
    if (romance.partner.money >= pay)
    {
        romance.partner.money -= pay;
        romance.partner.credit.debt -= pay;
        romance.partner.credit.missed_payments = 0;
    }
    else
    {
        romance.partner.credit.missed_payments++;
    }

    if (romance.partner.credit.missed_payments >= 3)
    {
        RUB remaining_debt = romance.partner.credit.debt;
        romance.partner.credit.active = false;
        romance.partner.credit.debt = 0;
        
        RUB alice_share = remaining_debt / 2;
        sell_assets(alice_share);
        alice.vtb.account_rub -= alice_share;
        alice.total_expenses += alice_share;
    }

    if (romance.partner.credit.debt <= 0)
    {
        romance.partner.credit.active = false;
        romance.partner.credit.debt = 0;
    }
}



// ---------- PARTNER INVESTMENT FUNCTIONS ----------

void partner_deposit()
{
    if (romance.status != MARRIED) return;
    
    RUB reserve = 50000;
    RUB free = romance.partner.money - reserve;
    
    if (free > 50000)
    {
        RUB to_deposit = free * 0.3;
        romance.partner.money -= to_deposit;
        romance.partner.deposit += to_deposit;
    }
    
    if (romance.partner.deposit > 0)
    {
        float rate = 0.005 + (rand() % 10) / 1000.0;
        romance.partner.deposit = romance.partner.deposit * (1 + rate);
    }
}



void partner_invest()
{
    if (romance.status != MARRIED) return;
    
    RUB free = romance.partner.money;
    
    if (free > 100000)
    {
        RUB to_invest = free * 0.2;
        romance.partner.money -= to_invest;
        romance.partner.stocks += to_invest;
    }
    
    if (romance.partner.stocks > 0)
    {
        int roll = rand() % 100;
        
        if (roll < 40)
            romance.partner.stocks *= 1.01;
        else if (roll < 80)
            romance.partner.stocks *= 0.99;
        else
            romance.partner.stocks *= 1.03;
    }
}



void partner_liquidate_for_flat()
{
    if (romance.status != MARRIED) return;
    
    RUB price = alice.estate.flat_price;
    RUB total_liquid = romance.partner.money + romance.partner.deposit + romance.partner.stocks;
    
    if (total_liquid >= price && !romance.partner.owns_housing)
    {
        romance.partner.money = total_liquid - price;
        romance.partner.deposit = 0;
        romance.partner.stocks = 0;
        romance.partner.owns_housing = true;
        
        if (romance.status == DATING)
        {
            romance.status = LIVING_TOGETHER;
            romance.partner.living_together_months = 0;
            alice.home.rent = 0;
        }
    }
}



// ---------- CAR ----------

RUB car_price_by_category(int c)
{
    if (c == 1) return 1200000;
    if (c == 2) return 2500000;
    return 5000000;
}



void alice_buy_car_credit()
{
    if (alice.car.value > 0) return;

    RUB price = car_price_by_category(1);

    if (!alice.vtb.credit.active)
    {
        take_credit(price);

        if (alice.vtb.account_rub >= price)
        {
            alice.vtb.account_rub -= price;
            alice.car.value = price;
            alice.car.category = 1;
            alice.car.last_replace_year = 2026 + (romance.partner.relationship_months / 12);
        }
    }
}



void update_car()
{
    int current_year = 2026 + (romance.partner.relationship_months / 12);
    
    if (alice.car.category == 0)
    {
        RUB price = car_price_by_category(1);
        if (alice.cash_capital >= price)
        {
            sell_assets(price);
            if (alice.vtb.account_rub >= price)
            {
                alice.vtb.account_rub -= price;
                alice.total_expenses += price;
                romance.romance_stats.spent_on_car += price;
                alice.car.category = 1;
                alice.car.value = price;
                alice.car.last_replace_year = current_year;
            }
        }
        return;
    }
    
    if (current_year - alice.car.last_replace_year >= 10)
    {
        int desired = alice.car.category + 1;
        if (desired > 3) desired = 3;
        
        RUB price = car_price_by_category(desired);
        
        if (alice.cash_capital >= price)
        {
            sell_assets(price);
            
            if (alice.vtb.account_rub >= price)
            {
                RUB old_car_value = alice.car.value * 0.5;
                alice.vtb.account_rub += old_car_value;
                alice.vtb.account_rub -= price;
                RUB net_expense = price - old_car_value;
                alice.total_expenses += net_expense;
                romance.romance_stats.spent_on_car += net_expense;
                alice.car.category = desired;
                alice.car.value = price;
                alice.car.replaced++;
                alice.car.last_replace_year = current_year;
            }
        }
    }
}



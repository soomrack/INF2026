            expense = 12000 + rand() % 13000;
        else if (age_years < 7)
            expense = 10000 + rand() % 12000;
        else if (age_years < 10)
            expense = 15000 + rand() % 15000;
        else if (age_years < 16)
            expense = 20000 + rand() % 20000;
        else if (age_years < 20)
            expense = 15000;
        else
            expense = 0;
        
        if (age_years < 3 && (romance.status == DATING || romance.status == MARRIED || romance.status == LIVING_TOGETHER))
        {
            RUB total_partner = romance.partner.money + romance.partner.deposit + romance.partner.stocks;
            if (total_partner >= expense)
            {
                if (romance.partner.money >= expense)
                    romance.partner.money -= expense;
                else
                {
                    RUB remaining = expense - romance.partner.money;
                    romance.partner.money = 0;
                    if (romance.partner.deposit >= remaining)
                        romance.partner.deposit -= remaining;
                    else
                    {
                        remaining -= romance.partner.deposit;
                        romance.partner.deposit = 0;
                        romance.partner.stocks -= remaining;
                        if (romance.partner.stocks < 0)
                            romance.partner.stocks = 0;
                    }
                }
            }
            else
                total_child_expense += expense - total_partner;
        }
        else
        {
            total_child_expense += expense;
        }
        
        child.age_months++;
    }
    
    if (romance.status == SINGLE && romance.romance_stats.marriages_count > 0)
    {
        total_child_expense /= 2;
    }
    
    if (total_child_expense > 0)
    {
        sell_assets(total_child_expense);
        alice.vtb.account_rub -= total_child_expense;
        alice.total_expenses += total_child_expense;
        romance.romance_stats.spent_on_children += total_child_expense;
    }
}




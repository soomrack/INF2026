// ---------- CAPITAL ----------

void update_total_capital()
{
    RUB rub_cash = alice.vtb.account_rub;
    RUB usd_cash = alice.vtb.account_usd * economy.rate_usd_rub;
    RUB deposit_cash = alice.vtb.deposit.capital;
    RUB stocks_cash = alice.vtb.stocks.capital;
    
    alice.cash_capital = rub_cash + usd_cash + deposit_cash + stocks_cash;
    if (alice.cash_capital < 0) alice.cash_capital = 0;
    
    alice.real_estate_capital = alice.estate.flats * alice.estate.flat_price;
    alice.car_capital = alice.car.value;
    
    alice.total_capital = alice.cash_capital + alice.real_estate_capital + alice.car_capital;
}



// ---------- HELPERS ----------

void use_usd_if_needed(RUB needed)
{
    RUB rub = alice.vtb.account_usd * economy.rate_usd_rub;
    RUB take = std::min(rub, needed);
    USD usd = take / economy.rate_usd_rub;

    alice.vtb.account_usd -= usd;
    alice.vtb.account_rub += take;
}



void sell_assets(RUB needed)
{
    if (needed <= 0) return;
    
    if (alice.vtb.account_rub >= needed) return;

    use_usd_if_needed(needed - alice.vtb.account_rub);
    if (alice.vtb.account_rub >= needed) return;

    RUB from_dep = std::min(alice.vtb.deposit.capital, needed);
    alice.vtb.deposit.capital -= from_dep;
    alice.vtb.account_rub += from_dep;
    if (alice.vtb.account_rub >= needed) return;

    RUB from_stocks = std::min(alice.vtb.stocks.capital, needed);
    alice.vtb.stocks.capital -= from_stocks;
    alice.vtb.account_rub += from_stocks;
    if (alice.vtb.account_rub >= needed) return;
    
    if (alice.car.value > 0)
    {
        RUB car_value = alice.car.value * 0.7;
        alice.vtb.account_rub += car_value;
        alice.car.value = 0;
        alice.car.category = 0;
        alice.car_capital = 0;
        if (alice.vtb.account_rub >= needed) return;
    }
    
    if (alice.estate.flats > 0)
    {
        RUB flat_value = alice.estate.flat_price * 0.9;
        
        if (alice.estate.flats_alice > 0)
        {
            alice.estate.flats_alice--;
        }
        else if (alice.estate.flats_together > 0)
        {
            alice.estate.flats_together--;
        }
        else if (alice.estate.flats_mortgage > 0)
        {
            alice.estate.flats_mortgage--;
        }
        else
        {
            return; 
        }

        alice.vtb.account_rub += flat_value;
        alice.estate.flats--;
    }
}




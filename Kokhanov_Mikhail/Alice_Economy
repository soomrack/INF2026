Pet create_pet(PetType t)
{
    Pet p;
    p.type = t;
    p.name = get_pet_name(t);
    p.age_months = 0;
    p.alive = true;
    p.death_chance = 1;

    if (t == CAT) { p.max_lives = 8; p.grief_weight = 6; }
    else if (t == DOG) { p.max_lives = 10; p.grief_weight = 8; }
    else if (t == HAMSTER) { p.max_lives = 3; p.grief_weight = 3; }
    else if (t == PARROT) { p.max_lives = 6; p.grief_weight = 7; }
    else if (t == RABBIT) { p.max_lives = 5; p.grief_weight = 5; }
    else { p.max_lives = 12; p.grief_weight = 9; }

    p.lives = p.max_lives;
    return p;

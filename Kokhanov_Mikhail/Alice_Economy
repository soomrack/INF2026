        update_usd_rate();
        alice_health_update(year);
        
        if (romance.acquaintance_cooldown_months > 0)
        {
            romance.acquaintance_cooldown_months--;
            if (romance.acquaintance_cooldown_months <= 0)
                romance.has_acquaintance_cooldown = false;
        }
        
        start_acquaintance(year, month);
        update_acquaintance();
        
        alice_salary(month, year);
        alice_freelance();
        alice_rent_income();
        alice_expenses(month, year);
        if (month == 12) alice_taxes();
        
        update_partner_money();
        update_dating_relationship(year, month);
        update_living_together(year, month);
        update_married_life(year, month);
        
        check_pregnancy(year, month);
        handle_pregnancy_decision(year, month);
        update_pregnancy(year, month);
        update_children_expenses();

        alice_take_mortgage();
        alice_pay_mortgage();
        alice_buy_flat();
        pay_credit();
        
        update_clothing(year, month);
        update_entertainment();
        update_hobbies();

        alice_car_update();
        alice_car_break();
        alice_buy_car_credit();
        alice_phone(year);
        alice_laptop(year);
        alice_deposit();
        alice_investments();

        pets_update();
        grief_update();
        pets_try_adopt();

        month++;
        if (month == 13)
        {
            month = 1;
            year++;
        }
    }
}


// ---------- PREPARE RESULTS ----------

void print_pets()
{
    int alive_count = 0;
    for (auto& p : pets.pets)
        if (p.alive) alive_count++;
    
    if (alive_count == 0)
    {
        printf("\nТекущие животные: нет\n");
    }
    else
    {
        printf("\nТекущие животные:\n");
        for (auto& p : pets.pets)
        {
            if (!p.alive) continue;
            const char* type = p.type == CAT ? "Кошка" : p.type == DOG ? "Собака" : p.type == HAMSTER ? "Хомяк" : p.type == PARROT ? "Попугай" : p.type == RABBIT ? "Кролик" : "Черепаха";
            printf("%s: %s, %d лет\n", type, p.name.c_str(), p.age_months / 12);
        }
    }
}


void print_current_partner()
{
    if (romance.status != SINGLE)
    {
        printf("\nТекущий партнер: %s\n", romance.partner.name.c_str());
        const char* status_text = romance.status == ACQUAINTANCE ? "Знакомый" : romance.status == DATING ? "Встречается" : romance.status == LIVING_TOGETHER ? "Не в браке, но живут вместе" : "Замужем";
        printf("Статус: %s\n", status_text);
        
        int total_months = 0;
        if (romance.status == ACQUAINTANCE) total_months = romance.months_since_meeting;
        else total_months = romance.partner.relationship_months;
        
        int years = total_months / 12;
        int months = total_months % 12;
        if (years > 0) printf("Длительность: %d год(а/лет) %d месяц(ев/ца)\n", years, months);
        else printf("Длительность: %d месяц(ев/ца)\n", months);

        printf("Жилье до отношений с Alice: %s\n", romance.partner.owns_housing ? "есть" : "нет");
    }
}


void print_children()
{
    if (!romance.children.empty())
    {
        printf("\nДети:\n");
        for (auto& child : romance.children)
        {
            printf("  %s (%s), %d лет, родился %d.%d.%d\n", 
                child.name.c_str(), 
                child.gender == "male" ? "мальчик" : "девочка",
                child.age_months / 12,
                child.birth_day, child.birth_month, child.birth_year);
        }
    }
}


